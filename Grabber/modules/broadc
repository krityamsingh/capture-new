        """Show broadcast guide"""
        guide_text = (
            "📖 **Broadcast System Guide**\n\n"
            "**Commands:**\n"
            "• `/broadcast <mode>` - Start broadcast\n"
            "• `/broadcast_cancel [id]` - Cancel broadcast\n"
            "• `/broadcast_status [id]` - Check status\n\n"
            "**Modes:**\n"
            "• `all` - Send to all users & groups\n"
            "• `users` - Send to users only (DMs)\n"
            "• `groups` - Send to groups only\n"
            "• `pin` - Send and pin in groups\n\n"
            "**Options:**\n"
            "• `-d` - Dry run (test without sending)\n"
            "• `-s` - Silent (no notifications)\n"
            "• `-t=60` - Schedule (seconds)\n\n"
            "**Examples:**\n"
            "`/broadcast all`\n"
            "`/broadcast groups -s`\n"
            "`/broadcast users -t=300`"
        )
        
        await callback_query.message.edit_text(guide_text)
    
    async def _show_stats(self, callback_query: CallbackQuery):
        """Show broadcast statistics"""
        try:
            users = await user_collection.distinct("user_id")
            groups = await top_global_groups_collection.distinct("group_id")
            
            active_broadcasts = len([b for b in self.active_broadcasts.values() if b['is_active']])
            
            stats_text = (
                f"📊 **Broadcast Statistics**\n\n"
                f"• Total Users: `{len(users)}`\n"
                f"• Total Groups: `{len(groups)}`\n"
                f"• Active Broadcasts: `{active_broadcasts}`"
            )
            
            await callback_query.message.edit_text(stats_text)
        except Exception as e:
            logger.error(f"Error showing stats: {e}")
    
    async def _log_broadcast_start(self, broadcast_data: Dict):
        """Log broadcast start to database"""
        try:
            await broadcast_collection.insert_one({
                'broadcast_id': broadcast_data['id'],
                'initiator_id': broadcast_data['initiator_id'],
                'initiator_name': broadcast_data['initiator_name'],
                'mode': broadcast_data['mode'],
                'start_time': broadcast_data['start_time'],
                'total_users': broadcast_data['total_users'],
                'total_groups': broadcast_data['total_groups'],
                'status': 'started',
                'options': broadcast_data['options']
            })
        except Exception as e:
            logger.error(f"Failed to log broadcast start: {e}")
    
    async def _log_broadcast_complete(self, broadcast_data: Dict):
        """Log broadcast completion to database"""
        try:
            await broadcast_collection.update_one(
                {'broadcast_id': broadcast_data['id']},
                {'$set': {
                    'end_time': datetime.now(),
                    'status': 'completed',
                    'users_sent': broadcast_data['users_sent'],
                    'users_failed': broadcast_data['users_failed'],
                    'groups_sent': broadcast_data['groups_sent'],
                    'groups_failed': broadcast_data['groups_failed']
                }}
            )
        except Exception as e:
            logger.error(f"Failed to log broadcast completion: {e}")
    
    async def _log_broadcast_cancelled(self, broadcast_data: Dict):
        """Log broadcast cancellation to database"""
        try:
            await broadcast_collection.update_one(
                {'broadcast_id': broadcast_data['id']},
                {'$set': {
                    'end_time': datetime.now(),
                    'status': 'cancelled',
                    'users_sent': broadcast_data['users_sent'],
                    'groups_sent': broadcast_data['groups_sent']
                }}
            )
        except Exception as e:
            logger.error(f"Failed to log broadcast cancellation: {e}")
    
    def _cleanup_broadcast(self, broadcast_id: str):
        """Cleanup broadcast resources"""
        if broadcast_id in self.active_broadcasts:
            del self.active_broadcasts[broadcast_id]
        
        if broadcast_id in self.broadcast_tasks:
            del self.broadcast_tasks[broadcast_id]
    
    def cleanup_all(self):
        """Cleanup all broadcast resources"""
        for task in self.broadcast_tasks.values():
            task.cancel()
        
        self.active_broadcasts.clear()
        self.broadcast_tasks.clear()

# Initialize broadcast manager
broadcast_manager = BroadcastManager()

# Register handlers
app.add_handler(filters.command("broadcast") & dev_filter, broadcast_manager.broadcast_command)
app.add_handler(filters.command("broadcast_cancel") & dev_filter, broadcast_manager.broadcast_cancel_command)
app.add_handler(filters.command("broadcast_status") & dev_filter, broadcast_manager.broadcast_status_command)
app.add_handler(filters.callback_query("broadcast_"), broadcast_manager.broadcast_callback_handler)
