@app.on_message(filters.command("sweetspicy") & filters.group)
async def cmd_sweetspicy(client, message: Message):
    chat_id = message.chat.id
    if chat_id in _games:
        phase = _games[chat_id].phase
        if phase == "joining":
            return await message.reply_text("⚠️ A lobby is already open! Tap **Join 💕**.")
        if phase == "playing":
            return await message.reply_text("⚠️ A game is in progress! Use /endgame to stop it.")

    user    = message.from_user
    session = GameSession(chat_id=chat_id, starter_id=user.id)
    session.players.append(Player(user_id=user.id, name=user.first_name))
    _games[chat_id] = session

    text = (
        f"🍬🌶️ **Sweet or Spicy — Ultimate Truth & Dare!**\n\n"
        f"**{user.first_name}** opened a party! 🎉\n\n"
        f"🎁 Complete challenges → earn **🪙 coins**\n"
        f"⭐ Hard/Lucky rounds → **anime character drops**\n"
        f"🔥 Chain wins → **streak bonuses**\n"
        f"🏆 Top scorer wins a **jackpot**!\n\n"
        f"👇 Tap **Join 💕** — lobby closes in **{LOBBY_WAIT}s**\n\n"
        f"**Players joined ({len(session.players)}):**\n"
        f"• {user.first_name}"
    )
    msg = await message.reply_text(text, reply_markup=_join_kb(chat_id))
    session.join_message_id = msg.id

    await asyncio.sleep(LOBBY_WAIT)
    if chat_id in _games and _games[chat_id].phase == "joining":
        s = _games[chat_id]
        if len(s.players) < 2:
            _games.pop(chat_id, None)
            try:
                await client.edit_message_text(
                    chat_id, session.join_message_id,
                    "❌ Game cancelled — not enough players joined (need at least 2).",
                    reply_markup=None
                )
            except Exception:
                pass
        else:
            await _begin_game(client, s)


@app.on_message(filters.command("endgame") & filters.group)
async def cmd_endgame(client, message: Message):
    chat_id = message.chat.id
    if chat_id not in _games:
        return await message.reply_text("❌ No active game in this chat.")

    session  = _games[chat_id]
    user     = message.from_user
    is_admin = False
    try:
        member = await client.get_chat_member(chat_id, user.id)
        if member.status.name in ("ADMINISTRATOR", "OWNER"):
            is_admin = True
    except Exception:
        pass

    if user.id != session.starter_id and not is_admin:
        return await message.reply_text("❌ Only the game starter or an admin can end the game.")

    await message.reply_text("🛑 Game ended early. Tallying results...")
    await _end_game(client, session)


