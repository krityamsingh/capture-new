@dataclass
class Player:
    user_id:      int
    name:         str
    sweet_score:  int = 0
    spicy_score:  int = 0
    skips:        int = 0
    coins_earned: int = 0
    streak:       int = 0
    chars_won:    int = 0

    @property
    def total(self) -> int:
        return self.sweet_score + self.spicy_score


@dataclass
class GameSession:
    chat_id:             int
    starter_id:          int
    players:             list[Player] = field(default_factory=list)
    phase:               str = "joining"
    current_player_idx:  int = 0
    round_num:           int = 1
    total_rounds:        int = ROUNDS_DEFAULT
    last_category:       Optional[str] = None
    last_type:           Optional[str] = None
    last_difficulty:     Optional[str] = None
    is_lucky_round:      bool = False
    used: dict = field(default_factory=lambda: {
        "sweet": {
            "truth": {"easy": set(), "medium": set(), "hard": set()},
            "dare":  {"easy": set(), "medium": set(), "hard": set()},
        },
        "spicy": {
            "truth": {"easy": set(), "medium": set(), "hard": set()},
            "dare":  {"easy": set(), "medium": set(), "hard": set()},
        },
    })
    join_message_id:     Optional[int] = None
    question_message_id: Optional[int] = None
    vote: Optional[dict] = None

    @property
    def current_player(self) -> Optional[Player]:
        if self.players:
            return self.players[self.current_player_idx % len(self.players)]
        return None

    def get_question(self, cat: str, q_type: str, difficulty: str) -> tuple[int, str]:
        pool     = QUESTIONS[cat][q_type][difficulty]
        used_set = self.used[cat][q_type][difficulty]
        avail    = [i for i in range(len(pool)) if i not in used_set]
        if not avail:
            used_set.clear()
            avail = list(range(len(pool)))
        idx = random.choice(avail)
        used_set.add(idx)
        return idx, pool[idx]

    def next_turn(self) -> bool:
        self.current_player_idx += 1
        if self.current_player_idx >= len(self.players):
            self.current_player_idx = 0
            self.round_num += 1
        if self.round_num > self.total_rounds:
            self.phase = "ended"
            return False
        self.is_lucky_round = (self.round_num % LUCKY_ROUND_EVERY == 0)
        return True


