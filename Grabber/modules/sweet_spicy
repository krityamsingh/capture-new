async def _get_random_character() -> Optional[dict]:
    try:
        count = await _char_collection.count_documents({})
        if count == 0:
            return None
        skip = random.randint(0, max(0, count - 1))
        async for doc in _char_collection.find({}).skip(skip).limit(1):
            return doc
    except Exception:
        return None

async def _award_coins(user_id: int, amount: int) -> int:
    """Add/deduct coins. Returns new balance."""
    try:
        uid = int(user_id)
        # First find the document to detect which field name is used
        doc = (
            await _user_collection.find_one({"id": uid})
            or await _user_collection.find_one({"user_id": uid})
        )
        if doc is None:
            # User not in collection yet — nothing to update
            return 0

        field_key = "id" if "id" in doc else "user_id"

        # Ensure balance field exists, then increment
        result = await _user_collection.find_one_and_update(
            {field_key: uid},
            {
                "$inc": {"balance": amount},
                "$setOnInsert": {field_key: uid},
            },
            return_document=True,   # return AFTER update
            upsert=False,
        )
        if result is not None:
            return int(result.get("balance", 0))
    except Exception:
        pass
    return 0

async def _add_char_to_user(user_id: int, char_id: str) -> bool:
    try:
        uid = int(user_id)
        for field_key in ("id", "user_id"):
            result = await _user_collection.find_one_and_update(
                {field_key: uid},
                {"$addToSet": {"characters": char_id}},
                return_document=True,
            )
            if result:
                return True
    except Exception:
        pass
    return False


