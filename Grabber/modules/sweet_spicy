@app.on_callback_query(filters.regex(r"^ss_"))
async def on_callback(client, query: CallbackQuery):
    data = query.data
    user = query.from_user

    # JOIN
    if data.startswith("ss_join:"):
        chat_id = int(data.split(":")[1])
        session = _games.get(chat_id)
        if not session or session.phase != "joining":
            return await query.answer("⏰ Lobby is closed!", show_alert=True)
        if any(p.user_id == user.id for p in session.players):
            return await query.answer("You already joined! 💕", show_alert=True)

        session.players.append(Player(user_id=user.id, name=user.first_name))
        await query.answer("You're in the game! 🎉")
        pl = "\n".join(f"• {p.name}" for p in session.players)
        try:
            await query.edit_message_text(
                f"🍬🌶️ **Sweet or Spicy!**\n\n"
                f"👇 Tap **Join 💕** to play!\n\n"
                f"**Players ({len(session.players)}):**\n{pl}",
                reply_markup=_join_kb(chat_id)
            )
        except MessageNotModified:
            pass

    # FORCE START
    elif data.startswith("ss_forcestart:"):
        chat_id = int(data.split(":")[1])
        session = _games.get(chat_id)
        if not session or session.phase != "joining":
            return await query.answer("No active lobby!", show_alert=True)
        if user.id != session.starter_id:
            return await query.answer("Only the host can force start! 😅", show_alert=True)
        if len(session.players) < 2:
            return await query.answer("Need at least 2 players first! 🙏", show_alert=True)
        await query.answer("Starting now! 🎮")
        try:
            await query.edit_message_reply_markup(reply_markup=None)
        except Exception:
            pass
        await _begin_game(client, session)

    # CATEGORY PICK
    elif data.startswith("ss_cat:"):
        parts   = data.split(":")
        cat     = parts[1]
        chat_id = int(parts[2])
        session = _games.get(chat_id)
        if not session or session.phase != "playing":
            return await query.answer("No active game!", show_alert=True)
        cp = session.current_player
        if not cp or user.id != cp.user_id:
            return await query.answer(f"It's {cp.name if cp else 'someone else'}'s turn! 😅", show_alert=True)
        await query.answer(f"{'🍬 Sweet' if cat == 'sweet' else '🌶️ Spicy'} — pick difficulty!")
        await _send_difficulty_pick(client, session, cat)

    # DIFFICULTY PICK
    elif data.startswith("ss_diff:"):
        parts      = data.split(":")
        difficulty = parts[1]
        cat        = parts[2]
        chat_id    = int(parts[3])
        session    = _games.get(chat_id)
        if not session or session.phase != "playing":
            return await query.answer("No active game!", show_alert=True)
        cp = session.current_player
        if not cp or user.id != cp.user_id:
            return await query.answer(f"It's {cp.name if cp else 'someone else'}'s turn! 😅", show_alert=True)
        await query.answer(f"{DIFFICULTY_META[difficulty]['label']} — let's go!")
        await _send_question(client, session, cat, difficulty)

    # DONE — triggers group vote instead of instant reward
    elif data.startswith("ss_done:"):
        chat_id = int(data.split(":")[1])
        session = _games.get(chat_id)
        if not session or session.phase != "playing":
            return await query.answer("No active game!", show_alert=True)
        cp = session.current_player
        if not cp or user.id != cp.user_id:
            return await query.answer(f"Only {cp.name if cp else 'the active player'} can do this! 😅", show_alert=True)
        if getattr(session, "vote", None) and not session.vote.get("resolved"):
            return await query.answer("A vote is already in progress!", show_alert=True)

        await query.answer("🗳️ Sending it to a group vote!")
        # Remove action buttons from the question card
        try:
            await client.edit_message_reply_markup(
                session.chat_id, session.question_message_id, reply_markup=None
            )
        except Exception:
            pass
        # Launch vote (this sleeps 30s internally — run as a task)
        asyncio.create_task(_send_vote(client, session))

    # VOTE
    elif data.startswith("ss_vote:"):
        parts   = data.split(":")
        verdict = parts[1]       # "yes" or "no"
        chat_id = int(parts[2])
        session = _games.get(chat_id)
        vote    = getattr(session, "vote", None)

        if not session or not vote or vote.get("resolved"):
            return await query.answer("This vote has already closed!", show_alert=True)

        cp = session.current_player
        # Active player cannot vote on their own challenge
        if cp and user.id == cp.user_id:
            return await query.answer("You can't vote on your own challenge! 😅", show_alert=True)

        # Only registered players can vote
        if user.id not in vote["voters"]:
            return await query.answer("Only players in this game can vote!", show_alert=True)

        # Remove previous vote if they're changing their mind
        vote["yes"] = [v for v in vote["yes"] if v != user.id]
        vote["no"]  = [v for v in vote["no"]  if v != user.id]

        if verdict == "yes":
            vote["yes"].append(user.id)
            await query.answer("✅ You voted YES!")
        else:
            vote["no"].append(user.id)
            await query.answer("❌ You voted NO!")

        yes_cnt = len(vote["yes"])
        no_cnt  = len(vote["no"])
        needed  = vote["needed"]
        total   = len(vote["voters"])

        # Update vote message with live counts
        diff    = session.last_difficulty or "easy"
        reward  = DIFFICULTY_META[diff]["coins"] * (LUCKY_COIN_MULT if session.is_lucky_round else 1)
        drop_hint = (
            " + **guaranteed ⭐ char drop!**" if (session.is_lucky_round or diff == "hard")
            else " + 🎲 chance for char drop" if diff == "medium"
            else ""
        )
        text = (
            f"🗳️ **Group Vote!**\n\n"
            f"Did {_mention(cp)} actually complete the challenge?\n\n"
            f"💰 Reward at stake: **{reward:,}🪙**{drop_hint}\n"
            f"✅ Need **{needed}/{total}** YES vote(s)\n\n"
            f"✅ Yes: **{yes_cnt}**  ❌ No: **{no_cnt}**\n"
            f"⏳ Voting closes in 30 seconds"
        )
        kb = InlineKeyboardMarkup([[
            InlineKeyboardButton(f"✅ Yes  ({yes_cnt})", callback_data=f"ss_vote:yes:{chat_id}"),
            InlineKeyboardButton(f"❌ No   ({no_cnt})",  callback_data=f"ss_vote:no:{chat_id}"),
        ]])
        try:
            await query.edit_message_text(text, reply_markup=kb, disable_web_page_preview=True)
        except MessageNotModified:
            pass

        # Auto-resolve immediately if all eligible players have voted
        all_voted = (yes_cnt + no_cnt) >= total
        if all_voted and not vote.get("resolved"):
            await _resolve_vote(client, session)

    # SKIP
    elif data.startswith("ss_skip:"):
        chat_id = int(data.split(":")[1])
        session = _games.get(chat_id)
        if not session or session.phase != "playing":
            return await query.answer("No active game!", show_alert=True)
        cp = session.current_player
        if not cp or user.id != cp.user_id:
            return await query.answer(f"Only {cp.name if cp else 'the active player'} can skip! 😅", show_alert=True)

        cp.skips             += 1
        cp.streak             = 0
        cp.coins_earned       = max(0, cp.coins_earned - COIN_SKIP_PENALTY)
        await _award_coins(cp.user_id, -COIN_SKIP_PENALTY)

        taunt = random.choice(SKIP_TAUNTS)
        await query.answer(f"⏭ Skipped! -{COIN_SKIP_PENALTY}🪙  {taunt}", show_alert=True)

        if session.last_category and session.last_difficulty:
            await _send_question(client, session, session.last_category, session.last_difficulty)
        else:
            await _send_turn(client, session)
