async def _send_question(client, session: GameSession, cat: str, difficulty: str):
    q_type               = random.choice(["truth", "dare"])
    session.last_category   = cat
    session.last_type       = q_type
    session.last_difficulty = difficulty

    _, question = session.get_question(cat, q_type, difficulty)
    cp          = session.current_player
    diff_meta   = DIFFICULTY_META[difficulty]

    type_emoji = {"sweet_truth": "💬", "sweet_dare": "🎀", "spicy_truth": "🌶️", "spicy_dare": "🔥"}
    emoji      = type_emoji.get(f"{cat}_{q_type}", "❓")
    cat_label  = "🍬 Sweet" if cat == "sweet" else "🌶️ Spicy"

    base_coins   = diff_meta["coins"]
    reward_coins = base_coins * (LUCKY_COIN_MULT if session.is_lucky_round else 1)
    lucky_note   = f" **×{LUCKY_COIN_MULT} Lucky!**" if session.is_lucky_round else ""

    streak_bonus = cp.streak * STREAK_BONUS
    streak_note  = f" + 🔥{streak_bonus} streak" if streak_bonus > 0 else ""

    char_drop_note = (
        "\n⭐ **Character drop guaranteed!**"
        if (session.is_lucky_round or difficulty == "hard") else
        "\n🎲 Chance for character drop!"
        if difficulty == "medium" else ""
    )

    text = (
        f"{emoji} **{cat_label} — {'Truth' if q_type == 'truth' else 'Dare'}** {diff_meta['emoji']}\n\n"
        f"👤 {_mention(cp)}, your challenge:\n\n"
        f"❝ *{question}* ❞\n\n"
        f"━━━━━━━━━━━━━━━━━\n"
        f"💰 Reward: **{reward_coins:,}🪙**{lucky_note}{streak_note}"
        f"{char_drop_note}\n"
        f"━━━━━━━━━━━━━━━━━\n"
        f"Only {_mention(cp)} can respond!"
    )
    try:
        await client.edit_message_text(
            session.chat_id, session.question_message_id, text,
            reply_markup=_action_kb(session.chat_id),
            disable_web_page_preview=True
        )
    except Exception:
        try:
            msg = await client.send_message(
                session.chat_id, text,
                reply_markup=_action_kb(session.chat_id),
                disable_web_page_preview=True
            )
            session.question_message_id = msg.id
        except Exception:
            pass


async def _send_vote(client, session: GameSession):
    """Ask the group to vote on whether the active player completed the challenge."""
    cp      = session.current_player
    diff    = session.last_difficulty or "easy"
    reward  = DIFFICULTY_META[diff]["coins"] * (LUCKY_COIN_MULT if session.is_lucky_round else 1)
    others  = [p for p in session.players if p.user_id != cp.user_id]
    needed  = max(1, len(others))

    # Store vote state on session
    session.vote = {
        "yes":    [],        # user_ids who voted YES
        "no":     [],        # user_ids who voted NO
        "needed": needed,    # YES votes required to pass
        "voters": [p.user_id for p in others],  # who is allowed to vote
        "msg_id": None,
        "resolved": False,
    }

    drop_hint = (
        " + **guaranteed ⭐ char drop!**" if (session.is_lucky_round or diff == "hard")
        else " + 🎲 chance for char drop" if diff == "medium"
        else ""
    )

    text = (
        f"🗳️ **Group Vote!**\n\n"
        f"Did {_mention(cp)} actually complete the challenge?\n\n"
        f"💰 Reward at stake: **{reward:,}🪙**{drop_hint}\n"
        f"✅ Need **{needed}/{len(others)}** YES vote(s) to confirm\n\n"
        f"👥 Only other players can vote!\n"
        f"⏳ Voting closes in **30 seconds**"
    )
    kb = InlineKeyboardMarkup([[
        InlineKeyboardButton("✅ Yes  (0)", callback_data=f"ss_vote:yes:{session.chat_id}"),
        InlineKeyboardButton("❌ No   (0)", callback_data=f"ss_vote:no:{session.chat_id}"),
    ]])
    try:
        msg = await client.send_message(
            session.chat_id, text,
            reply_markup=kb, disable_web_page_preview=True
        )
        session.vote["msg_id"] = msg.id
    except Exception:
        pass

    # Auto-resolve after 30s if nobody voted
    await asyncio.sleep(30)
    if session.chat_id in _games and not session.vote.get("resolved"):
        await _resolve_vote(client, session, timed_out=True)


async def _resolve_vote(client, session: GameSession, timed_out: bool = False):
    """Finalise the vote — award rewards if passed, deny if failed."""
    vote = getattr(session, "vote", None)
    if not vote or vote.get("resolved"):
        return
    vote["resolved"] = True

    cp      = session.current_player
    yes_cnt = len(vote["yes"])
    no_cnt  = len(vote["no"])
    needed  = vote["needed"]
    passed  = yes_cnt >= needed

    # Remove vote buttons
    try:
        await client.edit_message_reply_markup(
            session.chat_id, vote["msg_id"], reply_markup=None
        )
    except Exception:
        pass

    if not passed:
        reason = (
            "⏰ Time's up — not enough votes came in."
            if timed_out
            else f"❌ Group voted NO ({no_cnt} no vs {yes_cnt} yes)."
        )
        if cp:
            cp.streak = 0   # reset streak on failed/rejected
        await client.send_message(
            session.chat_id,
            f"{reason}\n\n"
            f"😬 **{cp.name if cp else '?'}** gets nothing this round!\n\n"
            f"{_scoreboard(session)}",
            disable_web_page_preview=True
        )
    else:
        # Vote passed — award coins + possible char drop
        await _award_completion(client, session, cp)

    session.vote = None

    # Advance turn
    await asyncio.sleep(2)
    if not session.next_turn():
        await _end_game(client, session)
    else:
        await _send_turn(client, session)


async def _award_completion(client, session: GameSession, cp: Player):
    """Award coins and trigger character drop after vote passes."""
    diff       = session.last_difficulty or "easy"
    cat        = session.last_category   or "sweet"
    base_coin  = DIFFICULTY_META[diff]["coins"]
    mult       = LUCKY_COIN_MULT if session.is_lucky_round else 1
    coins      = base_coin * mult

    streak_bonus = cp.streak * STREAK_BONUS
    coins       += streak_bonus
    cp.streak   += 1

    if cat == "sweet":
        cp.sweet_score += 1
    else:
        cp.spicy_score += 1

    cp.coins_earned += coins
    new_balance = await _award_coins(cp.user_id, coins)

    react       = random.choice(REACTIONS[cat])
    streak_line = f"\n🔥 **{cp.streak}x STREAK BONUS!** +{streak_bonus}🪙 extra!" if cp.streak >= 2 else ""
    breakdown   = f"+{base_coin * mult:,} base" + (f" +{streak_bonus:,} streak" if streak_bonus else "")

    result_text = (
        f"✅ **{cp.name}** crushed the challenge!\n"
        f"{react}"
        f"{streak_line}\n\n"
        f"💰 **+{coins:,}🪙** ({breakdown})\n"
        f"🏦 New balance: `{new_balance:,}🪙`\n\n"
        f"{_scoreboard(session)}"
    )
    try:
        await client.send_message(session.chat_id, result_text, disable_web_page_preview=True)
    except Exception:
        pass

    # ── Character drop ────────────────────────────────────────────────────── #
    drop_chance = {"easy": 0.15, "medium": 0.40, "hard": 1.0}[diff]
    if session.is_lucky_round:
        drop_chance = 1.0

    if random.random() < drop_chance:
        char = await _get_random_character()
        if char:
            await _add_char_to_user(cp.user_id, str(char.get("_id", "")))
            cp.chars_won += 1

            char_name   = char.get("name",   char.get("character_name", "Unknown"))
            char_anime  = char.get("anime",  char.get("series",         "Unknown Anime"))
            char_rarity = char.get("rarity", "Common")
            char_img    = char.get("img",    char.get("image_url",       None))

            rarity_emoji = {
                "common": "⚪", "uncommon": "🟢", "rare":  "🔵",
                "epic":   "🟣", "legendary":"🟡", "mythic":"🔴",
            }.get(str(char_rarity).lower(), "✨")

            char_caption = (
                f"⭐ **CHARACTER DROP!** ⭐\n\n"
                f"🎴 **{char_name}**\n"
                f"📺 *{char_anime}*\n"
                f"{rarity_emoji} Rarity: `{char_rarity}`\n\n"
                f"🎉 Added to {_mention(cp)}'s harem collection!"
            )
            try:
                if char_img:
                    await client.send_photo(session.chat_id, photo=char_img, caption=char_caption)
                else:
                    await client.send_message(session.chat_id, char_caption, disable_web_page_preview=True)
            except Exception:
                try:
                    await client.send_message(session.chat_id, char_caption, disable_web_page_preview=True)
                except Exception:
                    pass


async def _end_game(client, session: GameSession):
    session.phase = "ended"
    _games.pop(session.chat_id, None)

    if not session.players:
        await client.send_message(session.chat_id, "Game ended. 👋")
        return

    sorted_p = sorted(session.players, key=lambda p: p.coins_earned, reverse=True)
    winner   = sorted_p[0]

    jackpot       = random.randint(100, 500)
    total_bonus   = WINNER_BONUS + jackpot
    winner_bal    = await _award_coins(winner.user_id, total_bonus)
    winner.coins_earned += total_bonus

    for p in session.players:
        if p.user_id != winner.user_id:
            await _award_coins(p.user_id, PARTICIPATION)

    total_sweet = sum(p.sweet_score for p in session.players)
    total_spicy = sum(p.spicy_score for p in session.players)
    vibe = (
        "You're all total sweethearts! 🍬💕"       if total_sweet > total_spicy else
        "This group is absolutely unhinged! 🌶️🔥" if total_spicy > total_sweet else
        "Perfectly balanced — sweet AND spicy! 💘"
    )

    best_streak  = max(session.players, key=lambda p: p.streak)
    most_chars   = max(session.players, key=lambda p: p.chars_won)
    streak_line  = f"\n🔥 **Streak King:** {_mention(best_streak)} ({best_streak.streak}x!)" if best_streak.streak >= 2 else ""
    char_line    = f"\n⭐ **Collector:** {_mention(most_chars)} ({most_chars.chars_won} chars!)" if most_chars.chars_won else ""

    text = (
        f"🎊 **GAME OVER!** 🎊\n\n"
        f"🏆 **Winner: {_mention(winner)}**\n"
        f"🎰 MVP Jackpot: **+{total_bonus:,}🪙** (balance: `{winner_bal:,}`)"
        f"{streak_line}"
        f"{char_line}\n\n"
        f"{'━' * 18}\n"
        f"{_scoreboard(session)}\n"
        f"{'━' * 18}\n\n"
        f"🎁 Everyone gets **+{PARTICIPATION}🪙** for playing!\n\n"
        f"✨ *{vibe}*\n\n"
        f"▶️ Start again with /sweetspicy"
    )
    await client.send_message(session.chat_id, text, disable_web_page_preview=True)


