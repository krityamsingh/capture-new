async def _begin_game(client, session: GameSession):
    random.shuffle(session.players)
    session.phase              = "playing"
    session.current_player_idx = 0
    session.round_num          = 1
    session.is_lucky_round     = False

    names = " • ".join(p.name for p in session.players)
    await client.send_message(
        session.chat_id,
        f"🎮 **Game Starting!**\n\n"
        f"👥 Players: {names}\n"
        f"🔄 {session.total_rounds} rounds each\n"
        f"🎰 Round {LUCKY_ROUND_EVERY}, {LUCKY_ROUND_EVERY*2}, {LUCKY_ROUND_EVERY*3}… = **Lucky Rounds** "
        f"(double coins + char drop!)\n\n"
        f"Goodluck~ 🔥",
        disable_web_page_preview=True
    )
    await asyncio.sleep(1)
    await _send_turn(client, session)


async def _send_turn(client, session: GameSession):
    cp = session.current_player
    if not cp:
        return

    lucky_banner = f"\n\n{random.choice(LUCKY_TAUNTS)}\n" if session.is_lucky_round else ""

    total_turns = session.total_rounds * len(session.players)
    done_turns  = (session.round_num - 1) * len(session.players) + session.current_player_idx
    done_turns  = min(done_turns, total_turns)
    bar         = "▓" * done_turns + "░" * max(0, total_turns - done_turns)

    text = (
        f"╔══════════════════════╗\n"
        f"   🍬 **Sweet or Spicy** 🌶️\n"
        f"╚══════════════════════╝"
        f"{lucky_banner}\n"
        f"📍 Round **{session.round_num}/{session.total_rounds}**  `{bar}`\n\n"
        f"👉 It's {_mention(cp)}'s turn!\n"
        f"{'🔥 Streak: **' + str(cp.streak) + '** ' + '🔥' * min(cp.streak, 5) if cp.streak > 0 else ''}\n\n"
        f"Pick your category 👇"
    )
    try:
        msg = await client.send_message(
            session.chat_id, text,
            reply_markup=_category_kb(session.chat_id, session.is_lucky_round),
            disable_web_page_preview=True
        )
        session.question_message_id = msg.id
    except Exception:
        pass


