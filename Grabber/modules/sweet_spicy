def _mention(p: Player) -> str:
    return f"[{p.name}](tg://user?id={p.user_id})"

def _scoreboard(session: GameSession) -> str:
    if not session.players:
        return ""
    lines = ["📊 **Live Scoreboard:**"]
    for i, p in enumerate(sorted(session.players, key=lambda x: x.coins_earned, reverse=True), 1):
        medal  = ["🥇", "🥈", "🥉"][i - 1] if i <= 3 else f"{i}."
        streak = f" 🔥×{p.streak}" if p.streak >= 2 else ""
        stars  = "⭐" * p.chars_won if p.chars_won else ""
        lines.append(f"{medal} {_mention(p)} — ✅`{p.total}` 🪙`{p.coins_earned:,}`{streak} {stars}")
    return "\n".join(lines)

