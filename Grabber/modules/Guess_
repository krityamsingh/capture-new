    user_id = message.from_user.id
    user_data = await get_user_data(user_id)
    
    keyboard = []
    for i in range(1, 11):
        req = achievement_levels[i]
        achieved = user_data.get("guesses", 0) >= req["guesses"]
        claimed = user_data.get("achievement_claims", {}).get(str(i), False)
        
        if achieved and not claimed:
            text = f"бҙ„КҹбҙҖЙӘбҙҚ КҹбҙҮбҙ бҙҮКҹ {i} КҖбҙҮбҙЎбҙҖКҖбҙ…"
            callback = f"claim_{i}"
        elif claimed:
            text = f"КҹбҙҮбҙ бҙҮКҹ {i} вң… бҙ„КҹбҙҖЙӘбҙҚбҙҮбҙ…"
            callback = f"claimed_{i}"
        else:
            text = f"КҹбҙҮбҙ бҙҮКҹ {i} ({user_data.get('guesses', 0)}/{req['guesses']})"
            callback = f"locked_{i}"
        
        keyboard.append([InlineKeyboardButton(text, callback_data=callback)])
    
    await message.reply(
        "рҹҸҶ **бҙҖбҙ„КңЙӘбҙҮбҙ бҙҮбҙҚбҙҮЙҙбҙӣ КҖбҙҮбҙЎбҙҖКҖбҙ…s**\n\n"
        "бҙҮбҙҖКҖЙҙ КҖбҙҮбҙЎбҙҖКҖбҙ…s КҷКҸ бҙҚбҙҖбҙӢЙӘЙҙЙў бҙ„бҙҸКҖКҖбҙҮбҙ„бҙӣ ЙўбҙңбҙҮssбҙҮs ЙӘЙҙ бҙӣКңбҙҮ ЙўбҙҖбҙҚбҙҮ!\n"
        "бҙ„КҹЙӘбҙ„бҙӢ бҙӣбҙҸ бҙ„КҹбҙҖЙӘбҙҚ бҙҖбҙ бҙҖЙӘКҹбҙҖКҷКҹбҙҮ КҖбҙҮбҙЎбҙҖКҖбҙ…s:",
        reply_markup=InlineKeyboardMarkup(keyboard)
    )

@bot.on_callback_query()
async def handle_achievement_claim(client: Client, callback_query: CallbackQuery):
    data = callback_query.data
    user_id = callback_query.from_user.id
    
    if data.startswith("claim_"):
        level = int(data.split("_")[1])
        user_data = await get_user_data(user_id)
        
        if (user_data.get("guesses", 0) >= achievement_levels[level]["guesses"] and 
            not user_data.get("achievement_claims", {}).get(str(level), False)):
            
            # Get reward characters
            reward_rarity = achievement_levels[level]["reward"]
            count = achievement_levels[level]["claims"]
            characters = []
            
            for _ in range(count):
                _, pipeline = get_random_character_weighted()
                character = await collection.aggregate(pipeline).to_list(1)
                if character:
                    characters.append(character[0])
            
            if characters:
                # Add characters to user's collection
                await user_collection.update_one(
                    {"id": user_id},
                    {
                        "$push": {"characters": {"$each": characters}},
                        "$set": {f"achievement_claims.{level}": True}
                    }
                )
                
                reward_text = "\n".join(
                    f"рҹҢҹ {c['name']} ({c['anime']}) - {c['rarity']}"
                    for c in characters
                )
                
                await callback_query.answer(f"рҹҺү КҸбҙҸбҙң КҖбҙҮбҙ„бҙҮЙӘбҙ бҙҮбҙ… {count} {reward_rarity} бҙ„КңбҙҖКҖбҙҖбҙ„бҙӣбҙҮКҖs!")
                await callback_query.message.edit(
                    text=f"рҹҺҒ **КҖбҙҮбҙЎбҙҖКҖбҙ… бҙ„КҹбҙҖЙӘбҙҚбҙҮбҙ…!** КҸбҙҸбҙң КҖбҙҮбҙ„бҙҮЙӘбҙ бҙҮбҙ…:\n\n{reward_text}",
                    reply_markup=None
                )
            else:
                await callback_query.answer("вқҢ Т“бҙҖЙӘКҹбҙҮбҙ… бҙӣбҙҸ ЙўбҙҮбҙӣ КҖбҙҮбҙЎбҙҖКҖбҙ… бҙ„КңбҙҖКҖбҙҖбҙ„бҙӣбҙҮКҖs. бҙӣКҖКҸ бҙҖЙўбҙҖЙӘЙҙ КҹбҙҖбҙӣбҙҮКҖ.")
        else:
            await callback_query.answer("вҡ пёҸ КҸбҙҸбҙң бҙ„бҙҖЙҙ'бҙӣ бҙ„КҹбҙҖЙӘбҙҚ бҙӣКңЙӘs КҖбҙҮбҙЎбҙҖКҖбҙ… КҸбҙҮбҙӣ!")
    elif data.startswith("locked_"):
        level = int(data.split("_")[1])
        req = achievement_levels[level]
        await callback_query.answer(f"рҹ”’ КҸбҙҸбҙң ЙҙбҙҮбҙҮбҙ… {req['guesses']} бҙӣбҙҸбҙӣбҙҖКҹ ЙўбҙңбҙҮssбҙҮs бҙӣбҙҸ бҙңЙҙКҹбҙҸбҙ„бҙӢ бҙӣКңЙӘs КҖбҙҮбҙЎбҙҖКҖбҙ…!")
    elif data.startswith("claimed_"):
        await callback_query.answer("вң… КҸбҙҸбҙң'бҙ бҙҮ бҙҖКҹКҖбҙҮбҙҖбҙ…КҸ бҙ„КҹбҙҖЙӘбҙҚбҙҮбҙ… бҙӣКңЙӘs КҖбҙҮбҙЎбҙҖКҖбҙ…!")

# Auto-start game after 2 minutes
async def auto_start_check():
    while True:
        current_time = time.time()
        for chat_id, room in list(waiting_rooms.items()):
            if current_time - room["start_time"] > 120 and len(room["players"]) >= 2:
                await start_actual_game(chat_id)
        
        await asyncio.sleep(10)

# Start the auto-start checker when bot starts
async def startup():
    asyncio.create_task(auto_start_check())

bot.run(startup())
