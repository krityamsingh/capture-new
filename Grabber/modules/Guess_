async def start_actual_game(chat_id):
    if chat_id not in waiting_rooms:
        return
    
    players = waiting_rooms[chat_id]["players"]
    del waiting_rooms[chat_id]
    
    # Initialize game
    active_games[chat_id] = {
        "players": players,
        "current_turn": random.choice(list(players.keys())),
        "round": 1,
        "character": None,
        "start_time": time.time(),
        "last_activity": time.time(),
        "waiting_for_guess": False
    }
    
    # Start first turn
    await start_new_turn(chat_id)

async def start_new_turn(chat_id):
    if chat_id not in active_games:
        return
    
    game = active_games[chat_id]
    current_player_id = game["current_turn"]
    current_player = game["players"][current_player_id]
    
    # Get new character
    rarity, pipeline = get_random_character_weighted()
    character = await collection.aggregate(pipeline).to_list(1)
    if not character:
        await bot.send_message(chat_id, "вқҢ **Т“бҙҖЙӘКҹбҙҮбҙ… бҙӣбҙҸ ЙўбҙҮбҙӣ бҙ„КңбҙҖКҖбҙҖбҙ„бҙӣбҙҮКҖ. бҙҮЙҙбҙ…ЙӘЙҙЙў ЙўбҙҖбҙҚбҙҮ.**")
        del active_games[chat_id]
        return
    
    character = character[0]
    game["character"] = character
    game["last_activity"] = time.time()
    game["waiting_for_guess"] = True
    
    # Send character image
    caption = (
        f"рҹҺҙ **КҖбҙҸбҙңЙҙбҙ… {game['round']}** | {current_player['name']}'s бҙӣбҙңКҖЙҙ!\n"
        f"вҸі **КҸбҙҸбҙң КңбҙҖбҙ бҙҮ 2 бҙҚЙӘЙҙбҙңбҙӣбҙҮs бҙӣбҙҸ ЙўбҙңбҙҮss бҙӣКңЙӘs бҙ„КңбҙҖКҖбҙҖбҙ„бҙӣбҙҮКҖ!**\n"
        f"рҹ’Ў **КңЙӘЙҙбҙӣ:** Т“КҖбҙҸбҙҚ {character['anime']}\n\n"
        f"рҹҸҶ **бҙ„бҙңКҖКҖбҙҮЙҙбҙӣ sбҙ„бҙҸКҖбҙҮs:**\n" +
        "\n".join(f"{p['name']}: {p['score']}" for p in game["players"].values())
    )
    
    await bot.send_photo(
        chat_id,
        character["img_url"],
        caption=caption
    )
    
    # Start timer
    asyncio.create_task(turn_timer(chat_id))

async def turn_timer(chat_id):
    await asyncio.sleep(120)  # 2 minutes
    
    if chat_id not in active_games:
        return
    
    game = active_games[chat_id]
    if not game["waiting_for_guess"]:  # Someone answered
        return
    
    current_player_id = game["current_turn"]
    game["players"][current_player_id]["missed_turns"] += 1
    
    # Check if player should be eliminated
    if game["players"][current_player_id]["missed_turns"] >= 2:
        await bot.send_message(
            chat_id,
            f"вҸ° **бҙӣЙӘбҙҚбҙҮ's бҙңбҙҳ!** {game['players'][current_player_id]['name']} бҙҚЙӘssбҙҮбҙ… бҙӣКңбҙҮЙӘКҖ бҙӣбҙңКҖЙҙ бҙӣбҙЎЙӘбҙ„бҙҮ бҙҖЙҙбҙ… ЙӘs бҙҮКҹЙӘбҙҚЙӘЙҙбҙҖбҙӣбҙҮбҙ…!"
        )
        del game["players"][current_player_id]
    else:
        await bot.send_message(
            chat_id,
            f"вҸ° **бҙӣЙӘбҙҚбҙҮ's бҙңбҙҳ!** {game['players'][current_player_id]['name']} бҙҚЙӘssбҙҮбҙ… бҙӣКңбҙҮЙӘКҖ бҙӣбҙңКҖЙҙ!"
        )
    
    # Check if game should end
    if len(game["players"]) < 2:
        await end_game(chat_id)
        return
    
    # Move to next turn
    game["waiting_for_guess"] = False
    await next_turn(chat_id)

async def next_turn(chat_id):
    if chat_id not in active_games:
        return
    
    game = active_games[chat_id]
    player_ids = list(game["players"].keys())
    current_index = player_ids.index(game["current_turn"])
    next_index = (current_index + 1) % len(player_ids)
    game["current_turn"] = player_ids[next_index]
    game["round"] += 1
    
    await start_new_turn(chat_id)

async def end_game(chat_id):
    if chat_id not in active_games:
        return
    
    game = active_games[chat_id]
    winner_id, winner_data = max(game["players"].items(), key=lambda x: x[1]["score"])
    
    # Update user stats
    for player_id, player_data in game["players"].items():
        user_data = await get_user_data(player_id)
        update_data = {
            "games_played": user_data.get("games_played", 0) + 1,
            "xp": user_data.get("xp", 0) + (XP_PER_GUESS * player_data["score"])
        }
        
        if player_id == winner_id:
            update_data["games_won"] = user_data.get("games_won", 0) + 1
            update_data["xp"] += XP_BONUS["game_win"]
        
        await update_user_data(player_id, update_data)
    
    # Announce winner
    await bot.send_message(
        chat_id,
        f"рҹҸҶ **ЙўбҙҖбҙҚбҙҮ бҙҸбҙ бҙҮКҖ!** рҹҸҶ\n\n"
        f"рҹҺү {winner_data['name']} бҙЎЙӘЙҙs бҙЎЙӘбҙӣКң {winner_data['score']} бҙҳбҙҸЙӘЙҙбҙӣs!\n\n"
        f"Т“ЙӘЙҙбҙҖКҹ sбҙ„бҙҸКҖбҙҮs:\n" +
        "\n".join(
            f"{i+1}. {p['name']}: {p['score']}" 
            for i, p in enumerate(sorted(
                game["players"].values(),
                key=lambda x: x["score"],
                reverse=True
            ))
        )
    )
    
    del active_games[chat_id]

@bot.on_message(filters.text & filters.group)
async def handle_guess(client: Client, message: Message):
    chat_id = message.chat.id
    user_id = message.from_user.id
    
    if chat_id not in active_games:
        return
    
    game = active_games[chat_id]
    if not game["waiting_for_guess"] or user_id != game["current_turn"]:
        return
    
    guess = message.text.strip()
    character_name = game["character"]["name"]
    
    user_data = await get_user_data(user_id)
    
    if is_correct_guess(guess, character_name):
        # Correct guess
        game["players"][user_id]["score"] += 1
        game["players"][user_id]["missed_turns"] = 0
        game["waiting_for_guess"] = False
        
        # Update user stats
        xp_earned = XP_PER_GUESS + XP_BONUS["correct_guess"]
        if game["character"]["rarity"] != "вҡ« Common":
            xp_earned += XP_BONUS["rare_character"]
        
        await update_user_data(user_id, {
            "correct_guesses": user_data.get("correct_guesses", 0) + 1,
            "guesses": user_data.get("guesses", 0) + 1,
            "xp": user_data.get("xp", 0) + xp_earned
        })
        
        await message.reply(
            f"вң… **бҙ„бҙҸКҖКҖбҙҮбҙ„бҙӣ!** {message.from_user.mention} ЙўбҙңбҙҮssбҙҮбҙ… ЙӘбҙӣ!\n"
            f"рҹҺү **+1 бҙҳбҙҸЙӘЙҙбҙӣ!** КҸбҙҸбҙң'бҙ бҙҮ бҙҮбҙҖКҖЙҙбҙҮбҙ… {xp_earned} xбҙҳ!\n"
            f"рҹҢҹ **бҙ„КңбҙҖКҖбҙҖбҙ„бҙӣбҙҮКҖ:** {character_name} ({game['character']['anime']})"
        )
        
        # Move to next turn
        await next_turn(chat_id)
    else:
        # Incorrect guess - only update guesses count
        await update_user_data(user_id, {
            "guesses": user_data.get("guesses", 0) + 1
        })

