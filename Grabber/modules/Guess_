@bot.on_message(filters.command("mystats"))
async def my_stats(client: Client, message: Message):
    user_id = message.from_user.id
    user_data = await get_user_data(user_id)
    
    level = calculate_level(user_data.get("xp", 0))
    next_level_xp = (level ** 2) * 1000
    progress = (user_data.get("xp", 0) / next_level_xp) * 100 if next_level_xp > 0 else 0
    
    stats_text = (
        f"рҹ“Ҡ **{message.from_user.mention}'s sбҙӣбҙҖбҙӣs**\n\n"
        f"рҹҸ… **КҹбҙҮбҙ бҙҮКҹ:** {level}\n"
        f"вңЁ **xбҙҳ:** {user_data.get('xp', 0)}/{next_level_xp} ({progress:.1f}%)\n\n"
        f"рҹ”№ **бҙӣбҙҸбҙӣбҙҖКҹ бҙ„КңбҙҖКҖбҙҖбҙ„бҙӣбҙҮКҖs:** {len(user_data.get('characters', []))}\n"
        f"рҹ”№ **бҙӣбҙҸбҙӣбҙҖКҹ ЙўбҙңбҙҮssбҙҮs:** {user_data.get('guesses', 0)}\n"
        f"рҹ”№ **бҙ„бҙҸКҖКҖбҙҮбҙ„бҙӣ ЙўбҙңбҙҮssбҙҮs:** {user_data.get('correct_guesses', 0)}\n"
        f"рҹ”№ **ЙўбҙҖбҙҚбҙҮs бҙҳКҹбҙҖКҸбҙҮбҙ…:** {user_data.get('games_played', 0)}\n"
        f"рҹ”№ **ЙўбҙҖбҙҚбҙҮs пҝҪбҙҸЙҙ:** {user_data.get('games_won', 0)}\n\n"
        f"рҹҺ® **бҙҖбҙ„КңЙӘбҙҮбҙ бҙҮбҙҚбҙҮЙҙбҙӣ бҙҳКҖбҙҸЙўКҖбҙҮss:**\n"
    )
    
    # Add achievement progress
    for level, req in achievement_levels.items():
        achieved = user_data.get("guesses", 0) >= req["guesses"]
        claimed = user_data.get("achievement_claims", {}).get(str(level), False)
        status = "вң…" if claimed else "вҳ‘пёҸ" if achieved else "вқҢ"
        stats_text += (
            f"КҹбҙҮбҙ бҙҮКҹ {level}: {req['guesses']} ЙўбҙңбҙҮssбҙҮs {status} "
            f"(КҖбҙҮбҙЎбҙҖКҖбҙ…: {rarity_system[req['reward']]['emoji']} x{req['claims']})\n"
        )
    
    await message.reply(stats_text)

