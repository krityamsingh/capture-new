# Helper functions
def calculate_level(xp):
    return int((xp / 1000) ** 0.5) + 1

def get_random_character_weighted():
    total_weight = sum(rarity['weight'] for rarity in rarity_system.values())
    rand = random.uniform(0, total_weight)
    current = 0
    for rarity, data in rarity_system.items():
        if current + data['weight'] >= rand:
            pipeline = [
                {"$match": {"rarity": rarity}},
                {"$sample": {"size": 1}}
            ]
            return rarity, pipeline
        current += data['weight']
    return 'вҡ« Common', [{"$match": {"rarity": "вҡ« Common"}}, {"$sample": {"size": 1}}]

async def get_user_data(user_id):
    user_data = await user_collection.find_one({"id": user_id})
    if not user_data:
        user_data = {
            "id": user_id,
            "characters": [],
            "guesses": 0,
            "correct_guesses": 0,
            "games_played": 0,
            "games_won": 0,
            "xp": 0,
            "achievement_claims": {str(i): False for i in range(1, 11)}
        }
        await user_collection.insert_one(user_data)
    return user_data

async def update_user_data(user_id, update_data):
    await user_collection.update_one(
        {"id": user_id},
        {"$set": update_data},
        upsert=True
    )

def normalize_name(name):
    """Normalize character names for comparison"""
    return name.lower().replace("&", "and").replace(".", "").strip()

def is_correct_guess(guess, character_name):
    """Check if guess matches character name with flexible matching"""
    guess = normalize_name(guess)
    char_name = normalize_name(character_name)
    
    # Check if either full name matches or last name matches
    return (guess == char_name or 
            guess in char_name.split() or 
            any(part in guess for part in char_name.split()))

