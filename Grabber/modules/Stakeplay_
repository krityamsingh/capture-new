# --- /stakeplay COMMAND HANDLER ---
@app.on_message(filters.command("stakeplay"))
@block_dec
async def stakeplay_handler(client, message):
    if not message.reply_to_message:
        return await message.reply("🎮 Reply to a user and type `/stakeplay <your_char_id> <their_char_id>` to start a stake game.")
    
    if len(message.command) < 3:
        return await message.reply("❗ Usage: `/stakeplay <your_character_id> <their_character_id>`")
    
    challenger = message.from_user
    opponent = message.reply_to_message.from_user
    
    if challenger.id == opponent.id:
        return await message.reply("😅 You can't play stake game with yourself!")
    
    challenger_char_id = message.command[1]
    opponent_char_id = message.command[2]
    
    # Check if opponent is blocked
    block_data = await user_collection.find_one({"id": opponent.id, "blocked_users": challenger.id})
    if block_data:
        return await message.reply("🚫 This user has blocked you from staking.")
    
    # Get challenger's character
    challenger_data = await user_collection.find_one({"id": challenger.id})
    if not challenger_data or "characters" not in challenger_data:
        return await message.reply("❌ You don't have any characters to stake.")
    
    challenger_char = next((c for c in challenger_data["characters"] if c.get("id") == challenger_char_id), None)
    if not challenger_char:
        return await message.reply(f"❌ Character with ID `{challenger_char_id}` not found in your collection.")
    
    # Check if character is already in a game
    if challenger_char.get("stake_locked"):
        return await message.reply("⚠️ This character is already in a stake game! Complete or cancel it first.")
    
    # Get opponent's character
    opponent_data = await user_collection.find_one({"id": opponent.id})
    if not opponent_data or "characters" not in opponent_data:
        return await message.reply("❌ The opponent doesn't have any characters.")
    
    opponent_char = next((c for c in opponent_data["characters"] if c.get("id") == opponent_char_id), None)
    if not opponent_char:
        return await message.reply(f"❌ Character with ID `{opponent_char_id}` not found in opponent's collection.")
    
    if opponent_char.get("stake_locked"):
        return await message.reply("⚠️ The opponent's character is already in a stake game!")
    
    # Lock both characters
    await user_collection.update_one(
        {"id": challenger.id, "characters.id": challenger_char_id},
        {"$set": {"characters.$.stake_locked": True, "characters.$.stake_game_id": f"{challenger.id}_{opponent.id}_{challenger_char_id}_{opponent_char_id}"}}
    )
    
    await user_collection.update_one(
        {"id": opponent.id, "characters.id": opponent_char_id},
        {"$set": {"characters.$.stake_locked": True, "characters.$.stake_game_id": f"{challenger.id}_{opponent.id}_{challenger_char_id}_{opponent_char_id}"}}
    )
    
    # Create caption for the game proposal
    caption = (
        f"🎮 **Stake Game Challenge**\n\n"
        f"**{challenger.mention}** wants to play a stake game with you!\n\n"
        f"**Stake Terms:**\n"
        f"• If **{opponent.mention}** wins: Gets `{challenger_char['name']}`\n"
        f"• If **{challenger.mention}** wins: Gets `{opponent_char['name']}`\n\n"
        f"**Characters Involved:**\n"
        f"1️⃣ **{challenger_char['name']}** ({challenger_char.get('anime', 'Unknown')}) - ID: `{challenger_char_id}`\n"
        f"2️⃣ **{opponent_char['name']}** ({opponent_char.get('anime', 'Unknown')}) - ID: `{opponent_char_id}`\n\n"
        f"**Only {opponent.mention} can respond to this challenge.**"
    )
    
    keyboard = IKM([
        [
            IKB("✅ Interested", callback_data=f"stake_accept:{challenger.id}:{opponent.id}:{challenger_char_id}:{opponent_char_id}:{message.chat.id}"),
            IKB("❌ Not Interested", callback_data=f"stake_reject:{challenger.id}:{opponent.id}:{challenger_char_id}:{opponent_char_id}:{message.chat.id}")
        ]
    ])
    
    try:
        await message.reply(caption, reply_markup=keyboard)
    except Exception as e:
        # Unlock characters if message fails
        await unlock_stake_characters(challenger.id, challenger_char_id, opponent.id, opponent_char_id)
        print(f"Stake game error: {e}")
        return await message.reply("❌ Couldn't send challenge message. Try again later.")

# --- STAKE CALLBACK HANDLERS ---
@app.on_callback_query(filters.regex("^stake_(accept|reject):"))
@block_cbq
async def stake_response_handler(client, cb):
    parts = cb.data.split(":")
    action = parts[0]
    challenger_id = int(parts[1])
    opponent_id = int(parts[2])
    challenger_char_id = parts[3]
    opponent_char_id = parts[4]
    chat_id = int(parts[5])
    
    # Only opponent can respond
    if cb.from_user.id != opponent_id:
        return await cb.answer("🚫 Only the challenged user can respond!", show_alert=True)
    
    if action == "stake_reject":
        await unlock_stake_characters(challenger_id, challenger_char_id, opponent_id, opponent_char_id)
        
        challenger = await client.get_users(challenger_id)
        await cb.message.edit(
            f"❌ **Stake Game Declined**\n\n"
            f"{cb.from_user.mention} declined the stake game challenge from {challenger.mention}."
        )
        return
    
    # Accept the challenge
    await cb.message.edit("🎮 **Game Starting...**")
    await asyncio.sleep(2)
    
    # Start the game in the same chat
    await start_stake_game(client, challenger_id, opponent_id, challenger_char_id, opponent_char_id, chat_id)

# --- GAME LOGIC ---
async def start_stake_game(client, challenger_id, opponent_id, challenger_char_id, opponent_char_id, chat_id):
    # Get characters info again
    challenger_data = await user_collection.find_one({"id": challenger_id})
    opponent_data = await user_collection.find_one({"id": opponent_id})
    
    if not challenger_data or not opponent_data:
        await unlock_stake_characters(challenger_id, challenger_char_id, opponent_id, opponent_char_id)
        return
    
    challenger_char = next((c for c in challenger_data["characters"] if c.get("id") == challenger_char_id), None)
    opponent_char = next((c for c in opponent_data["characters"] if c.get("id") == opponent_char_id), None)
    
    if not challenger_char or not opponent_char:
        await unlock_stake_characters(challenger_id, challenger_char_id, opponent_id, opponent_char_id)
        return
    
    challenger_user = await client.get_users(challenger_id)
    opponent_user = await client.get_users(opponent_id)
    
    # Store game info
    game_id = f"{challenger_id}_{opponent_id}_{challenger_char_id}_{opponent_char_id}"
    active_games[game_id] = {
        "challenger_id": challenger_id,
        "opponent_id": opponent_id,
        "challenger_char_id": challenger_char_id,
        "opponent_char_id": opponent_char_id,
        "chat_id": chat_id,
        "answered": False
    }
    
    # Send game starting message in the chat
    start_msg = await client.send_message(
        chat_id=chat_id,
        text=(
            "🎮 **Stake Game Started!**\n\n"
            f"**Players:** {challenger_user.mention} 🆚 {opponent_user.mention}\n"
            f"**Stake:** {challenger_char['name']} ↔️ {opponent_char['name']}\n\n"
            "📝 **Rules:**\n"
            "• Answer the trivia question correctly to win\n"
            "• Winner gets opponent's character\n"
            "• Loser's character is transferred\n"
            "• Only the challenged user answers\n\n"
            "🔍 **Fetching question...**"
        )
    )
    
    await asyncio.sleep(3)
    
    # Get question from APIs with fallback
    question_data = await fetch_question()
    
    if not question_data:
        question_data = random.choice(FALLBACK_QUESTIONS)
    
    question = question_data["question"]
    options = question_data["options"]
    correct_answer = question_data["correct"]
    
    # Shuffle options
    random.shuffle(options)
    correct_index = options.index(correct_answer)
    
    # Create buttons
    keyboard_buttons = []
    for i, option in enumerate(options):
        keyboard_buttons.append([IKB(f"{i+1}. {option}", callback_data=f"answer_{i}_{correct_index}:{challenger_id}:{opponent_id}:{challenger_char_id}:{opponent_char_id}:{chat_id}")])
    
    keyboard = IKM(keyboard_buttons)
    
    # Edit message with question
    await start_msg.edit(
        f"❓ **Trivia Question**\n\n"
        f"{question}\n\n"
        f"**Time Limit:** 30 seconds\n"
        f"**Answer as:** {opponent_user.mention}\n\n"
        f"Choose your answer:",
        reply_markup=keyboard
    )
    
    # Set timeout
    await asyncio.sleep(30)
    
    # Check if already answered
    if game_id in active_games and not active_games[game_id]["answered"]:
        try:
            await start_msg.edit(
                f"⏰ **Time's Up!**\n\n"
                f"Correct answer was: **{correct_answer}**\n\n"
                f"**Result:** {challenger_user.mention} wins by default!\n"
                f"{challenger_user.mention} gets {opponent_char['name']}!"
            )
            
            # Transfer character to challenger (winner)
            await transfer_character(
                winner_id=challenger_id,
                loser_id=opponent_id,
                winner_char_id=challenger_char_id,
                loser_char_id=opponent_char_id,
                chat_id=chat_id
            )
            
        except Exception as e:
            print(f"Timeout error: {e}")
        
        # Remove from active games
        if game_id in active_games:
            del active_games[game_id]

# --- ANSWER HANDLER ---
@app.on_callback_query(filters.regex("^answer_"))
@block_cbq
async def answer_handler(client, cb):
    parts = cb.data.split(":")
    answer_data = parts[0]
    challenger_id = int(parts[1])
    opponent_id = int(parts[2])
    challenger_char_id = parts[3]
    opponent_char_id = parts[4]
    chat_id = int(parts[5])
    
    # Only opponent can answer
    if cb.from_user.id != opponent_id:
        return await cb.answer("🚫 Only the challenged user can answer!", show_alert=True)
    
    selected_idx, correct_idx = map(int, answer_data.split("_")[1:3])
    
    challenger_user = await client.get_users(challenger_id)
    opponent_user = await client.get_users(opponent_id)
    
    # Get character info
    challenger_data = await user_collection.find_one({"id": challenger_id})
    opponent_data = await user_collection.find_one({"id": opponent_id})
    
    challenger_char = next((c for c in challenger_data["characters"] if c.get("id") == challenger_char_id), None) if challenger_data else None
    opponent_char = next((c for c in opponent_data["characters"] if c.get("id") == opponent_char_id), None) if opponent_data else None
    
    # Mark game as answered
    game_id = f"{challenger_id}_{opponent_id}_{challenger_char_id}_{opponent_char_id}"
    if game_id in active_games:
        active_games[game_id]["answered"] = True
    
    if selected_idx == correct_idx:
        # Opponent wins
        result_text = (
            f"✅ **Correct Answer!**\n\n"
            f"🏆 **Winner:** {opponent_user.mention}\n"
            f"🎁 **Prize:** {opponent_user.mention} gets {challenger_char['name']}!"
        )
        
        # Transfer character to opponent (winner)
        await transfer_character(
            winner_id=opponent_id,
            loser_id=challenger_id,
            winner_char_id=opponent_char_id,
            loser_char_id=challenger_char_id,
            chat_id=chat_id
        )
        
    else:
        # Challenger wins
        result_text = (
            f"❌ **Wrong Answer!**\n\n"
            f"🏆 **Winner:** {challenger_user.mention}\n"
            f"🎁 **Prize:** {challenger_user.mention} gets {opponent_char['name']}!"
        )
        
        # Transfer character to challenger (winner)
        await transfer_character(
            winner_id=challenger_id,
            loser_id=opponent_id,
            winner_char_id=challenger_char_id,
            loser_char_id=opponent_char_id,
            chat_id=chat_id
        )
    
    await cb.message.edit(result_text)
    await cb.answer()
    
    # Remove from active games
    if game_id in active_games:
        del active_games[game_id]

# --- HELPER FUNCTIONS ---
async def fetch_question():
    """Fetch question from multiple APIs with fallback"""
    async with aiohttp.ClientSession() as session:
        for api_url in QUESTION_APIS:
            try:
                async with session.get(api_url, timeout=5) as response:
                    if response.status == 200:
                        data = await response.json()
                        
                        # Parse based on API structure
                        if "results" in data:  # OpenTDB format
                            item = data["results"][0]
                            question = item["question"]
                            correct = item["correct_answer"]
                            options = item["incorrect_answers"] + [correct]
                        
                        elif isinstance(data, list):  # Array format
                            item = data[0]
                            question = item.get("question", item.get("text", ""))
                            correct = item.get("correctAnswer", item.get("answer", ""))
                            options = item.get("incorrectAnswers", item.get("options", []))
                            if correct and correct not in options:
                                options.append(correct)
                        
                        else:  # Object format
                            question = data.get("question", "")
                            correct = data.get("correct_answer", data.get("answer", ""))
                            options = data.get("incorrect_answers", data.get("options", []))
                            if correct and correct not in options:
                                options.append(correct)
                        
                        if question and correct and len(options) >= 4:
                            # Clean HTML entities
                            question = html.unescape(question)
                            correct = html.unescape(correct)
                            options = [html.unescape(opt) for opt in options]
                            
                            return {
                                "question": question,
                                "correct": correct,
                                "options": options[:4]  # Ensure exactly 4 options
                            }
                            
            except Exception as e:
                print(f"API Error ({api_url}): {e}")
                continue
    
    return None

async def transfer_character(winner_id, loser_id, winner_char_id, loser_char_id, chat_id):
    """Transfer character from loser to winner and announce in chat"""
    try:
        # Get loser's character
        loser_data = await user_collection.find_one({"id": loser_id})
        if not loser_data:
            return
        
        characters = loser_data.get("characters", [])
        char_index = next((i for i, c in enumerate(characters) if c.get("id") == loser_char_id), None)
        
        if char_index is None:
            return
        
        # Remove character from loser
        transferred_char = characters.pop(char_index)
        
        # Remove stake lock and game ID
        if "stake_locked" in transferred_char:
            del transferred_char["stake_locked"]
        if "stake_game_id" in transferred_char:
            del transferred_char["stake_game_id"]
        
        # Update loser
        await user_collection.update_one(
            {"id": loser_id},
            {"$set": {"characters": characters}}
        )
        
        # Add character to winner
        await user_collection.update_one(
            {"id": winner_id},
            {"$push": {"characters": transferred_char}},
            upsert=True
        )
        
        # Unlock winner's character
        await user_collection.update_one(
            {"id": winner_id, "characters.id": winner_char_id},
            {"$unset": {"characters.$.stake_locked": "", "characters.$.stake_game_id": ""}}
        )
        
        # Send announcement in chat
        winner = await app.get_users(winner_id)
        loser = await app.get_users(loser_id)
        
        announcement = (
            f"🎮 **Stake Game Result**\n\n"
            f"🏆 **Winner:** {winner.mention}\n"
            f"🎁 **Received:** {transferred_char['name']} ({transferred_char.get('anime', 'Unknown')})\n\n"
            f"💔 **Loser:** {loser.mention}\n"
            f"📤 **Lost:** {transferred_char['name']}"
        )
        
        try:
            await app.send_message(chat_id=chat_id, text=announcement)
        except Exception as e:
            print(f"Announcement error: {e}")
            
    except Exception as e:
        print(f"Transfer error: {e}")

async def unlock_stake_characters(challenger_id, challenger_char_id, opponent_id, opponent_char_id):
    """Unlock characters from stake lock"""
    try:
        await user_collection.update_one(
            {"id": challenger_id, "characters.id": challenger_char_id},
            {"$unset": {"characters.$.stake_locked": "", "characters.$.stake_game_id": ""}}
        )
        
        await user_collection.update_one(
            {"id": opponent_id, "characters.id": opponent_char_id},
            {"$unset": {"characters.$.stake_locked": "", "characters.$.stake_game_id": ""}}
        )
    except Exception as e:
        print(f"Unlock error: {e}")

# --- CANCEL STAKE COMMAND ---
@app.on_message(filters.command("cancel_stake"))
@block_dec
async def cancel_stake_handler(client, message):
    if len(message.command) < 2:
        return await message.reply("❗ Usage: `/cancel_stake <character_id>`")
    
    char_id = message.command[1]
    user_id = message.from_user.id
    
    # Find and unlock the character
    result = await user_collection.update_one(
        {"id": user_id, "characters.id": char_id, "characters.stake_locked": True},
        {"$unset": {"characters.$.stake_locked": "", "characters.$.stake_game_id": ""}}
    )
    
    if result.modified_count > 0:
        await message.reply(f"✅ Character `{char_id}` unlocked from stake game.")
    else:
        await message.reply(f"❌ No active stake game found for character `{char_id}`.")

# --- CLEANUP ACTIVE GAMES ---
async def cleanup_active_games():
    """Periodic cleanup of stale games"""
    while True:
        await asyncio.sleep(300)  # Every 5 minutes
        try:
            current_time = asyncio.get_event_loop().time()
            stale_games = []
            
            for game_id, game_data in list(active_games.items()):
                # Remove games older than 10 minutes
                if "start_time" in game_data and current_time - game_data["start_time"] > 600:
                    stale_games.append(game_id)
            
            for game_id in stale_games:
                if game_id in active_games:
                    del active_games[game_id]
        except:
            pass

# Start cleanup task when module loads
@app.on_startup()
async def startup():
    asyncio.create_task(cleanup_active_games())
