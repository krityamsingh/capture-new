@app.on_message(filters.command("mytrades"))
async def view_my_trades(client, message):
    try:
        user_id = message.from_user.id
        
        if user_id not in user_trade_requests or not user_trade_requests[user_id]:
            await message.reply_text("**You don't have any active trade requests!**")
            return
        
        active_trades = []
        for trade_id in user_trade_requests[user_id]:
            if trade_id in pending_global_trades:
                trade_data = pending_global_trades[trade_id]
                char_name = trade_data['receiver_char'].get('name', 'Unknown')
                owner = await client.get_users(trade_data['receiver_id'])
                active_trades.append(f"• {char_name} (Owner: {owner.first_name}) - `/cancel_trade {trade_id}`")
        
        if not active_trades:
            await message.reply_text("**You don't have any active trade requests!**")
            return
        
        await message.reply_text(
            "**📤 Your Active Trade Requests:**\n\n" + "\n".join(active_trades) +
            "\n\nUse `/cancel_trade [trade_id]` to cancel a specific trade."
        )
        
    except Exception as e:
        print(f"Error in mytrades: {e}")
        await message.reply_text("**An error occurred!**")

@app.on_message(filters.command("cancel_trade"))
async def cancel_specific_trade(client, message):
    try:
        if len(message.command) < 2:
            await message.reply_text("**Format:** `/cancel_trade [trade_id]`")
            return
            
        trade_id = message.command[1]
        user_id = message.from_user.id
        
        if user_id not in user_trade_requests or trade_id not in user_trade_requests[user_id]:
            await message.reply_text("**Trade not found in your active requests!**")
            return
            
        if trade_id in pending_global_trades:
            del pending_global_trades[trade_id]
        
        user_trade_requests[user_id].remove(trade_id)
        await message.reply_text("**✅ Trade request cancelled successfully!**")
        
    except Exception as e:
        print(f"Error in cancel_trade: {e}")
        await message.reply_text("**An error occurred!**")
