            "games_played": 0,
            "games_won": 0
        }
    
    buttons = []
    for achievement in ACHIEVEMENTS:
        completed = player_stats[user_id]["correct_guesses"] >= achievement["guesses"]
        text = f"{'✅' if completed else '🔘'} {achievement['guesses']} Guesses - {achievement['claims']} Claim"
        buttons.append(
            [InlineKeyboardButton(text, callback_data=f"claim_{achievement['guesses']}" if completed else "none")]
        )
    
    await message.reply(
        "🏆 **Achievements**\n\n"
        "Complete guessing milestones to earn character claims!\n"
        "Click on completed achievements to claim your reward.",
        reply_markup=InlineKeyboardMarkup(buttons)
    )

@app.on_callback_query(filters.regex(r"^claim_(\d+)$"))
async def claim_achievement(client: Client, callback: CallbackQuery):
    user_id = callback.from_user.id
    required_guesses = int(callback.data.split("_")[1])
    
    achievement = next((a for a in ACHIEVEMENTS if a["guesses"] == required_guesses), None)
    if not achievement:
        await callback.answer("Achievement not found!", show_alert=True)
        return
    
    if player_stats[user_id]["correct_guesses"] < required_guesses:
        await callback.answer("You haven't completed this achievement yet!", show_alert=True)
        return
    
    # Get random character within specified rarity range
    char = get_random_character(
        min_rarity=achievement["min_rarity"],
        max_rarity=achievement["max_rarity"]
    )
    
    if not char:
        await callback.answer("No characters available for this reward!", show_alert=True)
        return
    
    # Add to collection
    await ac(user_id, char["id"])
    
    await callback.answer(f"Claimed {char['name']} ({char['rarity']})!", show_alert=True)
    await callback.message.reply(
        f"🎉 Achievement Claimed!\n\n"
        f"🏆 {achievement['guesses']} Correct Guesses\n"
        f"🎁 Reward: {char['name']} ({char['rarity']})\n\n"
        "This character has been added to your collection!",
        reply_markup=InlineKeyboardMarkup([
            [InlineKeyboardButton("View Collection", callback_data=f"collection_{user_id}")]
        ])
    )

