# Game Constants
MAX_ATTEMPTS = 5
DAILY_WIN_LIMIT = 5
COOLDOWN_TIME = 20
STREAK_BONUS = 50
POWERUP_COST = 30
LEADERBOARD_SIZE = 10

# Game State
active_games = {}
cooldown_users = {}
powerups = {
    "reveal": "🔍 Reveal 1 Letter (Cost: 30 gold)",
    "reshuffle": "🔀 Reshuffle Letters (Cost: 30 gold)",
    "solve": "💡 Solve Instantly (Cost: 100 gold)"
}

class GameSession:
    def __init__(self, character, word):
        self.character = character
        self.original_word = word
        self.scrambled_word = self._scramble_word(word)
        self.attempts = 0
        self.hints_used = 0
        self.start_time = time.time()
        self.revealed_letters = set()
    
    def _scramble_word(self, word):
        word_list = list(word)
        while True:
            random.shuffle(word_list)
            scrambled = ''.join(word_list)
            if scrambled.lower() != word.lower():
                return scrambled
    
    def get_hint(self):
        self.hints_used += 1
        hidden = [letter if i in self.revealed_letters else '_' 
                 for i, letter in enumerate(self.original_word)]
        return ''.join(hidden)
    
    def use_powerup(self, powerup_type):
        if powerup_type == "reveal":
            hidden_indices = [i for i in range(len(self.original_word)) 
                            if i not in self.revealed_letters]
            if hidden_indices:
                self.revealed_letters.add(random.choice(hidden_indices))
        elif powerup_type == "reshuffle":
            self.scrambled_word = self._scramble_word(self.original_word)
        return self.get_hint()

def calculate_score(game_time, attempts, hints_used):
    time_bonus = max(0, 300 - game_time) // 10
    attempt_penalty = attempts * 5
    hint_penalty = hints_used * 10
    return max(50, 100 + time_bonus - attempt_penalty - hint_penalty)

async def get_character(collection):
    pipeline = [
        {"$match": {"name": {"$exists": True, "$ne": ""}}},
        {"$sample": {"size": 1}}
    ]
    return await collection.aggregate(pipeline).next()

async def update_user_stats(user_collection, user_id, score_change, win=False):
    now = datetime.now()
    user_data = await user_collection.find_one({'id': user_id}) or {
        'id': user_id,
        'wins': 0,
        'gold': 100,
        'streak': 0,
        'last_win': now - timedelta(days=2),
        'total_score': 0,
        'games_played': 0
    }
    
    if win:
        # Streak calculation
        if (now.date() - user_data['last_win'].date()).days == 1:
            user_data['streak'] += 1
        elif (now.date() - user_data['last_win'].date()).days > 1:
            user_data['streak'] = 1
        
        # Daily win limit check
        if user_data.get('last_win', now).date() == now.date():
            if user_data.get('daily_wins', 0) >= DAILY_WIN_LIMIT:
                return False
        
        user_data['wins'] = user_data.get('wins', 0) + 1
        user_data['daily_wins'] = user_data.get('daily_wins', 0) + 1
        user_data['last_win'] = now
        
        # Streak bonus
        if user_data['streak'] % 7 == 0:
            score_change += STREAK_BONUS
    
    user_data['gold'] = user_data.get('gold', 100) + score_change
    user_data['total_score'] = user_data.get('total_score', 0) + score_change
    user_data['games_played'] = user_data.get('games_played', 0) + 1
    
    await user_collection.replace_one({'id': user_id}, user_data, upsert=True)
    return True

async def get_leaderboard(user_collection):
    pipeline = [
        {"$sort": {"total_score": -1}},
        {"$limit": LEADERBOARD_SIZE},
        {"$project": {
            "username": 1,
            "total_score": 1,
            "wins": 1,
            "streak": 1,
            "gold": 1
        }}
    ]
    return await user_collection.aggregate(pipeline).to_list(length=None)

def create_powerup_keyboard(user_gold):
    buttons = []
    for powerup, desc in powerups.items():
        cost = int(desc.split(":")[1].strip().split()[0])
        disabled = user_gold < cost
        text = f"{desc} {'(❌)' if disabled else ''}"
        callback = f"powerup_{powerup}" if not disabled else "powerup_disabled"
        buttons.append([InlineKeyboardButton(text, callback_data=callback)])
    return InlineKeyboardMarkup(buttons)

async def clear_cooldowns():
    while True:
        await asyncio.sleep(60)
        now = time.time()
        expired = [uid for uid, t in cooldown_users.items() if now - t > COOLDOWN_TIME]
        for uid in expired:
            cooldown_users.pop(uid, None)

# Start the cooldown cleaner as a background task
