@app.on_message(filters.command(["quitgame", "xscrabble"]))
async def quit_game(client, message: Message):
    user_id = message.from_user.id
    if user_id in active_games:
        game = active_games.pop(user_id)
        elapsed = int(time.time() - game.start_time)
        await message.reply_text(
            f"🏳️ Game ended!\n"
            f"The word was: `{game.original_word}`\n"
            f"⏱️ You played for {elapsed}s\n\n"
            f"🔁 Use /scrabble to play again!"
        )
    else:
        await message.reply_text("ℹ️ You don't have an active game to quit.")

