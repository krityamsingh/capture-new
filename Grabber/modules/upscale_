import os
import time
import asyncio
from io import BytesIO
from . import app
from pyrogram import filters
from pyrogram.types import Message
from PIL import Image, ImageFilter
from typing import Union
import numpy as np
import cv2
from rembg import remove as remove_bg
from pyrogram.errors import FloodWait

# Tiny caps font style
def tiny_caps(text: str) -> str:
    return text.upper().translate(str.maketrans("ABCDEFGHIJKLMNOPQRSTUVWXYZ", "ᴀʙᴄᴅᴇꜰɢʜɪᴊᴋʟᴍɴᴏᴘǫʀsᴛᴜᴠᴡxʏᴢ"))

# Upscale factor
UPSCALE_FACTOR = 2

# Image Upscaler Function
async def upscale_image(input_file: Union[str, BytesIO]) -> BytesIO:
    try:
        if isinstance(input_file, BytesIO):
            file_bytes = input_file.getvalue()
        else:
            with open(input_file, 'rb') as f:
                file_bytes = f.read()

        np_arr = np.frombuffer(file_bytes, np.uint8)
        if len(np_arr) == 0:
            raise ValueError("Empty file received")

        img = cv2.imdecode(np_arr, cv2.IMREAD_UNCHANGED)
        if img is None:
            pil_img = Image.open(BytesIO(file_bytes))
            img = cv2.cvtColor(np.array(pil_img), cv2.COLOR_RGB2BGR)

        has_alpha = img.shape[2] == 4 if len(img.shape) > 2 else False

        if has_alpha:
            img = remove_bg(img)

        pil_img = Image.fromarray(cv2.cvtColor(img, cv2.COLOR_BGR2RGB))
        width, height = pil_img.size
        pil_img = pil_img.resize((width * UPSCALE_FACTOR, height * UPSCALE_FACTOR), Image.Resampling.LANCZOS)
        pil_img = pil_img.filter(ImageFilter.UnsharpMask(radius=2, percent=150, threshold=3))

        output = BytesIO()
        if has_alpha or (isinstance(input_file, str) and input_file.lower().endswith('.png')):
            pil_img.save(output, format="PNG", quality=100)
        else:
            pil_img.save(output, format="JPEG", quality=100)
        output.seek(0)
        return output

    except Exception as e:
        raise ValueError(f"Image processing failed: {str(e)}")

# Main Processing Function
async def process_media(message: Message):
    start_time = time.time()
    status_msg = await message.reply_text(f"{tiny_caps('processing')}...")

    try:
        if message.photo:
            file = await message.download(in_memory=True)
            upscaled = await upscale_image(file)
            await message.reply_photo(
                photo=upscaled,
                caption=f"{tiny_caps('upscaled')} {UPSCALE_FACTOR}x\n⚡ {tiny_caps('processed in')} {time.time() - start_time:.2f}s",
                reply_to_message_id=message.id
            )

        elif message.sticker:
            if message.sticker.is_animated:
                raise ValueError(tiny_caps('animated stickers not supported'))
            file = await message.download(in_memory=True)
            upscaled = await upscale_image(file)
            await message.reply_photo(
                photo=upscaled,
                caption=f"{tiny_caps('sticker upscaled')} {UPSCALE_FACTOR}x\n⚡ {tiny_caps('processed in')} {time.time() - start_time:.2f}s",
                reply_to_message_id=message.id
            )

        elif message.animation or (message.document and message.document.mime_type == 'image/gif'):
            await status_msg.edit_text(f"{tiny_caps('gif processing')}")
            file = await message.download(in_memory=True)
            with Image.open(file) as gif:
                gif.seek(0)
                frame = gif.convert("RGBA" if gif.info.get('transparency') else "RGB")
                frame_bytes = BytesIO()
                frame.save(frame_bytes, format="PNG" if 'transparency' in gif.info else "JPEG")
                frame_bytes.seek(0)
                upscaled = await upscale_image(frame_bytes)
            await message.reply_photo(
                photo=upscaled,
                caption=f"{tiny_caps('gif frame upscaled')} {UPSCALE_FACTOR}x\n⚡ {tiny_caps('processed in')} {time.time() - start_time:.2f}s",
                reply_to_message_id=message.id
            )

        else:
            raise ValueError(tiny_caps('unsupported media type'))

        await status_msg.delete()

    except Exception as e:
        await status_msg.edit_text(f"❌ {tiny_caps('error')}: {str(e)}")
        if os.path.exists('downloads'):
            for filename in os.listdir('downloads'):
                os.remove(f'downloads/{filename}')

# Manual Upscale Command
@app.on_message(filters.command("upscale"))
async def upscale_handler(_, message: Message):
    if message.reply_to_message:
        await process_media(message.reply_to_message)
    else:
        help_text = (
            f"✨ {tiny_caps('image upscaler system')} ✨\n\n"
            f"🔹 {tiny_caps('to upscale an image')}:\n"
            f"1. {tiny_caps('reply to an image or sticker')}\n"
            f"2. {tiny_caps('type')} /upscale\n"
        )
        await message.reply_text(help_text)

# Auto Handler – Fixed to check if replied message was sent by bot
@app.on_message(filters.reply)
async def auto_upscale(_, message: Message):
    try:
        replied = message.reply_to_message
        if replied.from_user and replied.from_user.is_self:
            if any([
                replied.photo,
                replied.sticker and not replied.sticker.is_animated,
                replied.animation,
                replied.document and replied.document.mime_type in ['image/gif', 'image/png', 'image/jpeg', 'image/webp']
            ]):
                await process_media(replied)
    except FloodWait as e:
        await asyncio.sleep(e.value)
    except Exception:
        pass  # avoid spamming errors
