# Check if group and channel are linked
async def are_group_channel_linked():
    try:
        group_chat = await app.get_chat(SUPPORT_GROUP)
        channel_chat = await app.get_chat(SUPPORT_CHANNEL)
        
        if hasattr(group_chat, 'linked_chat') and group_chat.linked_chat:
            return group_chat.linked_chat.id == SUPPORT_CHANNEL
        return False
    except:
        return False

# /startgive command (Owner only)
@app.on_message(filters.command("startgive") & filters.user(OWNER_ID))
async def start_giveaway(client: Client, message: Message):
    try:
        char_id = message.text.split()[1].strip()
    except IndexError:
        return await message.reply("**Usage:** `/startgive [character_id]`")

    # Find character
    char = None
    try:
        char = await collection.find_one({"_id": ObjectId(char_id)})
    except:
        char = await collection.find_one({"id": char_id})
    
    if not char:
        char = await collection.find_one({"name": char_id})
        if not char:
            return await message.reply("❌ Character not found in database.")

    # Standardize character data
    char["_id"] = str(char.get("_id"))
    if "id" not in char:
        char["id"] = str(char["_id"])

    giveaway_id = f"giveaway_{int(time.time())}"
    
    # Create giveaway data
    giveaway_data = {
        "giveaway_id": giveaway_id,
        "character": char,
        "participants": [],
        "eliminated": [],
        "start_time": datetime.utcnow(),
        "status": "active",
        "group_message_id": None,
        "channel_message_id": None,
        "pinned_message_id": None,
        "last_elimination": datetime.utcnow(),
        "total_participants": 0,
        "join_count": 0,
        "join_phase": True
    }

    # Save to database
    await giveaway_collection.delete_many({"status": "active"})
    await giveaway_collection.insert_one(giveaway_data)
    
    # Store in memory
    active_giveaways[giveaway_id] = giveaway_data

    # Send to SUPPORT_CHANNEL with character info
    channel_caption = (
        f"**🎮 Character Giveaway Started!**\n\n"
        f"**{char['name']}** - {char['rarity']}\n"
        f"From: {char['anime']}\n"
        f"Use /joingive in group to participate!"
    )

    if char.get("video_url"):
        channel_msg = await client.send_video(SUPPORT_CHANNEL, char["video_url"], caption=channel_caption)
    else:
        channel_msg = await client.send_photo(SUPPORT_CHANNEL, char["img_url"], caption=channel_caption)

    # Send to SUPPORT_GROUP with giveaway info
    group_caption = (
        f"**🎮 Character Giveaway Started!**\n\n"
        f"**{char['name']}** - {char['rarity']}\n"
        f"From: {char['anime']}\n\n"
        f"**Participants:** 0\n"
        f"**Status:** Join Phase - Use /joingive\n"
    )

    # Create inline button with channel message link
    view_button = InlineKeyboardMarkup([[
        InlineKeyboardButton("🔍 View Character", url=channel_msg.link)
    ]])

    if char.get("video_url"):
        group_msg = await client.send_video(SUPPORT_GROUP, char["video_url"], caption=group_caption, reply_markup=view_button)
    else:
        group_msg = await client.send_photo(SUPPORT_GROUP, char["img_url"], caption=group_caption, reply_markup=view_button)

    # Check if group and channel are linked
    are_linked = await are_group_channel_linked()
    
    # Only pin message if groups are not linked
    if not are_linked:
        # Create and pin instruction message
        instruction_msg = await client.send_message(
            SUPPORT_GROUP,
            f"**🎯 Active Giveaway \n\n"
            f"**Character:** {char['name']}\n"
            f"**Rarity:** {char['rarity']}\n\n"
            f"**Use /joingive to participate!**\n\n"
            f"Join now before elimination rounds start!"
        )
        
        # Pin the instruction message
        await client.pin_chat_message(SUPPORT_GROUP, instruction_msg.id)

        # Update database with pinned message ID
        await giveaway_collection.update_one(
            {"giveaway_id": giveaway_id},
            {"$set": {"pinned_message_id": instruction_msg.id}}
        )
        active_giveaways[giveaway_id]["pinned_message_id"] = instruction_msg.id

    # Update database with message IDs
    await giveaway_collection.update_one(
        {"giveaway_id": giveaway_id},
        {"$set": {
            "channel_message_id": channel_msg.id,
            "group_message_id": group_msg.id
        }}
    )
    active_giveaways[giveaway_id].update({
        "channel_message_id": channel_msg.id,
        "group_message_id": group_msg.id
    })

    # Send DM to owner
    try:
        await client.send_message(
            OWNER_ID,
            f"**🎮 Giveaway Started Successfully**\n\n"
            f"**Character:** {char['name']}\n"
            f"**Rarity:** {char['rarity']}\n"
            f"**Anime:** {char['anime']}\n"
            f"**Giveaway ID:** {giveaway_id}\n\n"
        )
    except:
        pass

    await message.reply(f"✅ Giveaway started!\nCharacter: {char['name']}\nID: {giveaway_id}")

