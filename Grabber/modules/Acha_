# Elimination process - SUPER FAST MODE (10 seconds)
async def elimination_process(client: Client, giveaway_id: str):
    round_count = 0
    
    while giveaway_id in active_giveaways:
        giveaway = active_giveaways[giveaway_id]
        
        if len(giveaway["participants"]) <= 1:
            break

        # Wait only 10 seconds for super fast mode
        await asyncio.sleep(10)

        if giveaway_id not in active_giveaways:
            break

        participants = giveaway["participants"]
        if len(participants) <= 1:
            break

        round_count += 1
        
        # Calculate elimination percentage (more aggressive for fast mode)
        remaining = len(participants)
        
        # More aggressive elimination percentages for super fast mode
        if remaining > 1000:
            eliminate_percent = 0.6  # 60% for large groups
        elif remaining > 500:
            eliminate_percent = 0.5  # 50%
        elif remaining > 200:
            eliminate_percent = 0.4  # 40%
        elif remaining > 100:
            eliminate_percent = 0.35 # 35%
        elif remaining > 50:
            eliminate_percent = 0.3  # 30%
        elif remaining > 20:
            eliminate_percent = 0.25 # 25%
        elif remaining > 10:
            eliminate_percent = 0.2  # 20%
        else:
            eliminate_percent = 0.15 # 15%

        eliminate_count = max(1, int(remaining * eliminate_percent))
        
        # For final rounds, eliminate more aggressively
        if remaining <= 10:
            eliminate_count = max(1, remaining - 1)  # Leave only 1 if possible
        
        # For very large groups, cap elimination count but keep it high
        if eliminate_count > 300:
            eliminate_count = 300
        
        # Randomly select participants to eliminate
        eliminated_users = random.sample(participants, eliminate_count)
        eliminated_ids = [user["user_id"] for user in eliminated_users]

        # Update database
        await giveaway_collection.update_one(
            {"giveaway_id": giveaway_id},
            {
                "$pull": {"participants": {"user_id": {"$in": eliminated_ids}}},
                "$push": {"eliminated": {"$each": eliminated_users}},
                "$set": {"last_elimination": datetime.utcnow(), "join_phase": False}
            }
        )

        # Update memory
        giveaway["participants"] = [p for p in participants if p["user_id"] not in eliminated_ids]
        giveaway["eliminated"].extend(eliminated_users)
        giveaway["join_phase"] = False

        # Send elimination notifications (only for significant rounds to avoid spam)
        if eliminate_count >= 5 or remaining <= 20:
            elimination_text = random.choice(ELIMINATION_MESSAGES)
            
            # Create mentions for eliminated users (limit to first 5 to avoid message too long)
            eliminated_mentions = []
            for user_data in eliminated_users[:5]:  # Show first 5 only
                try:
                    user_obj = await client.get_users(user_data["user_id"])
                    mention = user_obj.mention
                    eliminated_mentions.append(mention)
                except:
                    eliminated_mentions.append(f"User#{user_data['user_id']}")

            # Add count for remaining eliminated users
            if len(eliminated_users) > 5:
                eliminated_mentions.append(f"...and {len(eliminated_users) - 5} more")

            # Create elimination message
            elimination_message = (
                f"{elimination_text.format(user=', '.join(eliminated_mentions))}\n\n"
                f"**Remaining:** {len(giveaway['participants'])}\n"
                f"**Eliminated:** {eliminate_count}\n"
                f"**Next round:** 10 seconds ⚡"
            )

            # Send elimination GIF with message to group
            try:
                elimination_gif = random.choice(ELIMINATION_GIFS)
                await client.send_animation(SUPPORT_GROUP, elimination_gif, caption=elimination_message)
            except:
                await client.send_message(SUPPORT_GROUP, elimination_message)

        # Send DM to owner about elimination round (only for significant rounds)
        if eliminate_count >= 10 or remaining <= 50:
            try:
                await client.send_message(
                    OWNER_ID,
                    f"**⚡ Elimination Round {round_count}**\n\n"
                    f"**Character:** {giveaway['character']['name']}\n"
                    f"**Eliminated:** {eliminate_count} participants\n"
                    f"**Remaining:** {len(giveaway['participants'])}\n"
                    f"**Giveaway ID:** {giveaway_id}\n\n"
                    f"Next round in 10 seconds! ⚡"
                )
            except:
                pass

        # Update group message every round
        status_msg = "Final Round! ⚡" if len(giveaway["participants"]) <= 5 else f"Round {round_count} 🔥"
        
        group_caption = (
            f"**🎮 Character Giveaway - ELIMINATION PHASE**\n\n"
            f"**{giveaway['character']['name']}** - {giveaway['character']['rarity']}\n"
            f"From: {giveaway['character']['anime']}\n\n"
            f"**Remaining:** {len(giveaway['participants'])}\n"
            f"**Status:** {status_msg}\n"
        )

        view_button = InlineKeyboardMarkup([[
            InlineKeyboardButton("🔍 View Character", 
                               url=f"https://t.me/c/{str(SUPPORT_CHANNEL)[4:]}/{giveaway.get('channel_message_id', '')}")
        ]])

        try:
            await client.edit_message_caption(
                SUPPORT_GROUP,
                giveaway["group_message_id"],
                caption=group_caption,
                reply_markup=view_button
            )
        except:
            pass

        # Update pinned message for final rounds
        if len(giveaway["participants"]) <= 10 and giveaway.get("pinned_message_id"):
            try:
                await client.edit_message_text(
                    SUPPORT_GROUP,
                    giveaway["pinned_message_id"],
                    f"**🎯 Active Giveaway - FINAL ROUND**\n\n"
                    f"**Character:** {giveaway['character']['name']}\n"
                    f"**Rarity:** {giveaway['character']['rarity']}\n\n"
                    f"**Final {len(giveaway['participants'])} participants!**\n\n"
                    f"⚡ **Winner announcement in seconds!** ⚡"
                )
            except:
                pass

    # Giveaway ended - declare winner
    if giveaway_id in active_giveaways and len(giveaway["participants"]) == 1:
        await declare_winner(client, giveaway_id)

# Declare winner
async def declare_winner(client: Client, giveaway_id: str):
    if giveaway_id not in active_giveaways:
        return

    giveaway = active_giveaways[giveaway_id]
    winner_data = giveaway["participants"][0]
    character = giveaway["character"]

    try:
        winner_user = await client.get_users(winner_data["user_id"])
        
        # Add character to winner's collection
        await user_collection.update_one(
            {"id": winner_data["user_id"]},
            {"$push": {"characters": character}},
            upsert=True
        )

        # Update database
        await giveaway_collection.update_one(
            {"giveaway_id": giveaway_id},
            {"$set": {
                "status": "completed",
                "winner_id": winner_data["user_id"],
                "end_time": datetime.utcnow(),
                "join_phase": False
            }}
        )

        # Winner announcement message
        winner_message = (
            f"**🏆 Giveaway Winner!**\n\n"
            f"**Congratulations!** {winner_user.mention}\n\n"
            f"**Won:** {character['name']} - {character['rarity']}\n"
            f"**From:** {character['anime']}\n\n"
            f"⚡ **Super Fast Giveaway Completed!** ⚡\n"
            f"Character added to collection! 🎉"
        )

        # Send to both channels
        await client.send_message(SUPPORT_GROUP, winner_message)
        await client.send_message(SUPPORT_CHANNEL, winner_message)

        # Unpin the giveaway message if exists
        if giveaway.get("pinned_message_id"):
            try:
                await client.unpin_chat_message(SUPPORT_GROUP, giveaway["pinned_message_id"])
            except:
                pass

        # Send DM to owner
        try:
            await client.send_message(
                OWNER_ID,
                f"**🏆 Giveaway Completed**\n\n"
                f"**Winner:** {winner_user.first_name} (@{winner_user.username})\n"
                f"**Winner ID:** {winner_data['user_id']}\n"
                f"**Character:** {character['name']}\n"
                f"**Rarity:** {character['rarity']}\n"
                f"**Total Participants:** {giveaway['total_participants']}\n"
            )
        except:
            pass

        # DM winner
        try:
            await client.send_message(
                winner_data["user_id"],
                f"**🎉 CONGRATULATIONS! YOU WON!**\n\n"
                f"**Prize:** {character['name']} - {character['rarity']}\n"
                f"**From:** {character['anime']}\n\n"
                f"The character has been added to your collection!\n"
                f"Use /collection to view your characters!"
            )
        except:
            pass

        # Cleanup
        del active_giveaways[giveaway_id]
        if giveaway_id in elimination_tasks:
            del elimination_tasks[giveaway_id]

    except Exception as e:
        print(f"Error declaring winner: {e}")

# /stoprg command (Owner only)
@app.on_message(filters.command("stoprg") & filters.user(OWNER_ID))
async def stop_giveaway(client: Client, message: Message):
    active_giveaway = await giveaway_collection.find_one({"status": "active"})
    if not active_giveaway:
        return await message.reply("❌ No active giveaway found.")

    giveaway_id = active_giveaway["giveaway_id"]
    
    # Cancel elimination task
    if giveaway_id in elimination_tasks:
        elimination_tasks[giveaway_id].cancel()
        del elimination_tasks[giveaway_id]

    # Update database
    await giveaway_collection.update_one(
        {"giveaway_id": giveaway_id},
        {"$set": {"status": "cancelled", "end_time": datetime.utcnow(), "join_phase": False}}
    )

    # Remove from memory
    if giveaway_id in active_giveaways:
        del active_giveaways[giveaway_id]

    # Unpin the giveaway message if exists
    if active_giveaway.get("pinned_message_id"):
        try:
            await client.unpin_chat_message(SUPPORT_GROUP, active_giveaway["pinned_message_id"])
        except:
            pass

    # Send cancellation message
    cancellation_msg = (
        f"**🚫 Giveaway Cancelled**\n\n"
        f"Giveaway for {active_giveaway['character']['name']} has been cancelled.\n\n"
        f"**Participants:** {active_giveaway.get('total_participants', 0)} joined\n"
        f"**Duration:** {(datetime.utcnow() - active_giveaway['start_time']).seconds} seconds"
    )

    await client.send_message(SUPPORT_GROUP, cancellation_msg)
    await client.send_message(SUPPORT_CHANNEL, cancellation_msg)

    # Send DM to owner
    try:
        await client.send_message(
            OWNER_ID,
            f"**🛑 Giveaway Cancelled**\n\n"
            f"**Character:** {active_giveaway['character']['name']}\n"
            f"**Participants:** {active_giveaway.get('total_participants', 0)}\n"
            f"**Duration:** {(datetime.utcnow() - active_giveaway['start_time']).seconds} seconds\n"
            f"**Giveaway ID:** {giveaway_id}\n\n"
            f"Giveaway cancelled successfully."
        )
    except:
