# Background task to cleanup finished giveaways
async def giveaway_cleanup():
    while True:
        try:
            # Cleanup old completed giveaways from memory
            current_time = datetime.utcnow()
            giveaway_ids_to_remove = []
            
            for giveaway_id, giveaway in active_giveaways.items():
                if (current_time - giveaway["start_time"]).days > 1:  # Remove after 1 day
                    giveaway_ids_to_remove.append(giveaway_id)
            
            for giveaway_id in giveaway_ids_to_remove:
                del active_giveaways[giveaway_id]
                if giveaway_id in elimination_tasks:
                    elimination_tasks[giveaway_id].cancel()
                    del elimination_tasks[giveaway_id]
                    
        except Exception as e:
            print(f"Giveaway cleanup error: {e}")
        
        await asyncio.sleep(3600)  # Run every hour

# Start cleanup task on bot startup
async def giveaway_startup():
    await asyncio.sleep(5)
    asyncio.create_task(giveaway_cleanup())

asyncio.get_event_loop().create_task(giveaway_startup())
