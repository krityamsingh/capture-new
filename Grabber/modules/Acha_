    user = message.from_user
    
    # Check if any active giveaway exists
    active_giveaway = await giveaway_collection.find_one({"status": "active"})
    if not active_giveaway:
        return await message.reply("❌ No active giveaway currently running.")

    giveaway_id = active_giveaway["giveaway_id"]
    
    # Check if join phase is still active
    if not active_giveaway.get("join_phase", True):
        return await message.reply("❌ Join phase ended. Cannot join now.")
    
    # Check if user already joined
    if any(p["user_id"] == user.id for p in active_giveaway["participants"]):
        return await message.reply("⚠️ You already joined this giveaway.")

