def convert_to_tiny(text):
    """Convert normal text to tiny caps style"""
    return ''.join(TINY_FONT_MAP.get(c, c) for c in text)

# SQUID GAME SYSTEM
class SquidGame:
    def __init__(self):
        self.active_games = {}
        self.player_stats = {}
        self.game_counter = 1
        self.min_players = 5
        self.max_players = 20
        self.entry_fee = 1000  # Gold coins
        self.prize_pool_multiplier = 2.5
        self.game_duration = timedelta(hours=1)
        
        # Game missions
        self.missions = {
            1: {
                "name": "Red Light Green Light",
                "description": "Players must cross the finish line without being caught moving during red light",
                "elimination_rate": 0.4,
                "duration": 10  # minutes
            },
            2: {
                "name": "Honeycomb Challenge",
                "description": "Players must carve out the shape from honeycomb without breaking it",
                "elimination_rate": 0.3,
                "duration": 15
            },
            3: {
                "name": "Tug of War",
                "description": "Teams compete in a strength battle over a pit",
                "elimination_rate": 0.5,
                "duration": 5
            },
            4: {
                "name": "Marbles",
                "description": "Players compete in pairs with marbles games",
                "elimination_rate": 0.5,
                "duration": 20
            },
            5: {
                "name": "Glass Bridge",
                "description": "Players must choose the correct glass panels to cross",
                "elimination_rate": 0.7,
                "duration": 25
            },
            6: {
                "name": "Squid Game Finale",
                "description": "The final two players compete in the squid game",
                "elimination_rate": 0.5,
                "duration": 30
            }
        }

    async def create_game(self, creator_id):
        game_id = f"SG-{self.game_counter:04d}"
        self.game_counter += 1
        
        self.active_games[game_id] = {
            "creator": creator_id,
            "players": [creator_id],
            "status": "waiting",
            "start_time": None,
            "current_mission": 0,
            "eliminated": [],
            "prize_pool": self.entry_fee,
            "game_log": []
        }
        
        return game_id

    async def add_player(self, game_id, user_id, user_data):
        if game_id not in self.active_games:
            return False, "Game not found"
            
        game = self.active_games[game_id]
        
        if len(game["players"]) >= self.max_players:
            return False, "Game is full"
            
        if user_id in game["players"]:
            return False, "You're already in this game"
            
        if user_data.get("gold", 0) < self.entry_fee:
            return False, f"You need {self.entry_fee} gold to join"
            
        game["players"].append(user_id)
        game["prize_pool"] += self.entry_fee
        return True, "Successfully joined the game"

    async def start_game(self, game_id):
        if game_id not in self.active_games:
            return False, "Game not found"
            
        game = self.active_games[game_id]
        
        if len(game["players"]) < self.min_players:
            return False, f"Need at least {self.min_players} players to start"
            
        game["status"] = "in_progress"
        game["start_time"] = datetime.now()
        game["current_mission"] = 1
        
        # Initialize player stats
        for player in game["players"]:
            self.player_stats[player] = {
                "survived_missions": 0,
                "eliminated_at": None,
                "performance": {}
            }
        
        return True, "Game started!"

    async def run_mission(self, game_id):
        if game_id not in self.active_games:
            return False, "Game not found"
            
        game = self.active_games[game_id]
        
        if game["status"] != "in_progress":
            return False, "Game is not in progress"
            
        current_mission = game["current_mission"]
        mission_data = self.missions.get(current_mission)
        
        if not mission_data:
            return False, "Invalid mission"
            
        remaining_players = [p for p in game["players"] if p not in game["eliminated"]]
        
        # Eliminate players based on mission rate
        elimination_count = int(len(remaining_players) * mission_data["elimination_rate"])
        eliminated = random.sample(remaining_players, elimination_count)
        
        game["eliminated"].extend(eliminated)
        game["current_mission"] += 1
        
        # Update player stats
        for player in remaining_players:
            if player not in eliminated:
                self.player_stats[player]["survived_missions"] += 1
                
        for player in eliminated:
            self.player_stats[player]["eliminated_at"] = current_mission
            
        # Log mission results
        mission_log = {
            "mission": current_mission,
            "name": mission_data["name"],
            "eliminated": eliminated,
            "survivors": [p for p in remaining_players if p not in eliminated]
        }
        
        game["game_log"].append(mission_log)
        
        # Check if game should end
        if len([p for p in game["players"] if p not in game["eliminated"]]) <= 1:
            await self.end_game(game_id)
            return True, "Final mission completed!"
            
        return True, f"Mission {current_mission} completed"

    async def end_game(self, game_id):
        if game_id not in self.active_games:
            return False, "Game not found"
            
        game = self.active_games[game_id]
        game["status"] = "completed"
        
        # Determine winner(s)
        remaining_players = [p for p in game["players"] if p not in game["eliminated"]]
        
        if remaining_players:
            winner = remaining_players[0]
            prize = int(game["prize_pool"] * self.prize_pool_multiplier)
            
            # Update winner's gold
            await user_collection.update_one(
                {"id": winner},
                {"$inc": {"gold": prize}},
                upsert=True
            )
            
            game["winner"] = winner
            game["prize"] = prize
            
        return True, "Game completed"

