            f"рҹ’° бҙҮЙҙбҙӣКҖКҸ Т“бҙҮбҙҮ: {squid_game.entry_fee} вӮІ\n"
            f"рҹҸҶ бҙҳКҖЙӘбҙўбҙҮ бҙҳбҙҸбҙҸКҹ: {game['prize_pool'] * squid_game.prize_pool_multiplier} вӮІ\n\n"
            f"бҙҠбҙҸЙӘЙҙ бҙЎЙӘбҙӣКң /squidjoin {game_id}"
        )
    elif game["status"] == "in_progress":
        current_mission = game["current_mission"]
        mission = squid_game.missions.get(current_mission, {})
        remaining_players = [p for p in game["players"] if p not in game["eliminated"]]
        
        status_text = (
            f"рҹҺ® **ЙўбҙҖбҙҚбҙҮ ЙӘЙҙ бҙҳКҖбҙҸЙўКҖбҙҮss**\n\n"
            f"рҹҶ” ЙўбҙҖбҙҚбҙҮ ЙӘбҙ…: `{game_id}`\n"
            f"рҹ‘Ө бҙ„КҖбҙҮбҙҖбҙӣбҙҸКҖ: {creator.mention}\n"
            f"рҹ‘Ҙ КҖбҙҮбҙҚбҙҖЙӘЙҙЙӘЙҙЙў бҙҳКҹбҙҖКҸбҙҮКҖs: {len(remaining_players)}\n"
            f"рҹҺҜ бҙ„бҙңКҖКҖбҙҮЙҙбҙӣ бҙҚЙӘssЙӘбҙҸЙҙ: {mission.get('name', 'Unknown')} ({current_mission}/6)\n\n"
            f"рҹҸҶ бҙҳКҖЙӘбҙўбҙҮ бҙҳбҙҸбҙҸКҹ: {game['prize_pool'] * squid_game.prize_pool_multiplier} вӮІ"
        )
    else:
        winner = game.get("winner")
        prize = game.get("prize", 0)
        
        status_text = (
            f"рҹҺү **ЙўбҙҖбҙҚбҙҮ бҙ„бҙҸбҙҚбҙҳКҹбҙҮбҙӣбҙҮбҙ…!**\n\n"
            f"рҹҶ” ЙўбҙҖбҙҚбҙҮ ЙӘбҙ…: `{game_id}`\n"
            f"рҹ‘Ө бҙ„КҖбҙҮбҙҖбҙӣбҙҸКҖ: {creator.mention}\n"
            f"рҹ‘Ҙ бҙҸКҖЙӘЙўЙӘЙҙбҙҖКҹ бҙҳКҹбҙҖКҸбҙҮКҖs: {len(game['players'])}\n\n"
            f"рҹҺ–пёҸ **бҙЎЙӘЙҙЙҙбҙҮКҖ**: {(await client.get_users(winner)).mention if winner else 'None'}\n"
            f"рҹ’° **бҙҳКҖЙӘбҙўбҙҮ бҙЎбҙҸЙҙ**: {prize} вӮІ"
        )
    
    await message.reply_text(convert_to_tiny(status_text))

