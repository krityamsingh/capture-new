        await message.reply_text(convert_to_tiny("вҡ пёҸ КҸбҙҸбҙң ЙҙбҙҮбҙҮбҙ… бҙӣбҙҸ КҷбҙҮ КҖбҙҮЙўЙӘsбҙӣбҙҮКҖбҙҮбҙ… бҙӣбҙҸ бҙ„КҖбҙҮбҙҖбҙӣбҙҮ бҙҖ ЙўбҙҖбҙҚбҙҮ"))
