async def reset_daily_tasks():
    while True:
        now = datetime.utcnow()
        next_day = (now + timedelta(days=1)).replace(hour=0, minute=0, second=0, microsecond=0)
        wait_seconds = (next_day - now).total_seconds()
        await asyncio.sleep(wait_seconds)
        
        # Reset daily tasks for all users
        await user_collection.update_many(
            {},
            {"$set": {
                "tasks.daily_legendary": 0,
                "tasks.daily_all_rarity": 0,
                "tasks.last_reset": datetime.utcnow()
            }}
        )

async def reset_weekly_tasks():
    while True:
        now = datetime.utcnow()
        next_week = (now + timedelta(weeks=1)).replace(hour=0, minute=0, second=0, microsecond=0)
        wait_seconds = (next_week - now).total_seconds()
        await asyncio.sleep(wait_seconds)
        
        # Reset weekly tasks for all users
        await user_collection.update_many(
            {},
            {"$set": {
                "tasks.weekly_limited": 0
            }}
        )

@app.on_message(filters.command("task"))
async def task_command(client, message: Message):
    user_id = message.from_user.id
    user = await user_collection.find_one({"id": user_id})
    
    if not user:
        await user_collection.insert_one({
            "id": user_id,
            "tasks": {
                "daily_legendary": 0,
                "weekly_limited": 0,
                "daily_all_rarity": 0,
                "bio_updated": False,
                "support_messages": 0,
                "last_reset": datetime.utcnow(),
                "completed": False
            }
        })
        user = await user_collection.find_one({"id": user_id})
    
    tasks = user.get("tasks", {})
    
    # Check if tasks were completed
    if tasks.get("completed", False):
        await message.reply_text("🎉 You've already completed all tasks and claimed your rewards!")
        return
    
    # Prepare progress text
    progress_text = (
        "☀️ **Summer Event Tasks** ☀️\n\n"
        f"▫️ **Daily Legendary Characters (2):** {tasks.get('daily_legendary', 0)}/2\n"
        f"▫️ **Weekly Limited Edition Characters (2):** {tasks.get('weekly_limited', 0)}/2\n"
        f"▫️ **Daily All Rarity Characters (10):** {tasks.get('daily_all_rarity', 0)}/10\n"
        f"▫️ **Bio Updated with @Character_Seizer_Bot:** {'✅' if tasks.get('bio_updated', False) else '❌'}\n"
        f"▫️ **Support Group Messages (150):** {tasks.get('support_messages', 0)}/150\n\n"
        "✨ **Rewards:**\n"
        "- 1 × ☀️ Summer[Su] character\n"
        "- 2 × 🎐 Celestial characters\n"
        "- 1,000,000 Tokens"
    )
    
    # Check if all tasks are completed
    all_tasks_done = (
        tasks.get("daily_legendary", 0) >= 2 and
        tasks.get("weekly_limited", 0) >= 2 and
        tasks.get("daily_all_rarity", 0) >= 10 and
        tasks.get("bio_updated", False) and
        tasks.get("support_messages", 0) >= 150
    )
    
    keyboard = []
    if all_tasks_done:
        keyboard.append([InlineKeyboardButton("🎁 Claim Rewards", callback_data="claim_rewards")])
    else:
        keyboard.append([InlineKeyboardButton("📌 How to Complete Tasks", callback_data="task_help")])
        keyboard.append([InlineKeyboardButton("🔗 Support Group", url=SUPPORT_GROUP)])
    
    await message.reply_text(
        progress_text,
        reply_markup=InlineKeyboardMarkup(keyboard)
    )

