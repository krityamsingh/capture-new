        )
        try:
            await cbq.message.react("вҡЎ")
        except:
            pass
    else:
        await cbq.answer("ЙҙЙӘбҙ„бҙҮ бҙӣКҖКҸ, Кҷбҙңбҙӣ бҙӣКңбҙҖбҙӣ'кңұ ЙҙбҙҸбҙӣ ЙӘбҙӣ! КҷбҙҮбҙӣбҙӣбҙҮКҖ Кҹбҙңбҙ„бҙӢ ЙҙбҙҮxбҙӣ бҙӣЙӘбҙҚбҙҮ.", show_alert=True)
        caption = (
            f"вңҰ <b>бҙЎКҖбҙҸЙҙЙў бҙҖЙҙкңұбҙЎбҙҮКҖ!</b> вңҰ\n\n"
            f"вҖў <i>{name} бҙӣКҖЙӘбҙҮбҙ… Кҷбҙңбҙӣ бҙҚЙӘкңұкңұбҙҮбҙ… бҙӣКңбҙҮ бҙҚбҙҖКҖбҙӢ.</i>\n"
            f"вҖў бҙӣКңбҙҮ кңұбҙҮбҙҖКҖбҙ„Кң кң°бҙҸКҖ бҙӣКңбҙҮ КҖЙӘЙўКңбҙӣ бҙҖЙҙкңұбҙЎбҙҮКҖ бҙ„бҙҸЙҙбҙӣЙӘЙҙбҙңбҙҮкңұ...\n\n"
            f"бҙ…бҙҸЙҙ'бҙӣ ЙўЙӘбҙ бҙҮ бҙңбҙҳ! вңЁ"
        )

    del math_questions[chat_id]
    await cbq.message.edit_caption(caption=caption, reply_markup=None)
