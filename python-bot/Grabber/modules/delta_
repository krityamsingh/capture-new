    user_id = cbq.from_user.id
    name = cbq.from_user.first_name
    chat_id = cbq.message.chat.id

    if chat_id not in math_questions:
        return await cbq.answer("бҙӣКңЙӘкңұ бҙ„КңбҙҖКҹКҹбҙҮЙҙЙўбҙҮ КңбҙҖкңұ бҙҮxбҙҳЙӘКҖбҙҮбҙ…!", show_alert=True)

    if cbq.data == "correct":
        reward = random.randint(25000, 45000)
        await cbq.answer(
            f"вҡЎ КҷКҖбҙҖЙӘЙҙЙӘбҙҖбҙ„ бҙҖКҹбҙҮКҖбҙӣ! {name} ЙўбҙҸбҙӣ ЙӘбҙӣ КҖЙӘЙўКңбҙӣ!\n\nвңҰ КҖбҙҮбҙЎбҙҖКҖбҙ…: +{reward} рҹ”–",
            show_alert=True
        )
        await add(user_id, reward)
        caption = (
            f"вңҰ <b>бҙҚбҙҖбҙӣКң бҙҚбҙҖкңұбҙӣбҙҮКҖ бҙ…бҙҮбҙӣбҙҮбҙ„бҙӣбҙҮбҙ…!</b> вңҰ\n\n"
            f"вҖў <i>{name} кңұбҙҸКҹбҙ бҙҮбҙ… бҙӣКңбҙҮ бҙҮЗ«бҙңбҙҖбҙӣЙӘбҙҸЙҙ КҹЙӘбҙӢбҙҮ бҙҖ КҷбҙҸкңұкңұ!</i>\n"
