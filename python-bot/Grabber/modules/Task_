# Tic Tac Toe Game Implementation
@app.on_message(filters.command("pvp") & filters.reply)
async def start_tic_tac_toe(client: Client, message: Message):
    # Check if in support group
    if not await check_support_group(message):
        return
    
    challenger_id = message.from_user.id
    opponent_id = message.reply_to_message.from_user.id
    
    # Can't play against self or bot
    if challenger_id == opponent_id or opponent_id == client.me.id:
        return await message.reply_text("❌ You can't play against yourself or the bot!")
    
    # Check if either player is already in a game
    async with game_lock:
        for game_id, game in games.items():
            if challenger_id in [game['player1'], game['player2']] or opponent_id in [game['player1'], game['player2']]:
                return await message.reply_text("❌ One of you is already in a game!")
    
    # Create new game
    game_id = f"{challenger_id}_{opponent_id}_{datetime.now().timestamp()}"
    
    async with game_lock:
        games[game_id] = {
            'player1': challenger_id,
            'player2': opponent_id,
            'board': [['' for _ in range(3)] for _ in range(3)],
            'turn': challenger_id,  # Challenger goes first
            'message_id': None,
            'chat_id': message.chat.id
        }
    
    # Create game board message
    board_text = await format_board(game_id)
    challenger_mention = (await app.get_users(challenger_id)).mention
    opponent_mention = (await app.get_users(opponent_id)).mention
    
    caption = (
        f"🎮 **Tic-Tac-Toe Challenge**\n\n"
        f"**{challenger_mention}** vs **{opponent_mention}**\n\n"
        f"Current turn: {challenger_mention} (🔵)\n"
        f"Use the buttons below to make your move!"
    )
    
    keyboard = await create_game_keyboard(game_id)
    game_msg = await message.reply_text(
        caption + "\n\n" + board_text,
        reply_markup=keyboard
    )
    
    # Store message ID in game state
    async with game_lock:
        games[game_id]['message_id'] = game_msg.id

async def format_board(game_id):
    """Format the game board for display"""
    async with game_lock:
        board = games[game_id]['board']
        player1 = games[game_id]['player1']
        player2 = games[game_id]['player2']
    
    symbols = {
        '': '⬜',
        player1: '🔵',
        player2: '🟣'
    }
    
    board_text = ""
    for row in board:
        for cell in row:
            board_text += symbols[cell] if cell in symbols else symbols['']
        board_text += "\n"
    
    return board_text

async def create_game_keyboard(game_id):
    """Create inline keyboard for the game"""
    async with game_lock:
        game = games[game_id]
    
    keyboard = []
    for i in range(3):
        row = []
        for j in range(3):
            if game['board'][i][j] == game['player1']:
                symbol = '🔵'
            elif game['board'][i][j] == game['player2']:
                symbol = '🟣'
            else:
                symbol = '⬜'
            
            row.append(InlineKeyboardButton(
                symbol,
                callback_data=f"tictactoe_{game_id}_{i}_{j}"
            ))
        keyboard.append(row)
    
    # Add forfeit button
    keyboard.append([InlineKeyboardButton("🚫 Forfeit Game", callback_data=f"tictactoe_forfeit_{game_id}")])
    
    return InlineKeyboardMarkup(keyboard)

@app.on_callback_query(filters.regex("^tictactoe_"))
async def handle_move(client: Client, callback_query: CallbackQuery):
    data = callback_query.data.split("_")
    action = data[1]
    
    if action == "forfeit":
        game_id = data[2]
        await handle_forfeit(client, callback_query, game_id)
        return
    
    game_id = data[1]
    row, col = int(data[2]), int(data[3])
    
    async with game_lock:
        if game_id not in games:
            await callback_query.answer("Game not found!", show_alert=True)
            return
        
        game = games[game_id]
        
        # Check if it's this user's turn
        if callback_query.from_user.id != game['turn']:
            await callback_query.answer("It's not your turn!", show_alert=True)
            return
        
        # Check if cell is already occupied
        if game['board'][row][col] != '':
            await callback_query.answer("This cell is already occupied!", show_alert=True)
            return
        
        # Make move
        game['board'][row][col] = game['turn']
        
        # Check for win
        winner = await check_winner(game_id)
        if winner:
            # Game over - someone won
            winner_mention = (await app.get_users(winner)).mention
            loser_id = game['player2'] if winner == game['player1'] else game['player1']
            
            # Update winner's task completion
            await user_collection.update_one(
                {"user_id": winner},
                {"$set": {"task_game": True}},
                upsert=True
            )
            
            # Send win message
            board_text = await format_board(game_id)
            caption = (
                f"🎮 **Game Over!**\n\n"
                f"**{winner_mention}** wins! 🎉\n\n"
                f"Final board:\n{board_text}"
            )
            
            try:
                await client.edit_message_text(
                    game['chat_id'],
                    game['message_id'],
                    caption,
                    reply_markup=None
                )
            except:
                pass
            
            # Remove game from active games
            del games[game_id]
            await callback_query.answer("You won!", show_alert=True)
            return
        
        # Check for draw
        if await check_draw(game_id):
            # Game over - draw
            board_text = await format_board(game_id)
            caption = (
                f"🎮 **Game Over!**\n\n"
                f"It's a draw! 🤝\n\n"
                f"Final board:\n{board_text}"
            )
            
            try:
                await client.edit_message_text(
                    game['chat_id'],
                    game['message_id'],
                    caption,
                    reply_markup=None
                )
            except:
                pass
            
            # Remove game from active games
            del games[game_id]
            await callback_query.answer("It's a draw!", show_alert=True)
            return
        
        # Switch turns
        game['turn'] = game['player2'] if game['turn'] == game['player1'] else game['player1']
        
        # Update board message
        current_player_mention = (await app.get_users(game['turn'])).mention
        player_symbol = '🔵' if game['turn'] == game['player1'] else '🟣'
        
        board_text = await format_board(game_id)
        caption = (
            f"🎮 **Tic-Tac-Toe Game**\n\n"
            f"Current turn: {current_player_mention} ({player_symbol})\n"
            f"Use the buttons below to make your move!\n\n"
            f"{board_text}"
        )
        
        keyboard = await create_game_keyboard(game_id)
        try:
            await client.edit_message_text(
                game['chat_id'],
                game['message_id'],
                caption,
                reply_markup=keyboard
            )
        except:
            pass
        
        await callback_query.answer("Move made!")

async def handle_forfeit(client, callback_query, game_id):
    """Handle game forfeit"""
    async with game_lock:
        if game_id not in games:
            await callback_query.answer("Game not found!", show_alert=True)
            return
        
        game = games[game_id]
        user_id = callback_query.from_user.id
        
        # Check if user is in this game
        if user_id not in [game['player1'], game['player2']]:
            await callback_query.answer("You're not in this game!", show_alert=True)
            return
        
        # Determine winner (the other player)
        winner_id = game['player2'] if user_id == game['player1'] else game['player1']
        winner_mention = (await app.get_users(winner_id)).mention
        forfeiter_mention = (await app.get_users(user_id)).mention
        
        # Update winner's task completion
        await user_collection.update_one(
            {"user_id": winner_id},
            {"$set": {"task_game": True}},
            upsert=True
        )
        
        # Send forfeit message
        caption = (
            f"🎮 **Game Forfeited!**\n\n"
            f"**{forfeiter_mention}** has forfeited the game!\n"
            f"**{winner_mention}** wins by default! 🎉"
        )
        
        try:
            await client.edit_message_text(
                game['chat_id'],
                game['message_id'],
                caption,
                reply_markup=None
            )
        except:
            pass
        
        # Remove game from active games
        del games[game_id]
        await callback_query.answer("You forfeited the game!", show_alert=True)

async def check_winner(game_id):
    """Check if there's a winner in the game"""
    async with game_lock:
        board = games[game_id]['board']
        player1 = games[game_id]['player1']
        player2 = games[game_id]['player2']
    
    # Check rows
    for row in board:
        if row[0] == row[1] == row[2] != '':
            return row[0]
    
    # Check columns
    for col in range(3):
        if board[0][col] == board[1][col] == board[2][col] != '':
            return board[0][col]
    
    # Check diagonals
    if board[0][0] == board[1][1] == board[2][2] != '':
        return board[0][0]
    if board[0][2] == board[1][1] == board[2][0] != '':
        return board[0][2]
    
    return None

async def check_draw(game_id):
    """Check if the game is a draw"""
    async with game_lock:
        board = games[game_id]['board']
    
    for row in board:
        for cell in row:
            if cell == '':
                return False
    return True

# Auto-cleanup for inactive games (runs every hour)
async def cleanup_inactive_games():
    """Clean up games that have been inactive for more than 1 hour"""
    while True:
        await asyncio.sleep(3600)  # Run every hour
        async with game_lock:
            current_time = datetime.now()
            inactive_games = []
            
            for game_id, game in games.items():
                # If no move has been made in 1 hour, mark for cleanup
                if "last_move_time" in game:
                    if (current_time - game["last_move_time"]).total_seconds() > 3600:
                        inactive_games.append(game_id)
            
            # Remove inactive games
            for game_id in inactive_games:
                try:
                    game = games[game_id]
                    await app.edit_message_text(
                        game['chat_id'],
                        game['message_id'],
                        "⏰ **Game Expired**\n\nThis game was inactive for too long and has been removed.",
                        reply_markup=None
                    )
                except:
                    pass
                del games[game_id]

