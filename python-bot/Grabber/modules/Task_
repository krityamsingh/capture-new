def is_support_group():
    """Decorator to check if command is used in support group"""
    def func(flt, client, message):
        return message.chat.id == SUPPORT_GROUP_ID
    return filters.create(func)

async def check_support_group(message):
    """Check if message is from support group, return button if not"""
    if message.chat.id != SUPPORT_GROUP_ID:
        await message.reply_text(
            "⚠️ This command can only be used in our support group!",
            reply_markup=support_button
        )
        return False
    return True

