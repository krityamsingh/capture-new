# /atime - Set message count for auctions (admin only)
@app.on_message(filters.command("atime") & filters.group)
async def set_auction_time(client: Client, message: Message):
    # Check if user is admin or owner
    user = message.from_user
    chat_id = message.chat.id
    
    member = await client.get_chat_member(chat_id, user.id)
    if member.status not in ["administrator", "creator"] and user.id != OWNER_ID:
        return await message.reply("Only admins can set auction settings!")
    
    try:
        count = int(message.text.split()[1])
        if count < 1:
            return await message.reply("Please enter a number greater than 0!")
    except (IndexError, ValueError):
        return await message.reply("Usage: /atime [message_count]")
    
    # Update settings
    await chat_auctions.update_one(
        {"chat_id": chat_id},
        {"$set": {"message_count": count}},
        upsert=True
    )
    
    # Update local cache
    if chat_id not in chat_auction_settings:
        chat_auction_settings[chat_id] = {"auto_spawn": True}
    chat_auction_settings[chat_id]["message_count"] = count
    
    await message.reply(f"✅ Auction spawn set to every `{count}` messages!")

# Track messages for auto-spawning auctions
@app.on_message(filters.group & ~filters.service)
async def track_messages(client: Client, message: Message):
    chat_id = message.chat.id
    
    # Skip if auctions not enabled or already active
    if (chat_id not in chat_auction_settings or 
        not chat_auction_settings[chat_id].get("enabled", False) or
        chat_id in active_chat_auctions):
        return
    
    # Initialize message count if not exists
    if "msg_counter" not in chat_auction_settings[chat_id]:
        chat_auction_settings[chat_id]["msg_counter"] = 0
    
    # Increment counter
    chat_auction_settings[chat_id]["msg_counter"] += 1
    
    # Check if it's time to spawn
    required = chat_auction_settings[chat_id].get("message_count", 99)
    if chat_auction_settings[chat_id]["msg_counter"] >= required:
        await spawn_chat_auction(chat_id)
        chat_auction_settings[chat_id]["msg_counter"] = 0

# Spawn a new auction in chat
async def spawn_chat_auction(chat_id: int):
    # Skip if already active
    if chat_id in active_chat_auctions:
        return
    
    # Get random character from allowed rarities
    char = await collection.aggregate([
        {"$match": {"rarity": {"$in": RARITIES}}},
        {"$sample": {"size": 1}}
    ]).to_list(1)
    
    if not char:
        return  # No characters available
    
    char = char[0]
    char["_id"] = str(char["_id"])
    
    # Create auction data
    auction_data = {
        "chat_id": chat_id,
        "char": char,
        "start_time": datetime.utcnow(),
        "highest_bid": 0,
        "highest_user": None,
        "bidders": [],
        "last_bid_time": datetime.utcnow()
    }
    
    # Save to DB and memory
    await active_auctions.insert_one(auction_data)
    active_chat_auctions[chat_id] = auction_data
    
    # Send auction message
    caption = (
        f"**🎉 NEW AUCTION STARTED!**\n\n"
        f"🏷️ **Name:** `{char['name']}`\n"
        f"🧬 **Anime:** `{char['anime']}`\n"
        f"✨ **Rarity:** {char['rarity']}\n\n"
        f"💵 **Starting Bid:** `10,000` coins\n"
        f"⏳ **Time Left:** 2 minutes\n\n"
        f"Use `/mbid [amount]` to place your bid!"
    )
    
    if char.get("video_url"):
        await app.send_video(chat_id, char["video_url"], caption=caption)
    else:
        await app.send_photo(chat_id, char["img_url"], caption=caption)

# /mbid - Place bid in chat auction
@app.on_message(filters.command("mbid") & filters.group)
async def place_chat_bid(client: Client, message: Message):
    chat_id = message.chat.id
    
    # Check if auction is active
    if chat_id not in active_chat_auctions:
        return await message.reply("No auction is currently active in this chat!")
    
    auction_data = active_chat_auctions[chat_id]
    user = message.from_user
    
    try:
        amount = int(message.text.split()[1].replace(",", ""))
    except (IndexError, ValueError):
        return await message.reply("Usage: /mbid [amount]")
    
    # Check minimum bid
    if amount < 10000:
        return await message.reply("Minimum bid is 10,000 coins!")
    
    # Check if higher than current bid
    if amount <= auction_data["highest_bid"]:
        return await message.reply(f"Bid must be higher than current highest bid (`{auction_data['highest_bid']:,}`)!")
    
    # Get user balance
    user_data = await user_collection.find_one({"id": user.id})
    if not user_data:
        return await message.reply("You don't have an account! Create one first.")
    
    try:
        balance = int(user_data.get("balance", 0))
    except:
        balance = 0
        await user_collection.update_one({"id": user.id}, {"$set": {"balance": 0}})
    
    if balance < amount:
        return await message.reply(f"You don't have enough coins! (Balance: `{balance:,}`)")
    
    # Refund previous highest bidder
    prev_bidder = auction_data["highest_user"]
    prev_amount = auction_data["highest_bid"]
    
    if prev_bidder and prev_bidder != user.id:
        prev_user_data = await user_collection.find_one({"id": prev_bidder})
        if prev_user_data:
            try:
                prev_balance = int(prev_user_data.get("balance", 0))
            except:
                prev_balance = 0
                
            await user_collection.update_one(
                {"id": prev_bidder},
                {"$set": {"balance": prev_balance + prev_amount}}
            )
            
            try:
                await client.send_message(
                    prev_bidder,
                    f"❌ You've been outbid in {message.chat.title}!\n"
                    f"Your `{prev_amount:,}` coins have been refunded."
                )
            except:
                pass
    
    # Deduct coins from new bidder
    await user_collection.update_one(
        {"id": user.id},
        {"$set": {"balance": balance - amount}}
    )
    
    # Update auction data
    auction_data["highest_bid"] = amount
    auction_data["highest_user"] = user.id
    auction_data["last_bid_time"] = datetime.utcnow()
    auction_data["bidders"].append({
        "user_id": user.id,
        "amount": amount,
        "time": datetime.utcnow()
    })
    
    # Update in DB
    await active_auctions.update_one(
        {"chat_id": chat_id},
        {"$set": {
            "highest_bid": amount,
            "highest_user": user.id,
            "last_bid_time": datetime.utcnow()
        },
        "$push": {
            "bidders": {
                "user_id": user.id,
                "amount": amount,
                "time": datetime.utcnow()
            }
        }}
    )
    
    # Track bid counts
    if chat_id not in user_bid_counts:
        user_bid_counts[chat_id] = {}
    user_bid_counts[chat_id][user.id] = user_bid_counts[chat_id].get(user.id, 0) + 1
    
    # Notify chat
    await message.reply(
        f"🧨 **New Bid!** {user.mention} bid `{amount:,}` coins!\n"
        f"Current highest: `{amount:,}`"
    )

# /bidders - Check current bidders
@app.on_message(filters.command("bidders") & filters.group)
async def show_bidders(client: Client, message: Message):
    chat_id = message.chat.id
    
    if chat_id not in active_chat_auctions:
        return await message.reply("No active auction in this chat!")
    
    auction_data = active_chat_auctions[chat_id]
    char = auction_data["char"]
    bidders = auction_data.get("bidders", [])
    
    if not bidders:
        return await message.reply("No bids placed yet!")
    
    # Sort bidders by amount (descending)
    sorted_bidders = sorted(bidders, key=lambda x: x["amount"], reverse=True)
    
    text = (
        f"**🏆 Current Bidders for {char['name']}**\n"
        f"✨ {char['rarity']} | 💰 Highest: `{auction_data['highest_bid']:,}`\n\n"
    )
    
    # Show top 10 bidders
    for i, bid in enumerate(sorted_bidders[:10], 1):
        try:
            user = await client.get_users(bid["user_id"])
            name = user.first_name
        except:
            name = f"User {bid['user_id']}"
        
        text += f"{i}. {name} - `{bid['amount']:,}`\n"
    
    await message.reply(text)

# /currentbid - Show current auction info
@app.on_message(filters.command("currentbid") & filters.group)
async def show_current_bid(client: Client, message: Message):
    chat_id = message.chat.id
    
    if chat_id not in active_chat_auctions:
        return await message.reply("No active auction in this chat!")
    
    auction_data = active_chat_auctions[chat_id]
    char = auction_data["char"]
    highest_bid = auction_data["highest_bid"]
    highest_user = auction_data["highest_user"]
    
    time_left = timedelta(minutes=2) - (datetime.utcnow() - auction_data["last_bid_time"])
    mins, secs = divmod(time_left.seconds, 60)
    
    text = (
        f"**⏳ Current Auction**\n\n"
        f"🏷️ **Character:** `{char['name']}`\n"
        f"🧬 **Anime:** `{char['anime']}`\n"
        f"✨ **Rarity:** {char['rarity']}\n\n"
        f"💰 **Highest Bid:** `{highest_bid:,}`\n"
        f"⏱️ **Time Left:** {mins}m {secs}s\n\n"
    )
    
    if highest_user:
        try:
            user = await client.get_users(highest_user)
            text += f"👑 **Highest Bidder:** {user.mention}\n"
        except:
            text += f"👑 **Highest Bidder:** User {highest_user}\n"
    
    text += "\nUse `/mbid [amount]` to place your bid!"
    
    await message.reply(text)
