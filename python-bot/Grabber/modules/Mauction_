# Global dictionaries to track state
chat_auction_settings: Dict[int, Dict] = {}  # {chat_id: {"message_count": int, "auto_spawn": bool}}
active_chat_auctions: Dict[int, Dict] = {}  # {chat_id: auction_data}
user_bid_counts: Dict[int, Dict[int, int]] = {}  # {chat_id: {user_id: bid_count}}

# Initialize on startup
async def init_auction_data():
    global chat_auction_settings, active_chat_auctions
    
    # Load chat settings from DB
    async for chat in chat_auctions.find():
        chat_auction_settings[chat["chat_id"]] = {
            "message_count": chat.get("message_count", 99),
            "auto_spawn": chat.get("auto_spawn", True)
        }
    
    # Load active auctions from DB
    async for auction in active_auctions.find():
        active_chat_auctions[auction["chat_id"]] = auction

# Start auction monitoring
async def monitor_chat_auctions():
    while True:
        current_time = datetime.utcnow()
        
        # Check each active auction
        for chat_id, auction_data in list(active_chat_auctions.items()):
            try:
                last_bid_time = auction_data.get("last_bid_time", auction_data["start_time"])
                time_since_last_bid = current_time - last_bid_time
                
                # Check if auction should end
                if time_since_last_bid >= timedelta(minutes=2):
                    await end_chat_auction(chat_id, auction_data)
                    
                # Special case for first bid timeout
                elif auction_data["highest_bid"] == 0 and time_since_last_bid >= timedelta(minutes=1):
                    await cancel_chat_auction(chat_id, auction_data)
                    
            except Exception as e:
                print(f"Error monitoring auction in chat {chat_id}: {e}")
                continue
                
        await asyncio.sleep(30)

# Helper function to end auction
async def end_chat_auction(chat_id: int, auction_data: Dict):
    char = auction_data["char"]
    highest_bid = auction_data["highest_bid"]
    highest_user_id = auction_data["highest_user"]
    
    if highest_user_id:
        # Add character to winner's collection
        await user_collection.update_one(
            {"id": highest_user_id},
            {"$push": {"characters": char}},
            upsert=True
        )
        
        # Get winner mention
        try:
            user = await app.get_users(highest_user_id)
            mention = user.mention
        except:
            mention = f"User {highest_user_id}"
            
        caption = (
            f"**🎉 Auction Ended!**\n\n"
            f"🏆 **Character:** `{char['name']}`\n"
            f"🧬 **Anime:** `{char['anime']}`\n"
            f"✨ **Rarity:** {char['rarity']}\n"
            f"💰 **Winning Bid:** `{highest_bid:,}`\n"
            f"👑 **Winner:** {mention}\n\n"
            f"Character has been added to their collection!"
        )
        
        # Try to DM winner
        try:
            await app.send_message(
                highest_user_id,
                f"🎉 **You won {char['name']}** in the auction!\n"
                f"Paid: `{highest_bid:,}` coins\n"
                f"Added to your collection!"
            )
        except:
            pass
            
    else:
        caption = (
            f"**❌ Auction Ended**\n\n"
            f"🏷️ **Character:** `{char['name']}`\n"
            f"🧬 **Anime:** `{char['anime']}`\n"
            f"✨ **Rarity:** {char['rarity']}\n\n"
            f"No valid bids were placed!"
        )
        
    # Send result to chat
    if char.get("video_url"):
        await app.send_video(chat_id, char["video_url"], caption=caption)
    else:
        await app.send_photo(chat_id, char["img_url"], caption=caption)
        
    # Clean up
    del active_chat_auctions[chat_id]
    await active_auctions.delete_one({"chat_id": chat_id})
    
    # Reset bid counts for this chat
    if chat_id in user_bid_counts:
        del user_bid_counts[chat_id]

# Helper function to cancel auction
async def cancel_chat_auction(chat_id: int, auction_data: Dict):
    char = auction_data["char"]
    
    caption = (
        f"**❌ Auction Canceled**\n\n"
        f"🏷️ **Character:** `{char['name']}`\n"
        f"🧬 **Anime:** `{char['anime']}`\n"
        f"✨ **Rarity:** {char['rarity']}\n\n"
        f"No bids were placed in time!"
    )
    
    # Send cancellation message
    if char.get("video_url"):
        await app.send_video(chat_id, char["video_url"], caption=caption)
    else:
        await app.send_photo(chat_id, char["img_url"], caption=caption)
        
    # Clean up
    del active_chat_auctions[chat_id]
    await active_auctions.delete_one({"chat_id": chat_id})
    
    # Reset bid counts for this chat
    if chat_id in user_bid_counts:
        del user_bid_counts[chat_id]

# Start monitoring on bot startup
asyncio.create_task(init_auction_data())
asyncio.create_task(monitor_chat_auctions())

# /startca - Start auctions in all chats (owner only)
@app.on_message(filters.command("startca") & filters.user(OWNER_ID))
async def start_all_chat_auctions(client: Client, message: Message):
    # Enable auctions in all chats that have settings
    await chat_auctions.update_many({}, {"$set": {"enabled": True}})
    
    # Update local cache
    async for chat in chat_auctions.find():
        chat_auction_settings[chat["chat_id"]] = {
            "message_count": chat.get("message_count", 99),
            "auto_spawn": chat.get("auto_spawn", True),
            "enabled": True
        }
    
    await message.reply("✅ Auctions enabled in all chats!")
    
    # Notify all chats
    async for chat in chat_auctions.find():
        try:
            chat_obj = await client.get_chat(chat["chat_id"])
            await client.send_message(
                chat["chat_id"],
                f"🎉 **Chat Auction System Activated!**\n\n"
                f"This chat now has automatic character auctions!\n\n"
                f"Admins can configure with:\n"
                f"/atime [count] - Set message count between auctions\n"
                f"(Default: 99 messages)\n\n"
                f"Users can bid with /mbid when an auction is active!"
            )
        except Exception as e:
            print(f"Couldn't notify chat {chat['chat_id']}: {e}")

# /stopca - Stop auctions in all chats (owner only)
@app.on_message(filters.command("stopca") & filters.user(OWNER_ID))
async def stop_all_chat_auctions(client: Client, message: Message):
    # Disable auctions in all chats
    await chat_auctions.update_many({}, {"$set": {"enabled": False}})
    
    # Update local cache
    for chat_id in chat_auction_settings:
        chat_auction_settings[chat_id]["enabled"] = False
    
    await message.reply("❌ Auctions disabled in all chats!")
    
    # Notify all chats with active auctions
    for chat_id in list(active_chat_auctions.keys()):
        try:
            await client.send_message(
                chat_id,
                "❌ **Chat Auction System Disabled!**\n\n"
                "All active auctions have been canceled by the bot owner."
            )
            
            # Clean up active auction
            if chat_id in active_chat_auctions:
                del active_chat_auctions[chat_id]
            await active_auctions.delete_one({"chat_id": chat_id})
            
        except Exception as e:
            print(f"Couldn't notify chat {chat_id}: {e}")

# /cauction - Check enabled chats (owner only)
@app.on_message(filters.command("cauction") & filters.user(OWNER_ID))
async def check_active_auctions(client: Client, message: Message):
    enabled_chats = []
