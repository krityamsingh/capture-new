@app.on_message(filters.text & filters.group)
async def handle_player_move(client: Client, message: Message):
    chat_id = message.chat.id
    user_id = message.from_user.id
    text = message.text.lower().strip()
    
    game = active_games.get(chat_id)
    if not game or game["status"] != "playing":
        return
    
    players = game["joined_players"]
    if not players or game["turn_index"] >= len(players):
        return
    
    current_player = players[game["turn_index"]]
    if current_player["id"] != user_id:
        return
    
    # Validate the word
    if not text.startswith(game["current_letter"]):
        await message.reply_text(f"❌ {message.from_user.mention}, your word must start with '{game['current_letter'].upper()}'!")
        return
    
    if len(text) != game["current_length"]:
        await message.reply_text(f"❌ {message.from_user.mention}, your word must be exactly {game['current_length']} letters long!")
        return
    
    if text in game["used_words"]:
        await message.reply_text(f"❌ {message.from_user.mention}, this word has already been used!")
        return
    
    if text not in word_dictionary[len(text)]:
        await message.reply_text(f"❌ {message.from_user.mention}, this word doesn't exist in our dictionary!")
        return
    
    # Valid word - update game state
    game["used_words"].add(text)
    game["current_letter"] = text[-1]
    
    # Increase word length occasionally
    if (random.random() < game["settings"]["letter_increase_chance"] and 
        game["current_length"] < game["settings"]["max_letters"]):
        game["current_length"] += 1
    
    # Update player score
    current_player["score"] += len(text) * 10
    
    # Update user stats
    await update_user_stats(user_id, "words_played", 1)
    await update_user_stats(user_id, "letters_played", len(text))
    await track_word_stats(user_id, text)
    
    await message.reply_text(f"✅ {message.from_user.mention} played: `{text.upper()}`\n"
                           f"Next letter: `{game['current_letter'].upper()}`")
    
    # Cancel current timer and move to next player
    if chat_id in player_timers:
        player_timers[chat_id].cancel()
    
    await next_turn(chat_id)

async def track_word_stats(user_id: int, word: str):
    user_stats = await user_collection.find_one({"user_id": user_id})
    
    if not user_stats or len(word) > len(user_stats.get("stats", {}).get("longest_word", "")):
        await user_collection.update_one(
            {"user_id": user_id},
            {"$set": {"stats.longest_word": word}},
            upsert=True
        )
    
    if not user_stats or len(word) < len(user_stats.get("stats", {}).get("shortest_word", "zzzzzzzzzz")):
        await user_collection.update_one(
            {"user_id": user_id},
            {"$set": {"stats.shortest_word": word}},
            upsert=True
        )

@app.on_message(filters.command("mystats"))
async def player_stats_handler(client: Client, message: Message):
    user_id = message.from_user.id
    user = message.from_user
    
    stats = await user_collection.find_one({"user_id": user_id})
    if not stats:
        stats = {"stats": {}}
    
    stat_data = stats.get("stats", {})
    
    # Calculate win rate
    wins = stat_data.get("wins", 0)
    losses = stat_data.get("losses", 0)
    total_games = wins + losses
    win_rate = (wins / total_games * 100) if total_games > 0 else 0
    
    # Prepare rarity counts
    rarity_counts = []
    for rarity in RARITIES:
        key = rarity.lower().replace(' ', '_') + "_chars"
        count = stat_data.get(key, 0)
        if count > 0:
            rarity_counts.append(f"{RARITIES[rarity]} {rarity.split()[0]}: {count}")
    
    # Create stats message
    stats_msg = (
        f"📊 **Player Stats for {user.first_name}**\n\n"
        f"🏆 Wins: `{wins}`\n"
        f"💔 Losses: `{losses}`\n"
        f"📈 Win Rate: `{win_rate:.1f}%`\n"
        f"🔤 Words Played: `{stat_data.get('words_played', 0)}`\n"
        f"🔡 Letters Played: `{stat_data.get('letters_played', 0)}`\n"
        f"📏 Longest Word: `{stat_data.get('longest_word', 'N/A')}`\n"
        f"📐 Shortest Word: `{stat_data.get('shortest_word', 'N/A')}`\n\n"
        f"🎖️ Characters Collected: `{stat_data.get('characters_collected', 0)}`\n"
        f"{', '.join(rarity_counts) if rarity_counts else 'No characters collected yet'}"
    )
    
    if user.photo:
        try:
            photo = await app.download_media(user.photo.big_file_id)
            await message.reply_photo(photo, caption=stats_msg)
            return
        except Exception:
            pass
    
    await message.reply_text(stats_msg)

