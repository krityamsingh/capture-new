    chat_id = int(callback_query.data.split("_")[1])
    user_id = callback_query.from_user.id
    user_mention = callback_query.from_user.mention
    
    game = active_games.get(chat_id)
    if not game or game["status"] != "waiting":
        await callback_query.answer("No active game to join!", show_alert=True)
        return
    
    if any(p["id"] == user_id for p in game["joined_players"]):
        await callback_query.answer("You've already joined this game!", show_alert=True)
        return
    
    game["joined_players"].append({
        "id": user_id,
        "mention": user_mention,
        "score": 0
    })
    
    try:
        await app.edit_message_text(
            chat_id,
            game["message_id"],
            f"🎮 **New {GAME_MODES[game['mode']]['name']} Chain Game Started!**\n\n"
            f"Hosted by: {game['joined_players'][0]['mention']}\n"
            f"Mode: {GAME_MODES[game['mode']]['description']}\n"
            f"Time limit: {GAME_MODES[game['mode']]['time_limit']} seconds per turn\n"
            f"Starting word length: {GAME_MODES[game['mode']]['min_letters']} letters\n\n"
            f"Players joined: {len(game['joined_players'])}\n"
            f"The game will start in 1 minute or when /forcestart is used.",
            reply_markup=InlineKeyboardMarkup([
                [InlineKeyboardButton(f"Join Game ({len(game['joined_players'])})", callback_data=f"join_{chat_id}")]
            ])
        )
    except Exception:
        pass
    
    await callback_query.answer(f"You've joined the game!", show_alert=True)
