@app.on_callback_query(filters.regex(r'^ag_r_'))
async def ag_rarity_selected(client, cq):
    await cq.answer()
    short_key = cq.data.split("ag_r_", 1)[-1]
    full_rarity = rarity_key_to_name.get(short_key)
    if not full_rarity:
        return await cq.answer("❌ Invalid rarity.", show_alert=True)

    user_id = cq.from_user.id
