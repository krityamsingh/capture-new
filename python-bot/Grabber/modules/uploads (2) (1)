async def send_anim_media(chat_id, file_id, media_type, caption):
    try:
        if media_type == "video":
            await app.send_video(chat_id=chat_id, video=file_id, caption=caption)
        else:
            await app.send_animation(chat_id=chat_id, animation=file_id, caption=caption)
    except Exception as e:
        print(f"send_anim_media error to {chat_id}: {e}")
        await app.send_message(chat_id=chat_id, text=caption)


