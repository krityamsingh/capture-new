# ✅ Always reads real max ID from DB — never resets to 1
async def get_next_sequence_number(sequence_name):
    sequence_collection = db.sequences
    all_chars = await collection.find({"id": {"$exists": True}}, {"id": 1}).to_list(None)
    existing_ids = []
    for c in all_chars:
        try:
            existing_ids.append(int(c["id"]))
        except (ValueError, TypeError):
            pass
    db_max = max(existing_ids) if existing_ids else 0
    seq_doc = await sequence_collection.find_one({'_id': sequence_name})
    seq_val = seq_doc['sequence_value'] if seq_doc else 0
    next_value = max(db_max, seq_val) + 1
    await sequence_collection.update_one(
        {'_id': sequence_name},
        {'$set': {'sequence_value': next_value}},
        upsert=True
    )
    return next_value


