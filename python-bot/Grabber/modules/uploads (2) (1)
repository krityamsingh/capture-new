        return await cq.answer("Session expired. Start again.", show_alert=True)

    anim_states[user_id]["rarity"] = full_rarity
    anim_states[user_id]["state"] = "awaiting_event"
    await cq.message.edit_text(
        f"✅ Rarity: `{full_rarity}`\n\n"
        "🎬 **Step 4/4** — Event (optional)\n\nChoose an event or skip:",
        reply_markup=get_anim_event_buttons()
