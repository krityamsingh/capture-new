def get_anim_event_buttons(change_mode=False):
    buttons = []
    row = []
    for event_name, short_key in event_emojis.items():
        emoji = event_name.split()[0]
        label = event_name.split()[-1]
        # callback: ag_ev_{short_key} or ag_evc_{short_key}
        cb = f"ag_evc_{short_key}" if change_mode else f"ag_ev_{short_key}"
        row.append(InlineKeyboardButton(f"{emoji} {label}", callback_data=cb))
        if len(row) == 2:
            buttons.append(row)
            row = []
    if row:
        buttons.append(row)
    skip_cb = "ag_evc_skip" if change_mode else "ag_ev_skip"
    buttons.append([
        InlineKeyboardButton("⏭ Skip", callback_data=skip_cb),
        InlineKeyboardButton("❌ Cancel", callback_data="ag_cancel")
    ])
    return InlineKeyboardMarkup(buttons)


def get_anim_rarity_buttons():
    buttons = []
    row = []
    for rarity, short_key in rarity_short_keys.items():
        emoji = rarity_emojis[rarity]
        label = rarity.split()[1]
        # callback: ag_r_{short_key}  e.g. ag_r_r1
        row.append(InlineKeyboardButton(f"{emoji} {label}", callback_data=f"ag_r_{short_key}"))
        if len(row) == 3:
            buttons.append(row)
            row = []
    if row:
        buttons.append(row)
    buttons.append([InlineKeyboardButton("❌ Cancel", callback_data="ag_cancel")])
    return InlineKeyboardMarkup(buttons)


