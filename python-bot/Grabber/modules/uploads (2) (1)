@app.on_message(filters.private & (filters.animation | filters.video) & uploader_filter)
async def anim_receive_media(client, message):
    user_id = message.from_user.id
    state_data = anim_states.get(user_id)
    if not state_data:
        return

    if message.animation:
        file_id = message.animation.file_id
        media_type = "animation"
    elif message.video:
        file_id = message.video.file_id
        media_type = "video"
    else:
        return

    state = state_data.get("state")

    try:
        # ── NEW CHARACTER UPLOAD ──
        if state == "awaiting_media":
            char_id = str(await get_next_sequence_number('character_id'))
            character = {
                'anim_url': file_id,
                'img_url': file_id,       # fallback so existing systems don't break
                'media_type': media_type,
                'name': state_data["name"],
                'anime': state_data["anime"],
                'rarity': state_data["rarity"],
                'event': state_data.get("event"),
                'id': char_id,
                'is_animated': True
            }
            await collection.insert_one(character)
            await message.reply_text("⏳ Uploading animated waifu...")

            event_line = f"\n{state_data['event']}" if state_data.get("event") else ""
            caption = (
                f"OwO! Animated character!\n\n"
                f"{state_data['anime']}\n"
                f"{char_id}: {state_data['name']}\n"
                f"{rarity_emojis.get(state_data['rarity'], '')} 𝙍𝘼𝙍𝙄𝙏𝙔: {state_data['rarity'].split()[-1]}"
                f"{event_line}\n\n"
                f"➼ ᴀᴅᴅᴇᴅ ʙʏ: [{message.from_user.first_name}](tg://user?id={user_id})"
            )
            await send_anim_media(CHARA_CHANNEL_ID, file_id, media_type, caption)
            await send_anim_media(SUPPORT_CHAT, file_id, media_type, caption)
            await message.reply_text(f"✅ Done! Animated Waifu added with ID: `{char_id}`")
            anim_states.pop(user_id, None)

        # ── UPDATE EXISTING MEDIA ──
        elif state == "updating_media":
            waifu_id = state_data.get("waifu_id")
            waifu = await collection.find_one_and_update(
                {"id": waifu_id},
                {"$set": {"anim_url": file_id, "img_url": file_id, "media_type": media_type}},
                return_document=ReturnDocument.AFTER
            )
            if waifu:
                await message.reply_text("✅ Media updated!")
                caption = (
                    f"🎬 Media Updated!\n"
                    f"👤 By: [{message.from_user.first_name}](tg://user?id={user_id})\n"
                    f"👧 {waifu.get('name', 'Unknown')}"
                )
                await send_anim_media(CHARA_CHANNEL_ID, file_id, media_type, caption)
                await send_anim_media(SUPPORT_CHAT, file_id, media_type, caption)
            else:
                await message.reply_text("❌ Failed to update. Waifu not found.")
            anim_states.pop(user_id, None)

    except Exception as e:
        await message.reply_text(f"⚠️ Error: `{str(e)}`")
        print(f"anim_receive_media error: {e}")
        anim_states.pop(user_id, None)


