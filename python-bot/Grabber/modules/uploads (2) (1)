@app.on_callback_query(filters.regex(r'^ag_setr_'))
async def ag_set_rarity_cb(client, cq):
    await cq.answer()
    # Format: ag_setr_{short_key}_{waifu_id}
    parts = cq.data.split("ag_setr_", 1)[-1].split("_", 1)
    short_key = parts[0]
    waifu_id = parts[1] if len(parts) > 1 else None
    new_rarity = rarity_key_to_name.get(short_key)

    if not new_rarity or not waifu_id:
        return await cq.answer("❌ Invalid data.", show_alert=True)

    waifu = await collection.find_one({"id": waifu_id})
    if not waifu:
        return await cq.answer("❌ Waifu not found.", show_alert=True)

    old_rarity = waifu["rarity"]
    await collection.update_one({"id": waifu_id}, {"$set": {"rarity": new_rarity}})
    updated = await collection.find_one({"id": waifu_id})
    caption = f"✨ Rarity Updated!\n👧 {updated['name']}\n🛠 Old: {old_rarity}\n🌟 New: {new_rarity}"
    await send_anim_media(cq.from_user.id, updated["anim_url"], updated.get("media_type", "animation"), caption)
    await send_anim_media(CHARA_CHANNEL_ID, updated["anim_url"], updated.get("media_type", "animation"), caption)
    await send_anim_media(SUPPORT_CHAT, updated["anim_url"], updated.get("media_type", "animation"), caption)
    await cq.message.edit_text(f"✅ Rarity updated to `{new_rarity}`.")
    anim_states.pop(cq.from_user.id, None)


