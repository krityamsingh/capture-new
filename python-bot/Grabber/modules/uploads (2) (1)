@app.on_message(filters.private & filters.text & uploader_filter)
async def anim_text_handler(client, message):
    # Ignore panel button — handled by separate handler above
    if message.text.strip() == "🎬 Animated Panel 🎬":
        return

    user_id = message.from_user.id
    state_data = anim_states.get(user_id)
    if not state_data:
        return

    text = message.text.strip()
    state = state_data.get("state")

    # ── Step 1: Anime name ──
    if state == "awaiting_anime_name":
        anim_states[user_id]["anime"] = text
        anim_states[user_id]["state"] = "awaiting_char_name"
        await message.reply_text(
            f"✅ Anime: `{text}`\n\n"
            "🎬 **Step 2/4** — Character Name\n\nType the **character name**:",
            reply_markup=InlineKeyboardMarkup([
                [InlineKeyboardButton("❌ Cancel", callback_data="ag_cancel")]
            ])
        )

    # ── Step 2: Character name ──
    elif state == "awaiting_char_name":
        anim_states[user_id]["name"] = text
        anim_states[user_id]["state"] = "awaiting_rarity"
        await message.reply_text(
            f"✅ Name: `{text}`\n\n"
            "🎬 **Step 3/4** — Rarity\n\nChoose a rarity:",
            reply_markup=get_anim_rarity_buttons()
        )

    # ── Add anime ──
    elif state == "adding_anime":
        existing = await collection.find_one({"anime": text})
        if existing:
            await message.reply_text(f"⚠️ Anime **'{text}'** already exists!")
        else:
            await collection.insert_one({"anime": text})
            await message.reply_text(f"✅ **'{text}'** added to the anime list!")
            mention = f"<a href='tg://user?id={user_id}'>{message.from_user.first_name}</a>"
            await app.send_message(CHARA_CHANNEL_ID, f"✨ #NewAnime Added!\n📺 `{text}`\n👤 {mention}")
            await app.send_message(SUPPORT_CHAT, f"✨ #NewAnime Added!\n📺 `{text}`\n👤 {mention}")
        anim_states.pop(user_id, None)

    # ── Rename waifu ──
    elif state == "renaming_waifu":
        waifu_id = state_data.get("waifu_id")
        waifu = await collection.find_one({"id": waifu_id})
        if waifu:
            old_name = waifu["name"]
            await collection.update_one({"id": waifu_id}, {"$set": {"name": text}})
            await message.reply_text(f"✅ Renamed **{old_name}** → **{text}**!")
            mention = f"<a href='tg://user?id={user_id}'>{message.from_user.first_name}</a>"
            caption = f"🔔 #RENAME\n\n🔄 Old: `{old_name}`\n✨ New: `{text}`\n👤 {mention}"
            await send_anim_media(CHARA_CHANNEL_ID, waifu["anim_url"], waifu.get("media_type", "animation"), caption)
            await send_anim_media(SUPPORT_CHAT, waifu["anim_url"], waifu.get("media_type", "animation"), caption)
        else:
            await message.reply_text("❌ Waifu not found.")
        anim_states.pop(user_id, None)

    # ── Rename anime ──
    elif state == "renaming_anime":
        old = state_data.get("anime")
        await collection.update_many({"anime": old}, {"$set": {"anime": text}})
        await message.reply_text(f"✅ Renamed **'{old}'** → **'{text}'**!")
        mention = f"<a href='tg://user?id={user_id}'>{message.from_user.first_name}</a>"
        await app.send_message(CHARA_CHANNEL_ID, f"🔔 #RENIMEANIME\n🔄 `{old}` → `{text}`\n👤 {mention}")
        await app.send_message(SUPPORT_CHAT, f"🔔 #RENIMEANIME\n🔄 `{old}` → `{text}`\n👤 {mention}")
        anim_states.pop(user_id, None)


