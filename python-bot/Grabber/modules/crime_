@app.on_message(filters.command("crime"))
async def crime_menu(client: Client, message: Message):
    user_id = message.from_user.id
    
    # Check if user is jailed
    if user_id in jailed_users:
        release_time = jailed_users[user_id]
        if datetime.now() < release_time:
            time_left = release_time - datetime.now()
            await message.reply_text(f"🚨 You're in jail! Time remaining: {str(time_left).split('.')[0]}")
            return
        else:
            del jailed_users[user_id]
    
    # Check if user is already in a crime
    if user_id in crime_in_progress:
        crime_data = crime_in_progress[user_id]
        elapsed = time.time() - crime_data["start_time"]
        remaining = max(0, crime_data["duration"] - elapsed)
        
        if remaining > 0:
            progress_bar = create_progress_bar(elapsed, crime_data["duration"])
            await message.reply_text(
                f"⏳ Crime in progress: {crime_data['type_name']}\n"
                f"{progress_bar}\n"
                f"Estimated completion in: {int(remaining)} seconds"
            )
            return
        else:
            del crime_in_progress[user_id]
    
    # Create crime menu with difficulty levels
    buttons = []
    for crime_id, crime_info in CRIME_TYPES.items():
        cooldown_expired = True
        if user_id in crime_cooldowns and crime_id in crime_cooldowns[user_id]:
            cooldown_end = crime_cooldowns[user_id][crime_id]
            if datetime.now() < cooldown_end:
                cooldown_expired = False
                time_left = cooldown_end - datetime.now()
                text = f"{crime_info['emoji']} {crime_info['name']} (⌛ {str(time_left).split('.')[0]})"
                buttons.append([InlineKeyboardButton(text, callback_data="crime_cooldown")])
            else:
                del crime_cooldowns[user_id][crime_id]
        
        if cooldown_expired:
            risk_level = "🟢 Low" if crime_info["jail_chance"] < 0.3 else "🟡 Medium" if crime_info["jail_chance"] < 0.6 else "🔴 High"
            text = f"{crime_info['emoji']} {crime_info['name']} | Reward: ${crime_info['min_reward']}-{crime_info['max_reward']} | Risk: {risk_level}"
            buttons.append([InlineKeyboardButton(text, callback_data=f"crime_start_{crime_id}")])
    
    # Add gang and leaderboard options
    buttons.extend([
        [InlineKeyboardButton("👥 Join/Create Gang", callback_data="crime_gang")],
        [InlineKeyboardButton("🏆 Crime Leaderboard", callback_data="crime_leaderboard")]
    ])
    
    await message.reply_text(
        "🔫 **Underworld Crime Network** 🔫\n\n"
        "Choose your operation carefully. Higher risk means higher reward but greater chance of getting caught!\n\n"
        "💼 **Your Stats:**\n"
        f"- Successful Crimes: {crime_leaderboard.get(user_id, {}).get('success', 0)}\n"
        f"- Failed Crimes: {crime_leaderboard.get(user_id, {}).get('failed', 0)}\n"
        f"- Times Jailed: {crime_leaderboard.get(user_id, {}).get('jailed', 0)}",
        reply_markup=InlineKeyboardMarkup(buttons)
    )

def create_progress_bar(elapsed, total):
    progress = min(1.0, elapsed / total)
    filled = int(20 * progress)
    return f"[{'█' * filled}{'░' * (20 - filled)}] {int(progress * 100)}%"

@app.on_callback_query(filters.regex(r"crime_start_(\w+)"))
async def start_crime(client: Client, callback_query: CallbackQuery):
    user_id = callback_query.from_user.id
    crime_id = callback_query.data.split("_")[-1]
    crime_info = CRIME_TYPES[crime_id]
    
    # Set crime in progress
    crime_duration = random.randint(10, 30)  # Crime takes 10-30 seconds
    crime_in_progress[user_id] = {
        "type": crime_id,
        "type_name": crime_info["name"],
        "start_time": time.time(),
        "duration": crime_duration
    }
    
    # Send crime initiation message with animation
    msg = await callback_query.message.edit_text(
        f"🕵️‍♂️ Initiating {crime_info['name']}...\n\n"
        "Preparing equipment...\n"
        "░░░░░░░░░░ 0%"
    )
    
    # Animated preparation sequence
    steps = [
        "Scouting location...",
        "Gathering crew...",
        "Disabling security...",
        "Executing plan..."
    ]
    
    for i, step in enumerate(steps):
        time.sleep(2)
        progress = (i + 1) / len(steps)
        progress_bar = create_progress_bar(progress, 1)
        await msg.edit_text(
            f"🕵️‍♂️ Initiating {crime_info['name']}...\n\n"
            f"{step}\n"
            f"{progress_bar}"
        )
    
    await msg.edit_text(
        f"🚀 {crime_info['name']} in progress!\n\n"
        "Stay low and wait for completion...\n"
        f"Estimated time: {crime_duration} seconds\n\n"
        "Check back with /crime to see progress"
    )
    await callback_query.answer()

@app.on_message(filters.command("completecrime"))
async def complete_crime(client: Client, message: Message):
    user_id = message.from_user.id
    
    if user_id not in crime_in_progress:
        await message.reply_text("You don't have any active crimes!")
        return
    
    crime_data = crime_in_progress[user_id]
    elapsed = time.time() - crime_data["start_time"]
    
    if elapsed < crime_data["duration"]:
        await message.reply_text(f"Crime not completed yet! {int(crime_data['duration'] - elapsed)} seconds remaining.")
        return
    
    # Crime completion logic
    crime_info = CRIME_TYPES[crime_data["type"]]
    success = random.random() < crime_info["success_rate"]
    jailed = random.random() < crime_info["jail_chance"] if not success else False
    
    # Get user data
    user_data = await user_collection.find_one({"id": user_id})
    current_balance = user_data.get("balance", 0) if user_data else 0
    
    # Initialize leaderboard stats
    if user_id not in crime_leaderboard:
        crime_leaderboard[user_id] = {"success": 0, "failed": 0, "jailed": 0}
    
    if success:
        reward = random.randint(crime_info["min_reward"], crime_info["max_reward"])
        new_balance = current_balance + reward
        crime_leaderboard[user_id]["success"] += 1
        
        # Gang bonus if in a gang
        gang_bonus = 0
        for gang_id, gang_data in gangs.items():
            if user_id in gang_data["members"]:
                gang_bonus = int(reward * 0.1)  # 10% gang bonus
                new_balance += gang_bonus
                break
        
        response = (
            f"🎉 **CRIME SUCCESSFUL!**\n\n"
            f"💰 You stole: ${reward}\n"
            f"🏦 New balance: ${new_balance}\n"
            f"🕵️‍♂️ Crime: {crime_info['name']}\n\n"
        )
        
        if gang_bonus > 0:
            response += f"👥 Gang bonus: +${gang_bonus}\n\n"
        
        # Rare loot chance
        if random.random() < 0.05:  # 5% chance for rare loot
            rare_items = ["💎 Diamond", "🖼 Famous Painting", "🔑 VIP Access Card", "💿 Confidential Data"]
            rare_item = random.choice(rare_items)
            rare_value = random.randint(2000, 5000)
            new_balance += rare_value
            response += f"✨ **RARE LOOT!** Found {rare_item} worth ${rare_value}!\n"
        
        response += "🏃‍♂️ You escaped cleanly!"
        
    else:
        penalty = random.randint(int(crime_info["min_reward"] * 0.5), int(crime_info["max_reward"] * 0.5))
        new_balance = max(0, current_balance - penalty)
        crime_leaderboard[user_id]["failed"] += 1
        
        if jailed:
            jail_time = datetime.now() + timedelta(minutes=random.randint(5, 30))
            jailed_users[user_id] = jail_time
            crime_leaderboard[user_id]["jailed"] += 1
            
            response = (
                f"🚨 **CAUGHT BY POLICE!**\n\n"
                f"👮 You failed the {crime_info['name']} and got arrested!\n"
                f"💸 Fine paid: ${penalty}\n"
                f"⏳ Jail time: {str(jail_time - datetime.now()).split('.')[0]}\n\n"
                "Use this time to reflect on your criminal ways..."
            )
        else:
            response = (
                f"😬 **CRIME FAILED!**\n\n"
                f"💸 You lost ${penalty} in the botched {crime_info['name']}\n"
                f"🏦 New balance: ${new_balance}\n\n"
                "You managed to escape but came away empty-handed..."
            )
    
    # Update user balance
    await user_collection.update_one(
        {"id": user_id},
        {"$set": {"balance": new_balance}},
        upsert=True
    )
    
    # Set cooldown
    if user_id not in crime_cooldowns:
        crime_cooldowns[user_id] = {}
    crime_cooldowns[user_id][crime_data["type"]] = datetime.now() + timedelta(seconds=crime_info["cooldown"])
    
    # Clean up
    del crime_in_progress[user_id]
    
    # Send result with animation
    msg = await message.reply_text("Calculating results...")
    time.sleep(2)
    
    for _ in range(3):
        await msg.edit_text("🔍 Reviewing security footage...")
        time.sleep(1)
        await msg.edit_text("📡 Tracing your steps...")
        time.sleep(1)
    
    await msg.edit_text(response)

@app.on_callback_query(filters.regex("crime_leaderboard"))
async def show_leaderboard(client: Client, callback_query: CallbackQuery):
    # Sort by successful crimes
    sorted_users = sorted(
        crime_leaderboard.items(),
        key=lambda x: (x[1]["success"], -x[1]["jailed"]),
        reverse=True
    )[:10]
    
    leaderboard_text = "🏆 **Top Criminals** 🏆\n\n"
    for rank, (user_id, stats) in enumerate(sorted_users, 1):
        try:
            user = await client.get_users(user_id)
            name = user.first_name
        except:
            name = f"User {user_id}"
        
        leaderboard_text += (
            f"{rank}. {name} - ✅ {stats['success']} | ❌ {stats['failed']} | 🚨 {stats['jailed']}\n"
        )
    
    await callback_query.message.edit_text(
        leaderboard_text,
        reply_markup=InlineKeyboardMarkup([
            [InlineKeyboardButton("🔙 Back", callback_data="crime_back")]
        ])
    )

