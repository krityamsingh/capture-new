                [InlineKeyboardButton("🔙 Back", callback_data="crime_gang")]
            ])
        )
        return
    
    buttons.append([InlineKeyboardButton("🔙 Cancel", callback_data="crime_gang")])
    
    await callback_query.message.edit_text(
        "👑 **Transfer Gang Leadership**\n\n"
        "Select a member to make the new leader:",
        reply_markup=InlineKeyboardMarkup(buttons)
    )

