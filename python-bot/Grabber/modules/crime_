# Gang Creation Handler
@app.on_callback_query(filters.regex("gang_create"))
async def create_gang(client: Client, callback_query: CallbackQuery):
    user_id = callback_query.from_user.id
    user_data = await user_collection.find_one({"id": user_id})
    
    # Safely fetch balance as integer
    try:
        balance = int(user_data.get("balance", 0))
    except (ValueError, TypeError):
        balance = 0  # If somehow invalid, fallback to 0

    # Check if user has enough money
    if balance < 5000:
        await callback_query.answer("❌ You need $5000 to create a gang!", show_alert=True)
        return
    
    # Check if user is already in a gang
    for gang_id, gang_data in gangs.items():
        if user_id in gang_data["members"]:
            await callback_query.answer("❌ You're already in a gang!", show_alert=True)
            return
    
    # Ask for gang name
    await callback_query.message.edit_text(
        "🆕 **Create a New Gang**\n\n"
        "Enter your gang name (3-20 characters):\n\n"
        "⚠️ This will cost $5000 from your balance",
        reply_markup=InlineKeyboardMarkup([
            [InlineKeyboardButton("🔙 Cancel", callback_data="crime_gang")]
        ])
    )
    
    # Store temporary state for gang creation
    crime_in_progress[user_id] = {
        "action": "awaiting_gang_name",
        "start_time": time.time()
    }

# Gang Name Handler
@app.on_message(filters.text & filters.private & ~filters.create(filters.command))
async def handle_gang_name(client: Client, message: Message):
    user_id = message.from_user.id

    if user_id not in crime_in_progress or crime_in_progress[user_id].get("action") != "awaiting_gang_name":
        return

    gang_name = message.text.strip()

    # Validate gang name
    if len(gang_name) < 3 or len(gang_name) > 20:
        await message.reply_text(
            "❌ Gang name must be 3-20 characters!",
            reply_markup=InlineKeyboardMarkup([
                [InlineKeyboardButton("🔙 Back", callback_data="crime_gang")]
            ])
        )
        del crime_in_progress[user_id]
        return

    # Check if gang name already exists
    for gang_id, gang_data in gangs.items():
        if gang_data["name"].lower() == gang_name.lower():
            await message.reply_text(
                "❌ Gang name already taken!",
                reply_markup=InlineKeyboardMarkup([
                    [InlineKeyboardButton("🔙 Back", callback_data="crime_gang")]
                ])
            )
            del crime_in_progress[user_id]
            return

    # Deduct money and create gang
    user_data = await user_collection.find_one({"id": user_id})
    new_balance = user_data["balance"] - 5000

    gang_id = f"gang_{random.randint(1000, 9999)}"
    gangs[gang_id] = {
        "id": gang_id,
        "name": gang_name,
        "leader": user_id,
        "members": [user_id],
        "fund": 0,
        "created_date": datetime.now().strftime("%Y-%m-%d"),
        "level": 1,
        "reputation": 0
    }

    # Update user balance
    await user_collection.update_one(
        {"id": user_id},
        {"$set": {"balance": new_balance}},
        upsert=True
    )

    # Send confirmation
    await message.reply_text(
        f"🎉 **Gang Created!**\n\n"
        f"👥 Name: {gang_name}\n"
        f"👑 Leader: You\n"
        f"💰 Creation Cost: $5000\n"
        f"💵 Your New Balance: ${new_balance}\n\n"
        "Use /gang to manage your gang",
        reply_markup=InlineKeyboardMarkup([
            [InlineKeyboardButton("👥 View Gang", callback_data="crime_gang")]
        ])
    )

    del crime_in_progress[user_id]

