@app.on_callback_query(filters.regex("gang_join"))
async def join_gang_menu(client: Client, callback_query: CallbackQuery):
    user_id = callback_query.from_user.id
    
    # Check if user is already in a gang
    for gang_id, gang_data in gangs.items():
        if user_id in gang_data["members"]:
            await callback_query.answer("❌ You're already in a gang!", show_alert=True)
