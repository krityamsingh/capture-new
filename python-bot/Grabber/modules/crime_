# Gang Leave Confirm Handler
@app.on_callback_query(filters.regex(r"gang_leave_confirm_(\w+)"))
async def leave_gang_execute(client: Client, callback_query: CallbackQuery):
    user_id = callback_query.from_user.id
    gang_id = callback_query.data.split("_")[-1]
    
    if gang_id in gangs and user_id in gangs[gang_id]["members"]:
        gangs[gang_id]["members"].remove(user_id)
        gang_name = gangs[gang_id]["name"]
        
        # Set cooldown
        if user_id not in crime_cooldowns:
            crime_cooldowns[user_id] = {}
        crime_cooldowns[user_id]["gang_join"] = datetime.now() + timedelta(hours=24)
        
        await callback_query.message.edit_text(
            f"🚪 You've left {gang_name}!\n\n"
            "You can join another gang after 24 hours.",
            reply_markup=InlineKeyboardMarkup([
                [InlineKeyboardButton("🔙 Back", callback_data="crime_gang")]
            ])
        )
        
        # Notify gang leader
        try:
            await client.send_message(
                gangs[gang_id]["leader"],
                f"👤 {callback_query.from_user.first_name} has left your gang {gang_name}!"
            )
        except:
            pass
        
        # Delete gang if empty
        if len(gangs[gang_id]["members"]) == 0:
            del gangs[gang_id]

# Gang Transfer Leadership Handler
@app.on_callback_query(filters.regex("gang_transfer"))
async def transfer_leadership_menu(client: Client, callback_query: CallbackQuery):
    user_id = callback_query.from_user.id
    
    # Find user's gang
    user_gang = None
    for gang_id, gang_data in gangs.items():
        if user_id == gang_data["leader"]:
            user_gang = gang_data
            break
    
    if not user_gang:
        await callback_query.answer("❌ You're not a gang leader!", show_alert=True)
        return
    
    # Create member list
    buttons = []
    for member_id in user_gang["members"]:
        if member_id != user_id:  # Can't transfer to yourself
            try:
                member = await client.get_users(member_id)
                name = member.first_name
            except:
