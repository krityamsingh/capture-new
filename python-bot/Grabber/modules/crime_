# Gang Contribution Handler
@app.on_message(filters.text & filters.private & ~filters.create(filters.command))
async def handle_gang_contribution(client: Client, message: Message):
    user_id = message.from_user.id
    
    if (user_id not in crime_in_progress or 
        crime_in_progress[user_id].get("action") != "awaiting_gang_contribution"):
        return
    
    try:
        amount = int(message.text.strip())
        if amount <= 0:
            raise ValueError
    except:
        await message.reply_text("❌ Please enter a valid positive number!", reply_markup=InlineKeyboardMarkup([
            [InlineKeyboardButton("🔙 Back", callback_data="crime_gang")]
        ]))
        del crime_in_progress[user_id]
        return
    
    gang_id = crime_in_progress[user_id]["gang_id"]
    user_data = await user_collection.find_one({"id": user_id})
    
    # Check if user has enough money
    if user_data.get("balance", 0) < amount:
        await message.reply_text("❌ You don't have enough money!", reply_markup=InlineKeyboardMarkup([
            [InlineKeyboardButton("🔙 Back", callback_data="crime_gang")]
        ]))
        del crime_in_progress[user_id]
        return
    
    # Process contribution
    new_balance = user_data["balance"] - amount
    gangs[gang_id]["fund"] = gangs[gang_id].get("fund", 0) + amount
    
    # Update user balance
    await user_collection.update_one(
        {"id": user_id},
        {"$set": {"balance": new_balance}},
        upsert=True
    )
    
    await message.reply_text(
        f"✅ You contributed ${amount} to {gangs[gang_id]['name']}'s fund!\n\n"
        f"💵 New Gang Fund: ${gangs[gang_id]['fund']}\n"
        f"💰 Your New Balance: ${new_balance}",
        reply_markup=InlineKeyboardMarkup([
            [InlineKeyboardButton("👥 View Gang", callback_data="crime_gang")]
        ])
    )
    
    del crime_in_progress[user_id]

