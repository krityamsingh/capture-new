# Gang Join Confirm Handler
@app.on_callback_query(filters.regex(r"gang_join_(\w+)"))
async def join_gang_confirm(client: Client, callback_query: CallbackQuery):
    user_id = callback_query.from_user.id
    gang_id = callback_query.data.split("_")[-1]
    
    # Check if user is already in a gang
    for g_id, gang_data in gangs.items():
        if user_id in gang_data["members"]:
            await callback_query.answer("❌ You're already in a gang!", show_alert=True)
            return
    
    # Add user to gang
    if gang_id in gangs:
        if len(gangs[gang_id]["members"]) >= 10:
            await callback_query.answer("❌ Gang is full!", show_alert=True)
            return
        
        gangs[gang_id]["members"].append(user_id)
        
        # Notify gang members
        gang_name = gangs[gang_id]["name"]
        try:
            leader = await client.get_users(gangs[gang_id]["leader"])
            leader_name = leader.first_name
        except:
            leader_name = "Unknown"
        
        await callback_query.message.edit_text(
            f"🎉 You've joined {gang_name}!\n\n"
            f"👑 Leader: {leader_name}\n"
            f"👥 Members: {len(gangs[gang_id]['members'])}/10\n\n"
            "You now get 10% bonus on successful crimes!",
            reply_markup=InlineKeyboardMarkup([
                [InlineKeyboardButton("👥 View Gang", callback_data="crime_gang")]
            ])
        )
        
        # Notify gang leader
        try:
            await client.send_message(
                gangs[gang_id]["leader"],
                f"👤 {callback_query.from_user.first_name} has joined your gang {gang_name}!"
            )
        except:
            pass

