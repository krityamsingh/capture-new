@app.on_callback_query(filters.regex(r"gang_disband_confirm_(\w+)"))
async def disband_gang_execute(client: Client, callback_query: CallbackQuery):
    user_id = callback_query.from_user.id
    gang_id = callback_query.data.split("_")[-1]
    
    if gang_id in gangs and user_id == gangs[gang_id]["leader"]:
        gang_name = gangs[gang_id]["name"]
        member_ids = gangs[gang_id]["members"].copy()
        
        # Notify members
        for member_id in member_ids:
            if member_id != user_id:  # Don't notify yourself
                try:
                    await client.send_message(
                        member_id,
                        f"💣 Your gang {gang_name} has been disbanded by the leader!"
                    )
                except:
                    pass
        
        # Delete gang
        del gangs[gang_id]
        
        await callback_query.message.edit_text(
            f"💥 {gang_name} has been disbanded!",
            reply_markup=InlineKeyboardMarkup([
                [InlineKeyboardButton("🔙 Back", callback_data="crime_gang")]
            ])
        )

