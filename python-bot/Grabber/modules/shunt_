last_usage_time_hunt = {}

@app.on_message(filters.command(["hunt"]))
async def hunt_command(client, message):
    user_id = message.from_user.id
    if user_id in temp_block and time.time() < temp_block[user_id]:
        return

    current_time = time.time()
    if user_id in last_usage_time_hunt and current_time - last_usage_time_hunt[user_id] < cooldown_duration_hunt:
        remaining_time = int(cooldown_duration_hunt - (current_time - last_usage_time_hunt[user_id]))
        return await message.reply_text(f"You're on cooldown. Please wait {remaining_time} seconds before hunting again.")

    try:
        try:
            await app.get_chat_member(MUST_JOIN, user_id)
        except UserNotParticipant:
            link = f"https://t.me/{MUST_JOIN}"
            return await message.reply_text(
                f"You must join the support group to use this command. Please join [here]({link}).",
                reply_markup=InlineKeyboardMarkup([[InlineKeyboardButton("Join", url=link)]]),
                disable_web_page_preview=True
            )

        dungeon = random.choice(dungeons)
        image_url = dungeon["image_url"]
        win_chance = dungeon["win_chance"]
        gold_range = dungeon["gold_reward"]
        xp_range = dungeon["xp_reward"]
        special_drops = dungeon["special_drop"]
        loss_message = dungeon["loss_message"]

        await message.reply_photo(photo=image_url, caption=f"🗡 You have entered the **{dungeon['name']}** (Rank {dungeon['rank']})")

        await asyncio.sleep(2)

        if random.randint(1, 100) <= win_chance:
            gold_won = random.randint(*gold_range)
            xp_won = random.randint(*xp_range)
            special_item = random.choice(special_drops)

            await user_collection.update_one({'id': user_id}, {'$inc': {'gold': gold_won, 'xp': xp_won}})
            await message.reply_text(f"🎉 You **won** the battle!\n🏆 **Gold:** {gold_won}\n🔹 **XP:** {xp_won}\n🎁 **Special Drop:** {special_item}")

        else:
            await message.reply_text(loss_message)

        last_usage_time_hunt[user_id] = current_time

    except Exception as e:
        await message.reply_text("An error occurred while processing your request. Please try again later.")

@app.on_message(filters.command(["leaderboard"]))
async def leaderboard_command(client, message):
    top_users = user_collection.find().sort("gold", -1).limit(5)
    leaderboard_text = "🏆 **Hunting Leaderboard** 🏆\n\n"

    async for user in top_users:
        username = user.get("username", "Unknown")
        gold = user.get("gold", 0)
        leaderboard_text += f"👑 {username} - 💰 {gold} Gold\n"

    await message.reply_text(leaderboard_text)

