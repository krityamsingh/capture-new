async def get_next_sequence_number(sequence_name: str = "character_id") -> int:
    """Get next character ID with safety checks."""
    try:
        all_chars = await collection.find(
            {"id": {"$exists": True}}, {"id": 1}
        ).to_list(length=None)

        existing_ids = []
        for c in all_chars:
            try:
                existing_ids.append(int(c["id"]))
            except (ValueError, TypeError):
                pass
        db_max = max(existing_ids) if existing_ids else 0

        seq_doc = await sequences_db.find_one({"_id": sequence_name})
        seq_val = seq_doc["sequence_value"] if seq_doc else 0

        next_val = max(db_max, seq_val) + 1

        await sequences_db.update_one(
            {"_id": sequence_name},
            {"$set": {"sequence_value": next_val}},
            upsert=True,
        )
        return next_val
    except Exception as e:
        raise RuntimeError(f"Failed to get next sequence number: {str(e)}")


def _parse_caption(caption: str) -> Optional[Tuple[str, str, str]]:
    """Parse 3-line caption with rarity validation."""
    lines = [ln.strip() for ln in caption.strip().splitlines() if ln.strip()]
    if len(lines) < 3:
        return None

    def extract_value(line: str) -> str:
        for sep in ("-", ":"):
            if sep in line:
                return line.split(sep, 1)[1].strip()
        return line.strip()

    char_name  = extract_value(lines[0]).title()
    anime      = extract_value(lines[1]).title()
    rarity_raw = extract_value(lines[2])

    if not char_name or not anime or not rarity_raw:
        return None

    rarity = _validate_rarity(rarity_raw)
    if not rarity:
        return None

    return char_name, anime, rarity


def _validate_rarity(rarity_str: str) -> Optional[str]:
    """Validate and normalize rarity string."""
    rarity_str = rarity_str.strip()
    
    # Exact match
    for valid in VALID_RARITIES:
        if valid.lower() == rarity_str.lower():
            return valid
    
    # Emoji match
    raw_emoji = rarity_str.split()[0] if rarity_str else ""
    for valid in VALID_RARITIES:
        if valid.startswith(raw_emoji) and raw_emoji:
            return valid
    
    # Fuzzy match
    def text_only(s):
        return re.sub(r"[^\w\s]", "", s, flags=re.UNICODE).lower().strip()
    
    raw_text = text_only(rarity_str)
    best = None
    best_score = 0
    for valid in VALID_RARITIES:
        valid_text = text_only(valid)
        matches = sum(a == b for a, b in zip(raw_text, valid_text))
        score = matches / max(len(raw_text), len(valid_text), 1)
        if score > best_score and score >= 0.6:
            best = valid
            best_score = score
    
    return best


async def _validate_image_url(url: str) -> Tuple[bool, Optional[str]]:
    """
    Check if URL is accessible and returns valid image content.
    Returns (is_valid: bool, error_reason: Optional[str])
    """
    if not url:
        return False, "URL is empty"
    
    if not (url.startswith("http://") or url.startswith("https://")):
        return False, "Invalid URL format"
    
    try:
        session = await get_aiohttp_session()
        async with session.head(
            url,
            timeout=aiohttp.ClientTimeout(total=10),
            allow_redirects=True,
            ssl=False,  # Some hosts have SSL issues
        ) as resp:
            # Check HTTP status
            if resp.status >= 400:
                return False, f"HTTP {resp.status}"
            
            # Check content type
            content_type = resp.headers.get("Content-Type", "").lower()
            if not any(img_type in content_type for img_type in ["image/", "jpeg", "jpg", "png", "gif", "webp"]):
                return False, f"Invalid content type: {content_type}"
            
            # Check content length if available
            content_length = resp.headers.get("Content-Length")
            if content_length:
                try:
                    size_mb = int(content_length) / (1024 * 1024)
                    if size_mb > 50:
                        return False, f"File too large: {size_mb:.1f}MB"
                    if size_mb < 0.01:
                        return False, f"File too small: {size_mb*1024:.1f}KB"
                except (ValueError, TypeError):
                    pass
            
            return True, None
    
    except asyncio.TimeoutError:
        return False, "Request timeout"
    except aiohttp.ClientError as e:
        return False, f"Network error: {type(e).__name__}"
    except Exception as e:
        return False, f"Error: {str(e)[:50]}"


async def _is_url_broken(url: str) -> Tuple[bool, Optional[str]]:
    """
    Check if URL is reachable.
    Returns (is_broken: bool, error_reason: Optional[str])
    """
    if not url:
        return True, "URL is empty"
    
    if not (url.startswith("http://") or url.startswith("https://")):
        return False, None   # Telegram file_id
    
    try:
        session = await get_aiohttp_session()
        async with session.head(
            url,
            timeout=aiohttp.ClientTimeout(total=8),
            allow_redirects=True,
            ssl=False,
        ) as resp:
            if resp.status >= 400:
                return True, f"HTTP {resp.status}"
            return False, None
    except asyncio.TimeoutError:
        return True, "Timeout"
    except aiohttp.ClientError as e:
        return True, f"Network: {type(e).__name__}"
    except Exception as e:
        return True, f"Error: {str(e)[:50]}"


def _is_valid_image_file(file_path: str) -> Tuple[bool, Optional[str]]:
    """
    Check if local file is a valid image.
    Returns (is_valid: bool, error_reason: Optional[str])
    """
    if not os.path.exists(file_path):
        return False, "File not found"
    
    try:
        file_size = os.path.getsize(file_path)
        
        # Check file size (10KB - 50MB)
        if file_size < 10240:
            return False, f"File too small: {file_size/1024:.1f}KB"
        if file_size > 50 * 1024 * 1024:
            return False, f"File too large: {file_size/(1024*1024):.1f}MB"
        
        # Check magic bytes (file signature)
        with open(file_path, 'rb') as f:
            magic = f.read(12)
        
        # Valid image signatures
        if magic.startswith(b'\xFF\xD8\xFF'):  # JPEG
            return True, None
        elif magic.startswith(b'\x89PNG\r\n\x1a\n'):  # PNG
            return True, None
        elif magic.startswith(b'GIF8'):  # GIF
            return True, None
        elif magic.startswith(b'RIFF') and magic[8:12] == b'WEBP':  # WEBP
            return True, None
        else:
            return False, f"Unrecognized image format (magic: {magic[:4].hex()})"
    
    except Exception as e:
        return False, f"File validation error: {str(e)[:50]}"


async def _upload_to_catbox(file_path: str, retry_count: int = 0) -> str:
    """
    Upload file to catbox.moe with retry logic and validation.
    Returns the public HTTPS URL.
    """
    # Validate local file
    is_valid, error = _is_valid_image_file(file_path)
    if not is_valid:
        raise RuntimeError(f"Invalid image file: {error}")
    
    try:
        with open(file_path, "rb") as fh:
            # Use sync requests for file upload (more reliable)
            resp = requests.post(
                "https://catbox.moe/user/api.php",
                data={"reqtype": "fileupload"},
                files={"fileToUpload": fh},
                timeout=CATBOX_TIMEOUT,
            )
        
        if resp.status_code != 200:
            raise RuntimeError(f"Catbox HTTP {resp.status_code}: {resp.text[:200]}")
        
        url = resp.text.strip()
        
        # Validate response is a URL
        if not url.startswith("https://"):
            raise RuntimeError(f"Invalid response from Catbox: {url[:100]}")
        
        # Validate the returned URL is accessible and contains image
        is_valid_url, url_error = await _validate_image_url(url)
        if not is_valid_url:
            if retry_count < MAX_CATBOX_RETRIES - 1:
                await asyncio.sleep(CATBOX_RETRY_DELAY)
                return await _upload_to_catbox(file_path, retry_count + 1)
            else:
                raise RuntimeError(f"Uploaded URL invalid: {url_error}")
        
        return url
    
    except requests.exceptions.Timeout:
        if retry_count < MAX_CATBOX_RETRIES - 1:
            await asyncio.sleep(CATBOX_RETRY_DELAY)
            return await _upload_to_catbox(file_path, retry_count + 1)
        else:
            raise RuntimeError("Catbox upload timeout after retries")
    
    except requests.exceptions.RequestException as e:
        if retry_count < MAX_CATBOX_RETRIES - 1:
            await asyncio.sleep(CATBOX_RETRY_DELAY)
            return await _upload_to_catbox(file_path, retry_count + 1)
        else:
            raise RuntimeError(f"Catbox upload failed: {str(e)[:100]}")


async def _save_character(
    client: Client,
    photo_msg: Message,
    char_name: str,
    anime: str,
    rarity: str,
    uploader_mention: str,
) -> dict:
    """
    Download photo → upload to Catbox → assign sequence ID →
    insert into MongoDB → announce to channels.
    """
    with tempfile.NamedTemporaryFile(suffix=".jpg", delete=False) as tmp:
        tmp_path = tmp.name

    try:
        # Download photo
        await client.download_media(photo_msg.photo, file_name=tmp_path)
        
        # Upload to Catbox with validation
        img_url = await _upload_to_catbox(tmp_path)
        
    except Exception as e:
        try:
            os.unlink(tmp_path)
        except OSError:
            pass
        raise RuntimeError(f"Upload process failed: {str(e)}")
    finally:
        try:
            os.unlink(tmp_path)
        except OSError:
            pass

    # Generate character data
    char_id = str(await get_next_sequence_number()).zfill(2)
    price   = random.randint(60_000, 80_000)

    character = {
        "img_url": img_url,
        "name":    char_name,
        "anime":   anime,
        "rarity":  rarity,
        "price":   price,
        "id":      char_id,
    }

    channel_caption = (
        f"🌸 **New Character Added!**\n\n"
        f"👤 **Name:** {char_name}\n"
        f"📺 **Anime:** {anime}\n"
        f"⭐ **Rarity:** {rarity}\n"
        f"💰 **Price:** {price:,}\n"
        f"🆔 **ID:** `{char_id}`\n"
        f"➕ **Added by:** {uploader_mention}"
    )

    # Send to upload channel
    try:
        sent = await client.send_photo(
            chat_id=UPLOAD_CHANNEL_ID,
            photo=img_url,
            caption=channel_caption,
        )
        character["message_id"] = sent.id
    except Exception as e:
        raise RuntimeError(f"Failed to send to upload channel: {str(e)}")

    # Send to announcement group
    try:
        await client.send_photo(
            chat_id=UPLOAD_GC_ID,
            photo=img_url,
            caption=channel_caption,
        )
    except Exception as e:
        # Non-critical failure
        pass

    # Send to character channel
    if CHARA_CHANNEL_ID not in (UPLOAD_CHANNEL_ID, UPLOAD_GC_ID):
        try:
            await client.send_photo(
                chat_id=CHARA_CHANNEL_ID,
                photo=img_url,
                caption=channel_caption,
            )
        except Exception:
            pass

    # Save to database
    try:
        await collection.insert_one(character)
    except Exception as e:
        raise RuntimeError(f"Database insert failed: {str(e)}")
    
    return character


