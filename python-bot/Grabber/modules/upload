#  /findchar — Search for characters by name or anime
# ══════════════════════════════════════════════════════════════════════════════

@app.on_message(filters.command("findchar") & uploader_filter)
async def findchar_command(client: Client, message: Message):
    """Search for characters."""
    args = message.text.split(None, 1)
    if len(args) < 2:
        return await message.reply_text("❌ **Usage:** `/findchar <name or anime>`")

    search_term = args[1].strip().lower()
    try:
        chars = await collection.find({
            "$or": [
                {"name": {"$regex": search_term, "$options": "i"}},
                {"anime": {"$regex": search_term, "$options": "i"}},
            ]
        }, {"id": 1, "name": 1, "anime": 1, "rarity": 1}).to_list(length=50)

        if not chars:
            return await message.reply_text(f"❌ No results for `{search_term}`.")

        lines = [f"🔍 **Results** (`{len(chars)}`)\n{'─'*40}\n"]
        for c in chars[:20]:
            lines.append(f"🆔 `{c['id']}` | {c['name']} | {c['anime']}")
        
        if len(chars) > 20:
            lines.append(f"\n... and {len(chars)-20} more")
        
        await message.reply_text("\n".join(lines))
    except Exception as e:
        await message.reply_text(f"❌ **Error:** `{str(e)}`")


# ══════════════════════════════════════════════════════════════════════════════
#  /checkall — scan all DB characters for broken/missing URLs
# ══════════════════════════════════════════════════════════════════════════════

@app.on_message(filters.command("checkall") & uploader_filter)
async def checkall_command(client: Client, message: Message):
    """Scan database for corrupted URLs."""
    status_msg = await message.reply_text(
        "🔍 **Scanning database…**\n⏳ Checking every character"
    )

    try:
        all_chars = await collection.find(
            {}, {"id": 1, "name": 1, "anime": 1, "rarity": 1, "img_url": 1, "video_url": 1}
        ).to_list(length=None)
    except Exception as e:
        return await status_msg.edit_text(f"❌ **DB Error:** `{str(e)}`")

    if not all_chars:
        return await status_msg.edit_text("📭 **Database is empty.**")

    broken = []
    for i, char in enumerate(all_chars):
        img_url = char.get("img_url", "").strip()
        vid_url = char.get("video_url", "").strip()

        img_broken, img_reason = await _is_url_broken(img_url) if img_url else (True, "Missing")
        vid_broken, vid_reason = await _is_url_broken(vid_url) if vid_url else (False, None)

        if (not img_url and not vid_url) or (img_url and img_broken and not vid_url):
            broken.append({
                "id": char['id'], "name": char['name'], "anime": char['anime'],
                "rarity": char['rarity'], "img_url": img_url or "—", 
                "img_status": f"❌ {img_reason}" if img_url else "❌ Missing",
                "vid_status": f"❌ {vid_reason}" if vid_url and vid_broken else ("✅" if vid_url else "—"),
            })

        if (i + 1) % 50 == 0:
            await status_msg.edit_text(
                f"🔍 **Scanning… [{i+1}/{len(all_chars)}]**\n"
                f"🚨 Broken: `{len(broken)}`"
            )
            await asyncio.sleep(0.2)

    if not broken:
        return await status_msg.edit_text(
            f"✅ **Scan Complete!**\n🗂 {len(all_chars)} characters checked\n🎉 All healthy!"
        )

    lines = [
        f"🚨 **Corrupted URLs**\n🗂 Total: `{len(all_chars)}` | 💔 Broken: `{len(broken)}`\n"
        f"{'─'*50}\n"
    ]
    for b in broken:
        lines.append(
            f"🆔 `{b['id']}` — {b['name']}\n"
            f"   {b['anime']} | {b['rarity']}\n"
            f"   {b['img_status']}\n"
        )

    lines.append(f"\n{'─'*50}\n💡 Use `/replace` to fix")
    
    # Send in chunks if too long
    text = "\n".join(lines)
    if len(text) > 3000:
        await status_msg.edit_text(text[:3000] + "\n\n... (continued in next message)")
        await message.reply_text(text[3000:])
    else:
        await status_msg.edit_text(text)


# ══════════════════════════════════════════════════════════════════════════════
#  /replace — fix a character's data
# ══════════════════════════════════════════════════════════════════════════════

@app.on_message(filters.command("replace") & uploader_filter)
async def replace_command(client: Client, message: Message):
    """Replace character data: /replace <id>-<url>-<anime>-<name>-<rarity>"""
    raw = message.text.split(None, 1)
    if len(raw) < 2:
        return await message.reply_text(
            "❌ **Usage:** `/replace <id>-<url>-<anime>-<name>-<rarity>`\n\n"
            "Example: `/replace 42-https://example.com/img.jpg-Naruto-Kakashi-🟠 Rare`"
        )

    parts = raw[1].split("-", 4)
    if len(parts) < 5:
        return await message.reply_text("❌ **Need 5 fields:** id-url-anime-name-rarity")

    char_id, new_url, anime, name, rarity_raw = [p.strip() for p in parts]
    
    if not all([char_id, new_url, anime, name, rarity_raw]):
        return await message.reply_text("❌ **All fields required.**")

    rarity = _validate_rarity(rarity_raw)
    if not rarity:
        return await message.reply_text(f"❌ **Invalid rarity:** `{rarity_raw}`")

    status = await message.reply_text("⏳ **Validating URL…**")

    # Validate URL
    is_valid, error = await _validate_image_url(new_url)
    if not is_valid:
        return await status.edit_text(f"❌ **URL invalid:** {error}\n`{new_url}`")

    # Find character
    try:
        char = await collection.find_one({"id": char_id})
    except Exception as e:
        return await status.edit_text(f"❌ **DB Error:** `{str(e)}`")

    if not char:
        return await status.edit_text(f"❌ **ID `{char_id}` not found.**")

    old_name = char.get("name", "Unknown")
    old_anime = char.get("anime", "Unknown")
    old_rarity = char.get("rarity", "Unknown")

    # Update
    try:
        await collection.update_one(
            {"id": char_id},
            {"$set": {"img_url": new_url, "name": name.title(), "anime": anime.title(), "rarity": rarity}}
        )
    except Exception as e:
        return await status.edit_text(f"❌ **Update failed:** `{str(e)}`")

    mention = f"[{message.from_user.first_name}](tg://user?id={message.from_user.id})"
    result = (
        f"🔄 **Replaced!**\n\n"
        f"🆔 `{char_id}`\n"
        f"👤 {old_name} → {name}\n"
        f"📺 {old_anime} → {anime}\n"
        f"⭐ {old_rarity} → {rarity}\n\n"
        f"✅ By: {mention}"
    )
    await status.edit_text(result)


