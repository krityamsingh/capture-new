@app.on_message(filters.command("charinfo") & uploader_filter)
async def charinfo_command(client: Client, message: Message):
    """Get detailed information about a character."""
    args = message.text.split()
    if len(args) < 2:
        return await message.reply_text("❌ **Usage:** `/charinfo <id>`")

    char_id = args[1].strip()
    try:
        char = await collection.find_one({"id": char_id})
        if not char:
            return await message.reply_text(f"❌ **ID `{char_id}` not found.**")

        img_broken, img_reason = await _is_url_broken(char.get("img_url", ""))
        vid_broken, vid_reason = await _is_url_broken(char.get("video_url", ""))

        info = (
            f"📋 **Character Info**\n{'─'*40}\n\n"
            f"🆔 **ID:** `{char.get('id')}`\n"
            f"👤 **Name:** {char.get('name')}\n"
            f"📺 **Anime:** {char.get('anime')}\n"
            f"⭐ **Rarity:** {char.get('rarity')}\n"
            f"💰 **Price:** {char.get('price', 0):,}\n\n"
            f"🖼 **Image:** {'✅ OK' if not img_broken else f'❌ {img_reason}'}\n"
            f"   `{char.get('img_url', '—')[:60]}`\n"
        )
        if char.get('video_url'):
            info += f"\n🎥 **Video:** {'✅ OK' if not vid_broken else f'❌ {vid_reason}'}\n"
        
        await message.reply_text(info)
    except Exception as e:
        await message.reply_text(f"❌ **Error:** `{str(e)}`")


