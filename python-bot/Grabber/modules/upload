#  /upload — single photo, sequence ID assigned automatically
# ══════════════════════════════════════════════════════════════════════════════

@app.on_message(filters.command("upload") & uploader_filter)
async def upload_cmd(client: Client, message: Message):
    """Reply to a photo with /upload. Caption can be on photo or after command."""
    reply = message.reply_to_message
    if not reply or not reply.photo:
        return await message.reply_text(
            "❌ **Reply to a photo** with `/upload`.\n\n" + CAPTION_FORMAT_HELP
        )

    raw_cap = (reply.caption or "").strip()
    if not raw_cap:
        parts = message.text.split(None, 1)
        raw_cap = parts[1].strip() if len(parts) > 1 else ""

    parsed = _parse_caption(raw_cap) if raw_cap else None
    if not parsed:
        return await message.reply_text(
            "❌ **Invalid or missing caption.**\n\n" + CAPTION_FORMAT_HELP
        )

    char_name, anime, rarity = parsed
    status = await message.reply_text(
        f"⏳ **Uploading** `{char_name}` to Catbox and validating…"
    )

    mention = f"[{message.from_user.first_name}](tg://user?id={message.from_user.id})"
    try:
        char = await _save_character(client, reply, char_name, anime, rarity, mention)
    except Exception as e:
        return await status.edit_text(
            f"❌ **Upload failed:**\n`{str(e)}`\n\n"
            "**Troubleshooting:**\n"
            "• Check image format (JPEG, PNG supported)\n"
            "• Check image size (10KB - 50MB)\n"
            "• Ensure stable internet connection"
        )

    await status.edit_text(
        f"✅ **Character saved!**\n\n"
        f"🆔 **ID:** `{char['id']}`\n"
        f"👤 **Name:** {char['name']}\n"
        f"📺 **Anime:** {char['anime']}\n"
        f"⭐ **Rarity:** {char['rarity']}\n"
        f"💰 **Price:** {char['price']:,}\n"
        f"🖼 **URL:** `{char['img_url'][:60]}…`"
    )


# ══════════════════════════════════════════════════════════════════════════════
#  /bulkupload — upload a full media-group album in one command
# ══════════════════════════════════════════════════════════════════════════════

@app.on_message(filters.command("bulkupload") & uploader_filter)
async def bulkupload_cmd(client: Client, message: Message):
    """Reply to the FIRST photo of an album with /bulkupload."""
    reply = message.reply_to_message
    if not reply or not reply.photo:
        return await message.reply_text(
            "❌ **Reply to the first photo of an album** with `/bulkupload`.\n\n"
            + CAPTION_FORMAT_HELP
        )

    media_group_id = reply.media_group_id
    if not media_group_id:
        return await message.reply_text(
            "⚠️ That photo is not part of an album.\nUse `/upload` for a single photo."
        )

    status = await message.reply_text("📥 **Collecting album photos…** ⏳")

    album_msgs: list[Message] = []
    async for m in client.get_chat_history(reply.chat.id, limit=50):
        if m.media_group_id == media_group_id and m.photo:
            album_msgs.append(m)
        if len(album_msgs) >= 10:
            break

    if not album_msgs:
        return await status.edit_text("❌ Could not retrieve album photos.")

    album_msgs.sort(key=lambda m: m.id)

    mention = f"[{message.from_user.first_name}](tg://user?id={message.from_user.id})"
    saved, failed = [], []

    for i, photo_msg in enumerate(album_msgs, 1):
        raw_cap = (photo_msg.caption or "").strip()
        parsed  = _parse_caption(raw_cap) if raw_cap else None

        if not parsed:
            failed.append(f"Photo {i} — bad/missing caption")
            continue

        char_name, anime, rarity = parsed
        await status.edit_text(f"📤 **Uploading {i}/{len(album_msgs)}:** `{char_name}`…")

        try:
            char = await _save_character(client, photo_msg, char_name, anime, rarity, mention)
            saved.append(f"✅ `{char['id']}` — **{char['name']}** ({char['anime']})")
        except Exception as e:
            failed.append(f"Photo {i} — {char_name}: {str(e)[:60]}")

        await asyncio.sleep(0.5)

    lines = [f"📦 **Bulk Upload Complete**", f"✅ {len(saved)} | ❌ {len(failed)}\n", *saved]
    if failed:
        lines += ["", "**Failures:**", *failed]

    await status.edit_text("\n".join(lines))


