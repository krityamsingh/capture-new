#  /queueupload — interactive one-by-one queue
# ══════════════════════════════════════════════════════════════════════════════

@app.on_message(filters.command("queueupload") & uploader_filter)
async def queueupload_start(client: Client, message: Message):
    """Open a queue-upload session."""
    uid = message.from_user.id
    _upload_queue[uid] = []
    await message.reply_text(
        "📋 **Queue mode ON!**\n\nSend photos one by one:\n"
        + CAPTION_FORMAT_HELP
        + "\n\n• `/queuedone` → save\n"
        "• `/queuecancel` → discard"
    )


@app.on_message(filters.private & filters.photo & uploader_filter)
async def queueupload_receive(client: Client, message: Message):
    """Capture photos during queue session."""
    uid = message.from_user.id
    if uid not in _upload_queue:
        return

    raw_cap = (message.caption or "").strip()
    parsed  = _parse_caption(raw_cap) if raw_cap else None

    if not parsed:
        return await message.reply_text(
            "⚠️ **Caption invalid** — photo NOT queued.\n\n" + CAPTION_FORMAT_HELP
        )

    char_name, anime, rarity = parsed
    _upload_queue[uid].append({
        "msg": message, "char_name": char_name, "anime": anime, "rarity": rarity,
    })
    await message.reply_text(
        f"✅ **Queued [{len(_upload_queue[uid])}]:** {char_name}\n"
        "Send more, or `/queuedone`"
    )


@app.on_message(filters.command("queuedone") & uploader_filter)
async def queueupload_done(client: Client, message: Message):
    """Commit queue to database."""
    uid = message.from_user.id
    queue = _upload_queue.get(uid)

    if queue is None:
        return await message.reply_text("❌ No active queue. Use `/queueupload` first.")
    if not queue:
        _upload_queue.pop(uid, None)
        return await message.reply_text("⚠️ Queue is empty.")

    status = await message.reply_text(f"📤 **Saving {len(queue)} character(s)…**")
    mention = f"[{message.from_user.first_name}](tg://user?id={uid})"
    saved, failed = [], []

    for i, item in enumerate(queue, 1):
        await status.edit_text(f"📤 **{i}/{len(queue)}:** `{item['char_name']}`…")
        try:
            char = await _save_character(
                client, item["msg"], item["char_name"], item["anime"], item["rarity"], mention
            )
            saved.append(f"✅ `{char['id']}` — **{char['name']}**")
        except Exception as e:
            failed.append(f"❌ {item['char_name']}: {str(e)[:60]}")
        await asyncio.sleep(0.4)

    _upload_queue.pop(uid, None)
    lines = [f"🎉 **Complete**: ✅ {len(saved)} | ❌ {len(failed)}\n", *saved]
    if failed:
        lines += ["", "**Failures:**", *failed]
    await status.edit_text("\n".join(lines))


@app.on_message(filters.command("queuecancel") & uploader_filter)
async def queueupload_cancel(client: Client, message: Message):
    """Discard current queue."""
    uid = message.from_user.id
    queue = _upload_queue.pop(uid, None)
    if queue is None:
        return await message.reply_text("❌ No active queue.")
    await message.reply_text(f"🗑 **Cancelled** — {len(queue)} photo(s) discarded.")


