@app.on_message(filters.command("adduploader") & owner_filter)
async def add_uploader(client: Client, message: Message):
    """Add uploader privileges."""
    if message.reply_to_message and message.reply_to_message.from_user:
        uid = message.reply_to_message.from_user.id
        name = message.reply_to_message.from_user.first_name
    else:
        args = message.text.split()
        if len(args) < 2:
            return await message.reply_text("❌ Reply to user or `/adduploader <id>`")
        try:
            uid = int(args[1])
            u = await client.get_users(uid)
            name = u.first_name
        except:
            return await message.reply_text("❌ **Invalid user ID.**")

    if await uploaderdb.find_one({"user_id": uid}):
        return await message.reply_text(f"⚠️ **{name}** already uploader.")

    try:
        await uploaderdb.insert_one({"user_id": uid})
        await message.reply_text(f"✅ **{name}** (`{uid}`) added!\n\nAvailable commands:\n• `/upload`\n• `/bulkupload`\n• `/queueupload`\n• `/checkall`\n• `/replace`")
    except Exception as e:
        await message.reply_text(f"❌ **Failed:** `{str(e)}`")


@app.on_message(filters.command("rmuploader") & owner_filter)
async def remove_uploader(client: Client, message: Message):
    """Remove uploader privileges."""
    if message.reply_to_message and message.reply_to_message.from_user:
        uid = message.reply_to_message.from_user.id
        name = message.reply_to_message.from_user.first_name
    else:
        args = message.text.split()
        if len(args) < 2:
            return await message.reply_text("❌ Reply to user or `/rmuploader <id>`")
        try:
            uid = int(args[1])
            u = await client.get_users(uid)
            name = u.first_name
        except:
            return await message.reply_text("❌ **Invalid user ID.**")

    if not await uploaderdb.find_one({"user_id": uid}):
