import random
from pyrogram import Client, filters
from pyrogram.errors import UserNotParticipant
from pyrogram.types import InlineKeyboardButton as IKB, InlineKeyboardMarkup as IKM, CallbackQuery
from pyrogram.enums import ParseMode
from datetime import datetime
from . import user_collection, app, collection
from .block import block_dec, block_cbq

ags = {}
daily_purchases = {}
pending_purchases = {}  # New dictionary to track pending purchases

SUPPORT_GROUP = "Phoenix_Reen"
SUPPORT_CHANNEL = "Capture_Update"

def get_join_buttons():
    return IKM([
        [IKB("рҹҘӮ бҙҠбҙҸЙӘЙҙ кңұбҙңбҙҳбҙҳбҙҸКҖбҙӣ ЙўКҖбҙҸбҙңбҙҳ", url=f"https://t.me/{SUPPORT_GROUP}")],
        [IKB("рҹ§ғ бҙҠбҙҸЙӘЙҙ бҙңбҙҳбҙ…бҙҖбҙӣбҙҮ бҙ„КңбҙҖЙҙЙҙбҙҮКҹ", url=f"https://t.me/{SUPPORT_CHANNEL}")]
    ])

async def send_media_message(message, character, price):
    caption = (
        f"<b>вңЁ бҙҖКҖбҙҖбҙҖ~ КңбҙҮКҖбҙҮ'кңұ бҙҖ бҙӢбҙҖбҙЎбҙҖЙӘЙӘ бҙ„КңбҙҖКҖбҙҖбҙ„бҙӣбҙҮКҖ кң°бҙҸКҖ КҸбҙҸбҙң!</b>\n\n"
        f"<b>рҹ§ғ ЙҙбҙҖбҙҚбҙҮ:</b> {character['name']}\n"
        f"<b>вқ„пёҸ ЙӘбҙ…:</b> {character['id']}\n"
        f"<b>рҹҘӮ КҖбҙҖКҖЙӘбҙӣКҸ:</b> {character['rarity']}\n"
        f"<b>вҳҳпёҸ бҙҳКҖЙӘбҙ„бҙҮ:</b> {price:,} ЙўбҙҸКҹбҙ…\n"
    )

    keyboard = [
        [IKB("рҹӣҚпёҸ КҷбҙңКҸ ЙҙбҙҸбҙЎ", callback_data=f"bg:{character['id']}:{price}:{message.from_user.id}"),
         IKB("рҹҷ… бҙ„бҙҖЙҙбҙ„бҙҮКҹ", callback_data=f"cg:{character['id']}:{message.from_user.id}")]
    ]

    if character['rarity'] == "рҹ§¬ Animation":
        return await message.reply_video(
            video=character['video_url'],
            caption=caption,
            reply_markup=IKM(keyboard),
            parse_mode=ParseMode.HTML
        )
    else:
        return await message.reply_photo(
            photo=character['img_url'],
            caption=caption,
            reply_markup=IKM(keyboard),
            parse_mode=ParseMode.HTML
        )

@app.on_message(filters.command("gbuy"))
@block_dec
async def gbuy(client, message):
    user = message.from_user
    user_id = user.id

    if not message.chat.username or message.chat.username != SUPPORT_GROUP:
        return await message.reply_text(
            f"<b>рҹ§ғ {user.first_name}, бҙӣКңЙӘкңұ бҙ„бҙҸбҙҚбҙҚбҙҖЙҙбҙ… бҙҸЙҙКҹКҸ бҙЎбҙҸКҖбҙӢкңұ ЙӘЙҙ бҙҸбҙңКҖ кңұбҙңбҙҳбҙҳбҙҸКҖбҙӣ ЙўКҖбҙҸбҙңбҙҳ~</b>\n"
            f"<i>бҙҖКҖбҙҖбҙҖ... бҙҳКҹбҙҮбҙҖкңұбҙҮ бҙҠбҙҸЙӘЙҙ Т“ЙӘКҖкңұбҙӣ!</i>",
            reply_markup=get_join_buttons(),
            parse_mode=ParseMode.HTML
        )

    try:
        await client.get_chat_member(SUPPORT_CHANNEL, user_id)
    except UserNotParticipant:
        return await message.reply_text(
            f"<b>рҹ§Ӣ {user.first_name}, КҸбҙҸбҙң бҙҚбҙңкңұбҙӣ бҙҠбҙҸЙӘЙҙ бҙҸбҙңКҖ бҙңбҙҳбҙ…бҙҖбҙӣбҙҮ бҙ„КңбҙҖЙҙЙҙбҙҮКҹ кң°ЙӘКҖкңұбҙӣ~</b>\n\n"
            f"<i>бҙҠбҙҸЙӘЙҙ бҙҖЙҙбҙ… бҙӣКҖКҸ бҙҖЙўбҙҖЙӘЙҙ~ бҙӢбҙҖбҙЎбҙҖЙӘЙӘ!</i>",
            reply_markup=get_join_buttons(),
            parse_mode=ParseMode.HTML
        )

    args = message.command[1:]
    today = datetime.now().date()

    # Check daily limit including pending purchases
    current_pending = len([k for k, v in pending_purchases.items() if v[0] == user_id and v[1] == today])
    if user_id in daily_purchases:
        last_date, count = daily_purchases[user_id]
        if today == last_date and (count + current_pending) >= 3:
            return await message.reply_text(
                "<b>рҹҳј КҸбҙҸбҙң'бҙ бҙҮ КҖбҙҮбҙҖбҙ„КңбҙҮбҙ… КҸбҙҸбҙңКҖ бҙ…бҙҖЙӘКҹКҸ КҹЙӘбҙҚЙӘбҙӣ бҙҸкң° 3 бҙҳбҙңКҖбҙ„КңбҙҖкңұбҙҮкңұ~</b>\n<i>бҙӢбҙҸбҙӣбҙҸбҙЎбҙҖКҖЙӘ!</i>",
                parse_mode=ParseMode.HTML
            )

    if not args:
        return await message.reply_text(
            "<b>рҹҰў бҙҸЙҙбҙҮбҙҮ-бҙ„КңбҙҖЙҙ~ бҙҳКҹбҙҮбҙҖкңұбҙҮ ЙўЙӘбҙ бҙҮ бҙҖ бҙ„КңбҙҖКҖбҙҖбҙ„бҙӣбҙҮКҖ ЙӘбҙ…!</b>\n\n<b>бҙңкңұбҙҖЙўбҙҮ:</b> <code>/gbuy &lt;id&gt;</code>",
            parse_mode=ParseMode.HTML
        )

    character = await collection.find_one({'id': args[0]})
    if not character:
        return await message.reply_text("рҹ’ў <b>бҙ„КңбҙҖКҖбҙҖбҙ„бҙӣбҙҮКҖ ЙҙбҙҸбҙӣ кң°бҙҸбҙңЙҙбҙ…~</b> КҷбҙҖбҙӢбҙҖ!", parse_mode=ParseMode.HTML)

    try:
        char_id = int(character['id'])
        if char_id > 400:
            return await message.reply_text("рҹ’ў <b>бҙӣКңЙӘкңұ бҙ„КңбҙҖКҖбҙҖбҙ„бҙӣбҙҮКҖ ЙӘбҙ… ЙӘкңұ бҙӣбҙҸбҙҸ КңЙӘЙўКң~</b> бҙҸЙҙКҹКҸ ЙӘбҙ…кңұ бҙңбҙҳ бҙӣбҙҸ 400 бҙҖКҖбҙҮ бҙҖКҹКҹбҙҸбҙЎбҙҮбҙ…!", parse_mode=ParseMode.HTML)
    except (ValueError, TypeError):
        return await message.reply_text("рҹ’ў <b>ЙӘЙҙбҙ бҙҖКҹЙӘбҙ… бҙ„КңбҙҖКҖбҙҖбҙ„бҙӣбҙҮКҖ ЙӘбҙ…~</b> КҷбҙҖбҙӢбҙҖ!", parse_mode=ParseMode.HTML)

    allowed_rarities = ["рҹ§¬ Animation", "рҹ§ҝ Galaxia", "вҡЎ Eternal", "рҹҺҗ Celestial"]
    if character.get('rarity') not in allowed_rarities:
        return await message.reply_text("рҹ‘Ҡ <b>бҙӣКңЙӘкңұ бҙҸЙҙбҙҮ ЙӘкңұ ЙҙбҙҸбҙӣ кң°бҙҸКҖ кңұбҙҖКҹбҙҮ~</b> бҙҖКҹКҹбҙҸбҙЎбҙҮбҙ… КҖбҙҖКҖЙӘбҙӣКҸ бҙҸЙҙКҹКҸ бҙҖЙҙЙӘбҙҚбҙҖбҙӣЙӘбҙҸЙҙ , ЙўбҙҖКҹбҙҖxЙӘбҙҖ , бҙҮбҙӣбҙҮКҖЙҙбҙҖКҹ , бҙ„бҙҮКҹбҙҮsбҙӣЙӘбҙҖКҹ ", parse_mode=ParseMode.HTML)

    price = random.randint(1000000, 2000000)
    msg = await send_media_message(message, character, price)
    ags[msg.message_id] = user_id
    pending_purchases[msg.message_id] = (user_id, today)  # Track pending purchase

@app.on_callback_query(filters.regex(r"^(bg|cg):"))
@block_cbq
async def handle_gbuy_callback(client, query: CallbackQuery):
    user_id = query.from_user.id
    data = query.data.split(":")
    action, character_id = data[0], data[1]
    current_user_id = int(data[2 if action == "cg" else 3])

    if user_id != current_user_id:
        return await query.answer("рҹҡ« ЙҙбҙҸбҙӣ КҸбҙҸбҙңКҖ КҖбҙҮQбҙңбҙҮкңұбҙӣ~ кңұбҙӣбҙҸбҙҳ КҷбҙҮЙӘЙҙЙў бҙҖ КҷбҙҖбҙӢбҙҖ!", show_alert=True)

    if action == "bg":
        price = int(data[2])
        user_data = await user_collection.find_one({'id': user_id})

        if user_data['gold'] < price:
            return await query.answer("вқҢ ЙӘЙҙкңұбҙңкң°кң°ЙӘбҙ„ЙӘбҙҮЙҙбҙӣ ЙўбҙҸКҹбҙ…~", show_alert=True)

        character = await collection.find_one({'id': character_id})
        
        try:
            char_id = int(character['id'])
            if char_id > 2500:
                return await query.answer("рҹҡ« бҙӣКңЙӘкңұ бҙ„КңбҙҖКҖбҙҖбҙ„бҙӣбҙҮКҖ ЙӘкңұ ЙҙбҙҸ КҹбҙҸЙҙЙўбҙҮКҖ бҙҖбҙ бҙҖЙӘКҹбҙҖКҷКҹбҙҮ кң°бҙҸКҖ бҙҳбҙңКҖбҙ„КңбҙҖкңұбҙҮ!", show_alert=True)
        except (ValueError, TypeError):
            return await query.answer("рҹҡ« ЙӘЙҙбҙ бҙҖКҹЙӘбҙ… бҙ„КңбҙҖКҖбҙҖбҙ„бҙӣбҙҮКҖ!", show_alert=True)

        allowed_rarities = ["рҹ§¬ Animation", "рҹ§ҝ Galaxia", "вҡЎ Eternal", "рҹҺҗ Celestial"]
        if character.get('rarity') not in allowed_rarities:
            return await query.answer("рҹҡ« бҙӣКңЙӘкңұ бҙ„КңбҙҖКҖбҙҖбҙ„бҙӣбҙҮКҖ ЙӘкңұ ЙҙбҙҸбҙӣ кң°бҙҸКҖ кңұбҙҖКҹбҙҮ!", show_alert=True)

        today = datetime.now().date()
        
        # Check daily limit again right before purchase
        if user_id in daily_purchases:
            last_date, count = daily_purchases[user_id]
            if today == last_date and count >= 3:
                pending_purchases.pop(query.message.message_id, None)
                return await query.answer("рҹҡ« КҸбҙҸбҙң'бҙ бҙҮ КҖбҙҮбҙҖбҙ„КңбҙҮбҙ… КҸбҙҸбҙңКҖ бҙ…бҙҖЙӘКҹКҸ КҹЙӘбҙҚЙӘбҙӣ!", show_alert=True)

        await user_collection.update_one(
            {'id': user_id},
            {'$inc': {'gold': -price}, '$push': {'characters': character}}
        )

        # Update daily purchases count
        if user_id in daily_purchases:
            last_date, count = daily_purchases[user_id]
            daily_purchases[user_id] = (today, count + 1 if today == last_date else 1)
        else:
            daily_purchases[user_id] = (today, 1)

        remaining = max(0, 3 - daily_purchases[user_id][1])
        await query.message.edit_caption(
            caption=f"<b>рҹҚң {character['name']}</b> бҙҳбҙңКҖбҙ„КңбҙҖкңұбҙҮбҙ… кңұбҙңбҙ„бҙ„бҙҮкңұкңұкң°бҙңКҹКҹКҸ~\n\n<b>КҖбҙҮбҙҚбҙҖЙӘЙҙЙӘЙҙЙў бҙӣбҙҸбҙ…бҙҖКҸ:</b> <code>{remaining}</code>",
            parse_mode=ParseMode.HTML
        )
    elif action == "cg":
        await query.message.edit_caption("вқҢ <b>бҙҳбҙңКҖбҙ„КңбҙҖкңұбҙҮ бҙ„бҙҖЙҙбҙ„бҙҮКҹКҹбҙҮбҙ…~</b> бҙҖКҖбҙҖ бҙҖКҖбҙҖ...", parse_mode=ParseMode.HTML)

    ags.pop(query.message.message_id, None)
    pending_purchases.pop(query.message.message_id, None)  # Remove from pending purchases
    await query.answer()
