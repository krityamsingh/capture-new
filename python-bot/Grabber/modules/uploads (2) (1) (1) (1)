# Function to generate event selection buttons
def get_event_buttons(change_mode=False):
    buttons = []
    row = []
    for event_name, emoji in event_emojis.items():
        cb = f"set_event_change_{event_name}" if change_mode else f"set_event_{event_name}"
        row.append(InlineKeyboardButton(f"{emoji} {event_name.split()[-1]}", callback_data=cb))
        if len(row) == 2:
            buttons.append(row)
            row = []
    if row:
        buttons.append(row)
    skip_cb = "set_event_change_None" if change_mode else "set_event_None"
    buttons.append([
        InlineKeyboardButton("⏭ Skip", callback_data=skip_cb),
        InlineKeyboardButton("❌ Cancel", callback_data="cancel_add_waifu")
    ])
    return InlineKeyboardMarkup(buttons)

