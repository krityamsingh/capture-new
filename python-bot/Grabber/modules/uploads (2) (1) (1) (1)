@app.on_callback_query(filters.regex(r'^set_event_change_'))
async def set_event_change_callback(client, callback_query):
    try:
        await callback_query.answer()  # Acknowledge callback to avoid timeout errors

        user_id = callback_query.from_user.id
        selected_event = callback_query.data.split('_', 3)[-1]
        new_event = None if selected_event == "None" else selected_event

        waifu_id = user_states.get(user_id, {}).get("waifu_id")
        if not waifu_id:
            await callback_query.message.edit_text("❌ Waifu ID not found. Please try again.")
            return

        result = await collection.update_one(
            {"id": waifu_id},
            {"$set": {"event": new_event}}
        )

        if result.modified_count:
            await callback_query.message.edit_text(f"✅ Event updated to: `{new_event or 'None'}`")
        else:
            await callback_query.message.edit_text("⚠️ Event was already set or failed to update.")

        user_states.pop(user_id, None)

    except Exception as e:
        print(f"Error in set_event_change_callback: {e}")
        await callback_query.message.edit_text("⚠️ An error occurred while processing your request. Please try again later.")

@app.on_callback_query(filters.regex(r'^destroy_waifu_'))
async def destroy_waifu_callback(client, callback_query):
    """Destroys a waifu permanently without confirmation."""
    waifu_id = callback_query.data.split('_', 2)[-1]

    try:
        # Perform the destruction directly
        waifu = await collection.find_one_and_delete({"id": waifu_id})

        if waifu:
            # Remove from everyone's harem
            await collection.update_many({}, {"$pull": {"harem": waifu_id}})

            # Inform the user and admin channels
            await callback_query.message.edit_text(
                f"✅ **Waifu ID `{waifu_id}` has been permanently destroyed.**"
            )
            await app.send_photo(
                chat_id=CHARA_CHANNEL_ID,
                photo=waifu["img_url"],
                caption=f"⚰️ **Waifu Destroyed**: <a href='tg://user?id={callback_query.from_user.id}'>{callback_query.from_user.first_name}</a> has permanently destroyed character **'{waifu['name']}'**."
            )
            await app.send_photo(
                chat_id=SUPPORT_CHAT,
                photo=waifu["img_url"],
                caption=f"⚰️ **Waifu Destroyed**: <a href='tg://user?id={callback_query.from_user.id}'>{callback_query.from_user.first_name}</a> has permanently destroyed character **'{waifu['name']}'**."
            )
        else:
            await callback_query.message.edit_text("❌ **Waifu not found. Please try again.**")
    except Exception as e:
        await callback_query.message.edit_text(f"⚠️ **An error occurred while destroying the waifu**: {str(e)}")
        print(f"Error in destroy: {e}")


