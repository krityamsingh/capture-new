@app.on_message(filters.private & filters.photo)
async def receive_photo(client, message):
    try:
        user_data = user_states.get(message.from_user.id)

        if user_data:
            if user_data["state"] == "awaiting_waifu_image" and user_data["name"] and user_data["rarity"]:
                photo_file_id = message.photo.file_id
                id = str(await get_next_sequence_number('character_id'))

                character = {
                    'img_url': photo_file_id,
                    'name': user_data["name"],
                    'anime': user_data["anime"],
                    'rarity': user_data["rarity"],
                    'event': user_data.get("event"),
                    'id': id
                }

                await collection.insert_one(character)
                await message.reply_text("⏳ Adding your waifu... Please wait a moment.")

                event_line = f"\n\n{user_data['event']}" if user_data.get("event") else ""

                waifu_caption = (
                    f"OwO! Check out this character!\n\n"
                    f"{user_data['anime']}\n"
                    f"{id}: {user_data['name']}\n"
                    f"{rarity_emojis.get(user_data['rarity'], '')} 𝙍𝘼𝙍𝙄𝙏𝙔: {user_data['rarity'].split()[-1]}"
                    f"{event_line}\n\n"
                    f"➼ ᴀᴅᴅᴇᴅ ʙʏ: [{message.from_user.first_name}](tg://user?id={message.from_user.id})"
                )

                await app.send_photo(chat_id=CHARA_CHANNEL_ID, photo=photo_file_id, caption=waifu_caption)
                await app.send_photo(chat_id=SUPPORT_CHAT, photo=photo_file_id, caption=waifu_caption)

                await message.reply_text("✅ Waifu successfully added to the collection!")

                user_states.pop(message.from_user.id, None)

            elif user_data["state"] == "changing_image" and user_data["waifu_id"]:
                waifu_id = user_data["waifu_id"]
                new_image = message.photo.file_id

                waifu = await collection.find_one_and_update(
                    {"id": waifu_id},
                    {"$set": {"img_url": new_image}},
                    return_document=ReturnDocument.AFTER
                )

                if waifu is not None:
                    await message.reply_text("✅ Character image updated successfully! 🖼️")

                    change_caption = (
                        f"🖼️ Waifu Image Updated!\n\n"
                        f"👤 Updated by: [{message.from_user.first_name}](tg://user?id={message.from_user.id})\n"
                        f"👧 Character: `{waifu.get('name', 'Unknown')}`"
                    )

                    await app.send_photo(chat_id=CHARA_CHANNEL_ID, photo=new_image, caption=change_caption)
                    await app.send_photo(chat_id=SUPPORT_CHAT, photo=new_image, caption=change_caption)

                else:
                    await message.reply_text("❌ Failed to update waifu image. Please try again.")

                user_states.pop(message.from_user.id, None)

    except Exception as e:
        await message.reply_text("⚠️ An error occurred while processing your request. Please try again later.")
        print(f"Error in receive_photo: {str(e)}")

@app.on_inline_query(uploader_filter)
async def search_anime(client, inline_query):
    query = inline_query.query.strip().lower()

    if query.startswith("choose_anime "):
        search_term = query[len("choose_anime "):]
    else:
        return  # Ignore unrelated inline queries

    # If search_term is empty, match all animes
    if search_term:
        regex_filter = {"anime": {"$regex": f"{search_term}", "$options": "i"}}
    else:
        regex_filter = {}

    anime_results = await collection.aggregate([
        {"$match": regex_filter},
        {"$group": {"_id": "$anime", "waifu_count": {"$sum": 1}}},
        {"$sort": {"_id": 1}},  # Sort alphabetically
        {"$limit": 20}
    ]).to_list(length=None)

    results = []

    if not anime_results:
        results.append(
            InlineQueryResultArticle(
                title="❌ No Anime Found",
                description="Try searching with a different name.",
                input_message_content=InputTextMessageContent(
                    "⚠️ No matching anime found! Try using a different keyword."
                )
            )
        )
    else:
        for anime in anime_results:
            title = anime["_id"]
            waifu_count = anime["waifu_count"]
            description = f"👧 Waifus Available: {waifu_count}"

            message_text = (
                f"📺 Anime Title: `{title}`\n"
                f"👧 Total Characters: `{waifu_count}`\n\n"
                f"🔹 You can add or view characters from this anime."
            )

            title_encoded = title[:30]

            inline_buttons = [
                [InlineKeyboardButton("📜 View Characters", switch_inline_query_current_chat=f"{title_encoded}")],
                [InlineKeyboardButton("➕ Add Waifu", callback_data=f"add_waifu_{title_encoded}")]
            ]

            results.append(
                InlineQueryResultArticle(
                    title=title,
                    description=description,
                    input_message_content=InputTextMessageContent(message_text),
                    reply_markup=InlineKeyboardMarkup(inline_buttons)
                )
            )

    await inline_query.answer(results, cache_time=0)

@app.on_inline_query()
async def view_characters(client, inline_query):
    query = inline_query.query.strip().lower()

    if query.startswith("view_chars_"):
        anime_name = query[len("view_chars_"):]
        waifu_results = await collection.find({"anime": anime_name}).to_list(length=50)

        results = []

