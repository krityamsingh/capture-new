@app.on_message(filters.private & (filters.photo | filters.video))
async def receive_media(client, message):
    try:
        user_data = user_states.get(message.from_user.id)

        if user_data:
            media_url = None
            media_type = None

            if message.photo:
                media_url = message.photo.file_id
                media_type = "image"
            elif message.video:
                media_url = message.video.file_id
                media_type = "video"

            if media_url and user_data["state"] == "awaiting_waifu_media" and user_data["name"] and user_data["rarity"]:
                # Handling waifu addition process
                waifu_id = str(await get_next_sequence_number('character_id')).zfill(2)

                waifu_data = {
                    'name': user_data["name"],
                    'anime': user_data["anime"],
                    'rarity': user_data["rarity"],
                    'id': waifu_id,
                }

                if media_type == "image":
                    waifu_data["img_url"] = media_url
                elif media_type == "video":
                    waifu_data["video_url"] = media_url

                await collection.insert_one(waifu_data)
                await message.reply_text("⏳ **Adding your waifu...** Please wait a moment. ✨")

                waifu_caption = (
                    f"🌸 **New Waifu Added!** 🌸\n\n"
                    f"👤 **Added by:** [{message.from_user.first_name}](tg://user?id={message.from_user.id})\n"
                    f"📺 **Anime:** `{user_data['anime']}`\n"
                    f"👧 **Name:** `{user_data['name']}`\n"
                    f"🆔 **Character ID:** `{waifu_id}`\n"
                    f"🎖 **Rarity:** `{user_data['rarity']}`"
                )

                # Sending to CHARACTERS and SUPPORT groups
                if media_type == "image":
                    await app.send_photo(chat_id=CHARA_CHANNEL_ID, photo=media_url, caption=waifu_caption)
                    await app.send_photo(chat_id=SUPPORT_CHAT, photo=media_url, caption=waifu_caption)
                elif media_type == "video":
                    await app.send_video(chat_id=CHARA_CHANNEL_ID, video=media_url, caption=waifu_caption)
                    await app.send_video(chat_id=SUPPORT_CHAT, video=media_url, caption=waifu_caption)

                await message.reply_text("✅ **Waifu successfully added to the collection!** 🎉")
                user_states.pop(message.from_user.id, None)

            elif user_data["state"] == "changing_media" and user_data["waifu_id"]:
                # Handling media update for existing waifu
                waifu_id = user_data["waifu_id"]
                
                update_data = {}
                if media_type == "image":
                    update_data["img_url"] = media_url
                elif media_type == "video":
                    update_data["video_url"] = media_url

                waifu = await collection.find_one_and_update(
                    {"id": waifu_id},
                    {"$set": update_data},
                    return_document=ReturnDocument.AFTER
                )

                if waifu:
                    await message.reply_text("✅ **Character media updated successfully!** 🖼️🎥")
                    
                    change_caption = (
                        f"🔄 **Waifu Media Updated!** 🔄\n\n"
                        f"👤 **Updated by:** [{message.from_user.first_name}](tg://user?id={message.from_user.id})\n"
                        f"👧 **Character:** `{waifu.get('name', 'Unknown')}`"
                    )

                    # Sending updated media
                    if media_type == "image":
                        await app.send_photo(chat_id=CHARA_CHANNEL_ID, photo=media_url, caption=change_caption)
                        await app.send_photo(chat_id=SUPPORT_CHAT, photo=media_url, caption=change_caption)
                    elif media_type == "video":
                        await app.send_video(chat_id=CHARA_CHANNEL_ID, video=media_url, caption=change_caption)
                        await app.send_video(chat_id=SUPPORT_CHAT, video=media_url, caption=change_caption)
                else:
                    await message.reply_text("❌ **Failed to update waifu media.** Please try again.")

                user_states.pop(message.from_user.id, None)

    except Exception as e:
        await message.reply_text("⚠️ **An error occurred while processing your request.** Please try again later.")
        print(f"Error in receive_media: {str(e)}")

@app.on_inline_query(uploader_filter)
async def search_anime(client, inline_query):
    query = inline_query.query.strip().lower()
    
    if query.startswith("choose_anime "):
        query = query[len("choose_anime "):]

        anime_results = await collection.aggregate([
            {"$match": {"anime": {"$regex": query, "$options": "i"}}},
            {"$group": {"_id": "$anime", "waifu_count": {"$sum": 1}}},
            {"$limit": 10}
        ]).to_list(length=None)

        results = []

        if not anime_results:
            results.append(
                InlineQueryResultArticle(
                    title="❌ No Anime Found",
                    description="Try searching with a different name.",
                    input_message_content=InputTextMessageContent(
                        "⚠️ No matching anime found! Try using a different keyword."
                    )
                )
            )
        else:
            for anime in anime_results:
                title = anime["_id"]
                waifu_count = anime["waifu_count"]
                description = f"👧 **Waifus Available:** {waifu_count} waifus"
                message_text = (
                    f"📺 **Anime Title:** `{title}`\n"
                    f"👧 **Total Characters:** `{waifu_count}`\n\n"
                    f"🔹 You can add, rename, remove, or view characters from this anime."
                )
                
                title_encoded = title[:30]  # Truncate for callback safety

                inline_buttons = [
                    [InlineKeyboardButton("📜 View Characters", switch_inline_query_current_chat=f"view_chars {title}")],
                    [InlineKeyboardButton("➕ Add Waifu", callback_data=f"add_waifu_{title_encoded}")],
                    [InlineKeyboardButton("✏ Rename Anime", callback_data=f"rename_anime_{title_encoded}")],
                    [InlineKeyboardButton("🗑 Remove Anime", callback_data=f"remove_anime_{title_encoded}")]
                ]
                reply_markup = InlineKeyboardMarkup(inline_buttons)

                results.append(
                    InlineQueryResultArticle(
                        title=title,
                        description=description,
                        input_message_content=InputTextMessageContent(message_text),
                        reply_markup=reply_markup
                    )
                )

        await inline_query.answer(results, cache_time=1)

@app.on_inline_query(uploader_filter)
async def search_characters(client, inline_query):
    query = inline_query.query.strip()

    if query.startswith("view_chars "):
        anime_title = query[len("view_chars "):]

        # Fetch characters from database
        character_results = await collection.find(
            {"anime": anime_title}, {"_id": 0, "character": 1, "rarity": 1, "image": 1}
        ).to_list(length=50)  # Fetch up to 50 characters

        results = []

        if not character_results:
            results.append(
                InlineQueryResultArticle(
                    title="❌ No Characters Found",
                    description=f"No characters available for {anime_title}.",
                    input_message_content=InputTextMessageContent(
                        f"⚠️ No characters found for `{anime_title}`. Try adding some first!"
                    )
                )
            )
        else:
            for char in character_results:
                char_name = char["character"]
                rarity = char["rarity"]
                image_url = char.get("image", None)  # Get image if available

                description = f"⭐ Rarity: {rarity}"
                message_text = (
                    f"📜 **Character Name:** `{char_name}`\n"
                    f"📺 **Anime:** `{anime_title}`\n"
                    f"⭐ **Rarity:** `{rarity}`\n\n"
                    f"🔹 Manage this character from the main menu."
                )

                if image_url:
                    results.append(
                        InlineQueryResultPhoto(
                            photo_url=image_url,
                            thumb_url=image_url,  # Thumbnail same as main image
                            title=char_name,
                            description=description,
                            caption=message_text
                        )
                    )
                else:
                    results.append(
                        InlineQueryResultArticle(
                            title=char_name,
                            description=description,
                            input_message_content=InputTextMessageContent(message_text)
                        )
                    )

        await inline_query.answer(results, cache_time=1)


@app.on_message(filters.private & filters.text)
async def receive_text_message(client, message):
    user_data = user_states.get(message.from_user.id)

    if not user_data:
        return  # Ignore messages from users not in an active session

    user_id = message.from_user.id
    first_name = message.from_user.first_name
    user_mention = f"<a href='tg://user?id={user_id}'>{first_name}</a>"
    user_input = message.text.strip()

    if user_data["state"] == "awaiting_waifu_name" and user_data["anime"]:
        # Handling new waifu name input
        user_states[user_id]["name"] = user_input
        user_states[user_id]["state"] = "awaiting_waifu_rarity"
        
        await message.reply_text(
            f"🌟 **Great Choice!**\n\n"
            f"Now, choose a **rarity level** for **{user_input}**:",
            reply_markup=InlineKeyboardMarkup(
                [
                    [InlineKeyboardButton(f" {rarity} ", callback_data=f"select_rarity_{rarity}")]
                    for rarity in rarity_emojis.keys()
                ]
            )
        )

    elif user_data["state"] == "adding_anime":
        # Handling new anime addition
        existing_anime = await collection.find_one({"anime": user_input})
        
        if existing_anime:
            await message.reply_text(f"⚠️ The anime **'{user_input}'** already exists!")
        else:
            anime_document = {"anime": user_input}
            await collection.insert_one(anime_document)
            await message.reply_text(f"✅ **'{user_input}'** has been added to the anime list!")

            # Enhanced Notification Format with User Mention
            announcement_text = (
                f"✨ ** #New Anime Added!** ✨\n\n"
                f"📺 **Title:** `{user_input}`\n"
                f"👤 **Added by:** {user_mention}\n"
            )

            # Send announcement to Chara Channel and Support Chat
            await app.send_message(CHARA_CHANNEL_ID, announcement_text)
            await app.send_message(SUPPORT_CHAT, announcement_text)

        user_states.pop(user_id, None)

    elif user_data["state"] == "renaming_anime" and user_data["anime"]:
        # Handling anime renaming
        old_anime_name = user_data["anime"]
        await collection.update_many({"anime": old_anime_name}, {"$set": {"anime": user_input}})

        notification_text = (
            f"📢 **Anime Renamed!**\n\n"
            f"🔄 **Old Name:** `{old_anime_name}`\n"
            f"✨ **New Name:** `{user_input}`\n"
            f"👤 **Renamed by:** {user_mention}"
        )

        await message.reply_text(f"✅ **'{old_anime_name}'** has been renamed to **'{user_input}'**!")
        await app.send_message(CHARA_CHANNEL_ID, f"🔔 #𝗥𝗘𝗡𝗔𝗠𝗘𝗔𝗡𝗜𝗠𝗘\n\n{notification_text}")
        await app.send_message(SUPPORT_CHAT, f"🔔 #𝗥𝗘𝗡𝗔𝗠𝗘𝗔𝗡𝗜𝗠𝗘\n\n{notification_text}")

        user_states.pop(user_id, None)

    elif user_data["state"] == "renaming_waifu" and user_data["waifu_id"]:
        # Handling waifu renaming
        waifu_id = user_data["waifu_id"]
        waifu = await collection.find_one({"id": waifu_id})

        if waifu:
            old_name = waifu["name"]
            await collection.update_one({"id": waifu_id}, {"$set": {"name": user_input}})

            # Select media (video if available, otherwise image)
            media = waifu.get("video_url") or waifu.get("img_url")
            send_media = app.send_video if "video_url" in waifu else app.send_photo

            notification_text = (
                f"📢 **Waifu Renamed!**\n\n"
                f"🔄 **Old Name:** `{old_name}`\n"
                f"✨ **New Name:** `{user_input}`\n"
                f"👤 **Renamed by:** {user_mention}"
            )

            await message.reply_text(f"✅ **{old_name}** has been renamed to **{user_input}**!")

            # Send update to Chara Channel & Support Chat
            await send_media(
                chat_id=CHARA_CHANNEL_ID,
                video=media if "video_url" in waifu else None,
                photo=media if "img_url" in waifu else None,
                caption=f"🔔 #𝗖𝗛𝗔𝗡𝗚𝗘𝗗𝗡𝗔𝗠𝗘\n\n{notification_text}"
            )
            await send_media(
                chat_id=SUPPORT_CHAT,
                video=media if "video_url" in waifu else None,
                photo=media if "img_url" in waifu else None,
                caption=f"🔔 #𝗖𝗛𝗔𝗡𝗚𝗘𝗗𝗡𝗔𝗠𝗘\n\n{notification_text}"
            )
        else:
            await message.reply_text("❌ **Failed to rename the waifu.** Please try again.")
        
        user_states.pop(user_id, None)

