@app.on_callback_query(filters.regex(r'^set_rarity_'))
async def set_rarity_callback(client, callback_query):
    """Updates the rarity of a selected waifu."""
    try:
        _, new_rarity, waifu_id = callback_query.data.rsplit('_', 2)

        waifu = await collection.find_one({"id": waifu_id})
        if not waifu:
            await callback_query.answer("❌ **Waifu not found.** Please try again.", show_alert=True)
            return

        old_rarity = waifu["rarity"]
        await collection.update_one({"id": waifu_id}, {"$set": {"rarity": new_rarity}})

        updated_waifu = await collection.find_one({"id": waifu_id})

        # Select media (video if available, otherwise image)
        media = updated_waifu.get("video_url") or updated_waifu.get("img_url")
        send_media = app.send_video if "video_url" in updated_waifu else app.send_photo

        # Prepare update message
        update_message = (
            f"✨ **Rarity Updated!**\n"
            f"👧 **Waifu:** `{updated_waifu['name']}`\n"
            f"🔄 **Old Rarity:** `{old_rarity}`\n"
            f"🌟 **New Rarity:** `{new_rarity}`"
        )

        # Send update to user
        await send_media(
            chat_id=callback_query.from_user.id,
            video=media if "video_url" in updated_waifu else None,
            photo=media if "img_url" in updated_waifu else None,
            caption=update_message
        )

        # Notify Admin/Support Channels
        await send_media(
            chat_id=CHARA_CHANNEL_ID,
            video=media if "video_url" in updated_waifu else None,
            photo=media if "img_url" in updated_waifu else None,
            caption=update_message
        )
        await send_media(
            chat_id=SUPPORT_CHAT,
            video=media if "video_url" in updated_waifu else None,
            photo=media if "img_url" in updated_waifu else None,
            caption=update_message
        )

        await callback_query.message.edit_text(f"✅ **Rarity successfully updated** to `{new_rarity}`.")
    except Exception as e:
        await callback_query.answer("⚠️ **An error occurred.** Please try again.", show_alert=True)
        print(f"Error in set_rarity_callback: {str(e)}")

@app.on_callback_query(filters.regex(r'^destroy_waifu_'))
async def destroy_waifu_callback(client, callback_query):
    """Destroys a waifu permanently without confirmation."""
    waifu_id = callback_query.data.split('_', 2)[-1]

    try:
        # Fetch waifu details
        waifu = await collection.find_one_and_delete({"id": waifu_id})

        if waifu:
            # Remove from everyone's harem
            await collection.update_many({}, {"$pull": {"harem": waifu_id}})

            # Choose whether to send image or video
            media = waifu.get("video_url") or waifu.get("img_url")
            send_media = app.send_video if "video_url" in waifu else app.send_photo

            # Inform the user and admin channels
            await callback_query.message.edit_text(
                f"✅ **Waifu ID `{waifu_id}` has been permanently destroyed.**"
            )
            await send_media(
                chat_id=CHARA_CHANNEL_ID,
                video=media if "video_url" in waifu else None,
                photo=media if "img_url" in waifu else None,
                caption=f"⚰️ **Waifu Destroyed**: <a href='tg://user?id={callback_query.from_user.id}'>{callback_query.from_user.first_name}</a> has permanently destroyed character **'{waifu['name']}'**."
            )
            await send_media(
                chat_id=SUPPORT_CHAT,
                video=media if "video_url" in waifu else None,
                photo=media if "img_url" in waifu else None,
                caption=f"⚰️ **Waifu Destroyed**: <a href='tg://user?id={callback_query.from_user.id}'>{callback_query.from_user.first_name}</a> has permanently destroyed character **'{waifu['name']}'**."
            )
        else:
            await callback_query.message.edit_text("❌ **Waifu not found. Please try again.**")
